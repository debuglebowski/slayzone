+  ~SlayzoneUsageUI() override;
+
+  void BindInterface(
+      mojo::PendingReceiver<slayzone::usage::mojom::UsageHost> receiver);
+
+ private:
+  std::unique_ptr<slayzone::SlayzoneUsageHost> host_;
+
+  WEB_UI_CONTROLLER_TYPE_DECL();
+};
