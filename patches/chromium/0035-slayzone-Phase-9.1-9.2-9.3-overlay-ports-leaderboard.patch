+
+#include "chrome/browser/slayzone/slayzone_leaderboard_host.h"
+
+#include <string>
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "base/values.h"
+#include "chrome/browser/slayzone/sidecar_client.h"
+
+namespace slayzone {
+
+namespace {
+
+leaderboard::mojom::LeaderboardSnapshotPtr FromDict(
+    const base::DictValue& response) {
+  auto snapshot = leaderboard::mojom::LeaderboardSnapshot::New();
+  const base::Value* result = response.Find("result");
+  const base::DictValue* dict =
+      (result && result->is_dict()) ? &result->GetDict() : nullptr;
+  if (!dict) {
+    return snapshot;
+  }
+
+  snapshot->total = dict->FindInt("total").value_or(0);
+  if (const std::string* uid = dict->FindString("currentUserId")) {
+    snapshot->current_user_id = *uid;
+  }
+
+  const base::ListValue* list = dict->FindList("rows");
+  if (list) {
+    for (const base::Value& entry : *list) {
+      if (!entry.is_dict()) {
+        continue;
+      }
+      const base::DictValue& e = entry.GetDict();
+      auto row = leaderboard::mojom::LeaderboardRow::New();
+      if (const std::string* id = e.FindString("id")) {
+        row->id = *id;
+      }
+      if (const std::string* name = e.FindString("name")) {
+        row->name = *name;
+      }
+      row->rank = e.FindInt("rank").value_or(0);
+      row->score = e.FindInt("score").value_or(0);
+      row->streak_days = e.FindInt("streakDays").value_or(0);
+      if (const std::string* avatar = e.FindString("avatarUrl")) {
+        row->avatar_url = *avatar;
+      }
+      if (const std::string* tier = e.FindString("tier")) {
+        row->tier = *tier;
+      }
+      snapshot->rows.push_back(std::move(row));
+    }
+  }
+
+  return snapshot;
+}
+
+}  // namespace
