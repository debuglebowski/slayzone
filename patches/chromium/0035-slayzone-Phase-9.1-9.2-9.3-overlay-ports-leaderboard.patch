+namespace {
+
+constexpr std::string_view kUsageMissingBundleHtml =
+    R"HTML(<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <title>SlayZone · usage</title>
+  <style>
+    :root { color-scheme: light dark; }
+    html, body { margin: 0; height: 100%; font: 11px/1.3 system-ui, sans-serif; }
+    body {
+      display: flex; align-items: center; padding: 0 10px;
+      background: #3a1a1a; color: #fca5a5;
+      border-left: 1px solid #6b2020;
+    }
+  </style>
+</head>
+<body>
+  <span>usage: bundle missing — pass --slayzone-webui-bundle-dir=&lt;repo&gt;/packages/webui</span>
+</body>
+</html>)HTML";
+
+}  // namespace
+
+SlayzoneUsageUI::SlayzoneUsageUI(content::WebUI* web_ui)
+    : content::WebUIController(web_ui),
+      host_(std::make_unique<slayzone::SlayzoneUsageHost>()) {
+  auto* source = content::WebUIDataSource::CreateAndAdd(
+      Profile::FromWebUI(web_ui), chrome::kChromeUISlayzoneUsageHost);
+  slayzone::ConfigureBundleSource(source, "usage", kUsageMissingBundleHtml);
+}
+
+SlayzoneUsageUI::~SlayzoneUsageUI() = default;
+
+WEB_UI_CONTROLLER_TYPE_IMPL(SlayzoneUsageUI)
+
+void SlayzoneUsageUI::BindInterface(
+    mojo::PendingReceiver<slayzone::usage::mojom::UsageHost> receiver) {
+  host_->Bind(std::move(receiver));
+}
