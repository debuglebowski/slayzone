@@ -0,0 +1,122 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/slayzone/slayzone_context_host.h"
+
+#include <string>
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "base/values.h"
+#include "chrome/browser/slayzone/sidecar_client.h"
+
+namespace slayzone {
+
+namespace {
+
+context::mojom::ContextSnapshotPtr FromDict(const base::DictValue& response) {
+  auto snapshot = context::mojom::ContextSnapshot::New();
+  const base::Value* result = response.Find("result");
+  const base::DictValue* dict =
+      (result && result->is_dict()) ? &result->GetDict() : nullptr;
+  if (!dict) {
+    return snapshot;
+  }
+
+  if (const std::string* active = dict->FindString("activeProjectId")) {
+    snapshot->active_project_id = *active;
+  }
+  if (const std::string* active = dict->FindString("activeProfileId")) {
+    snapshot->active_profile_id = *active;
+  }
+
+  if (const base::ListValue* list = dict->FindList("providers")) {
+    for (const base::Value& entry : *list) {
+      if (!entry.is_dict()) {
+        continue;
+      }
+      const base::DictValue& e = entry.GetDict();
+      auto p = context::mojom::ProviderEntry::New();
+      if (const std::string* v = e.FindString("id")) p->id = *v;
+      if (const std::string* v = e.FindString("label")) p->label = *v;
+      if (const std::string* v = e.FindString("status")) p->status = *v;
+      p->connected = e.FindBool("connected").value_or(false);
+      snapshot->providers.push_back(std::move(p));
+    }
+  }
+
+  if (const base::ListValue* list = dict->FindList("profiles")) {
+    for (const base::Value& entry : *list) {
+      if (!entry.is_dict()) {
+        continue;
+      }
+      const base::DictValue& e = entry.GetDict();
+      auto p = context::mojom::ProfileEntry::New();
+      if (const std::string* v = e.FindString("id")) p->id = *v;
+      if (const std::string* v = e.FindString("name")) p->name = *v;
+      if (const std::string* v = e.FindString("providerId")) p->provider_id = *v;
+      p->active = e.FindBool("active").value_or(false);
+      snapshot->profiles.push_back(std::move(p));
+    }
+  }
+
+  if (const base::ListValue* list = dict->FindList("skills")) {
+    for (const base::Value& entry : *list) {
+      if (!entry.is_dict()) {
+        continue;
+      }
+      const base::DictValue& e = entry.GetDict();
+      auto s = context::mojom::SkillEntry::New();
+      if (const std::string* v = e.FindString("id")) s->id = *v;
+      if (const std::string* v = e.FindString("name")) s->name = *v;
+      if (const std::string* v = e.FindString("source")) s->source = *v;
+      s->stale = e.FindBool("stale").value_or(false);
+      snapshot->skills.push_back(std::move(s));
+    }
+  }
+
+  if (const base::ListValue* list = dict->FindList("mcpServers")) {
+    for (const base::Value& entry : *list) {
+      if (!entry.is_dict()) {
+        continue;
+      }
+      const base::DictValue& e = entry.GetDict();
+      auto m = context::mojom::McpServerEntry::New();
+      if (const std::string* v = e.FindString("id")) m->id = *v;
+      if (const std::string* v = e.FindString("name")) m->name = *v;
+      if (const std::string* v = e.FindString("transport")) m->transport = *v;
+      m->connected = e.FindBool("connected").value_or(false);
+      snapshot->mcp_servers.push_back(std::move(m));
+    }
+  }
+
+  return snapshot;
+}
+
+}  // namespace
+
+SlayzoneContextHost::SlayzoneContextHost() = default;
+SlayzoneContextHost::~SlayzoneContextHost() = default;
+
+void SlayzoneContextHost::Bind(
+    mojo::PendingReceiver<context::mojom::ContextHost> receiver) {
+  receivers_.Add(this, std::move(receiver));
+}
+
+void SlayzoneContextHost::GetSnapshot(const std::string& project_id,
+                                      GetSnapshotCallback callback) {
+  base::ListValue params;
+  params.Append(project_id);
+  base::DictValue request;
+  request.Set("params", std::move(params));
+  SidecarClient::GetInstance()->Call(
+      "context:get-snapshot", std::move(request),
+      base::BindOnce(
+          [](GetSnapshotCallback cb, base::DictValue response) {
+            std::move(cb).Run(FromDict(response));
+          },
+          std::move(callback)));
+}
+
+}  // namespace slayzone
