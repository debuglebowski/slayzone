@@ -0,0 +1,141 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/slayzone/slayzone_usage_host.h"
+
+#include <string>
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "base/values.h"
+#include "chrome/browser/slayzone/sidecar_client.h"
+
+namespace slayzone {
+
+namespace {
+
+usage::mojom::UsageSnapshotPtr FromDict(const base::DictValue& response) {
+  auto snapshot = usage::mojom::UsageSnapshot::New();
+  const base::Value* result = response.Find("result");
+  const base::DictValue* dict =
+      (result && result->is_dict()) ? &result->GetDict() : nullptr;
+  if (!dict) {
+    return snapshot;
+  }
+
+  // int64 fields land as doubles over JSON-RPC; read as double then cast.
+  const auto as_int64 = [&](const char* key) -> int64_t {
+    if (auto v = dict->FindDouble(key)) {
+      return static_cast<int64_t>(*v);
+    }
+    return dict->FindInt(key).value_or(0);
+  };
+
+  snapshot->total_input_tokens = as_int64("totalInputTokens");
+  snapshot->total_output_tokens = as_int64("totalOutputTokens");
+  snapshot->total_cache_read_tokens = as_int64("totalCacheReadTokens");
+  snapshot->total_cache_write_tokens = as_int64("totalCacheWriteTokens");
+  snapshot->total_cost_usd = dict->FindDouble("totalCostUsd").value_or(0.0);
+  snapshot->total_messages = dict->FindInt("totalMessages").value_or(0);
+  snapshot->provider_supported =
+      dict->FindBool("providerSupported").value_or(true);
+  if (const std::string* label = dict->FindString("providerLabel")) {
+    snapshot->provider_label = *label;
+  }
+
+  const auto as_entry_int64 = [](const base::DictValue& e,
+                                 const char* key) -> int64_t {
+    if (auto v = e.FindDouble(key)) {
+      return static_cast<int64_t>(*v);
+    }
+    return e.FindInt(key).value_or(0);
+  };
+
+  if (const base::ListValue* list = dict->FindList("byDay")) {
+    for (const base::Value& entry : *list) {
+      if (!entry.is_dict()) {
+        continue;
+      }
+      const base::DictValue& e = entry.GetDict();
+      auto b = usage::mojom::DayBucket::New();
+      if (const std::string* d = e.FindString("date")) {
+        b->date = *d;
+      }
+      b->input_tokens = as_entry_int64(e, "inputTokens");
+      b->output_tokens = as_entry_int64(e, "outputTokens");
+      b->cache_read_tokens = as_entry_int64(e, "cacheReadTokens");
+      b->cache_write_tokens = as_entry_int64(e, "cacheWriteTokens");
+      b->cost_usd = e.FindDouble("costUsd").value_or(0.0);
+      snapshot->by_day.push_back(std::move(b));
+    }
+  }
+
+  if (const base::ListValue* list = dict->FindList("byModel")) {
+    for (const base::Value& entry : *list) {
+      if (!entry.is_dict()) {
+        continue;
+      }
+      const base::DictValue& e = entry.GetDict();
+      auto b = usage::mojom::ModelBucket::New();
+      if (const std::string* m = e.FindString("model")) {
+        b->model = *m;
+      }
+      b->input_tokens = as_entry_int64(e, "inputTokens");
+      b->output_tokens = as_entry_int64(e, "outputTokens");
+      b->cost_usd = e.FindDouble("costUsd").value_or(0.0);
+      snapshot->by_model.push_back(std::move(b));
+    }
+  }
+
+  if (const base::ListValue* list = dict->FindList("byTask")) {
+    for (const base::Value& entry : *list) {
+      if (!entry.is_dict()) {
+        continue;
+      }
+      const base::DictValue& e = entry.GetDict();
+      auto b = usage::mojom::TaskBucket::New();
+      if (const std::string* t = e.FindString("taskId")) {
+        b->task_id = *t;
+      }
+      if (const std::string* t = e.FindString("taskTitle")) {
+        b->task_title = *t;
+      }
+      b->total_tokens = as_entry_int64(e, "totalTokens");
+      b->cost_usd = e.FindDouble("costUsd").value_or(0.0);
+      b->message_count = e.FindInt("messageCount").value_or(0);
+      snapshot->by_task.push_back(std::move(b));
+    }
+  }
+
+  return snapshot;
+}
+
+}  // namespace
+
+SlayzoneUsageHost::SlayzoneUsageHost() = default;
+SlayzoneUsageHost::~SlayzoneUsageHost() = default;
+
+void SlayzoneUsageHost::Bind(
+    mojo::PendingReceiver<usage::mojom::UsageHost> receiver) {
+  receivers_.Add(this, std::move(receiver));
+}
+
+void SlayzoneUsageHost::GetSnapshot(const std::string& range_key,
+                                    const std::string& provider_filter,
+                                    GetSnapshotCallback callback) {
+  base::ListValue params;
+  params.Append(range_key);
+  params.Append(provider_filter);
+  base::DictValue request;
+  request.Set("params", std::move(params));
+  SidecarClient::GetInstance()->Call(
+      "usage:get-snapshot", std::move(request),
+      base::BindOnce(
+          [](GetSnapshotCallback cb, base::DictValue response) {
+            std::move(cb).Run(FromDict(response));
+          },
+          std::move(callback)));
+}
+
+}  // namespace slayzone
