+
+// CLI switch pointing at the outer-repo `packages/webui/` root. Set by
+// scripts/chromium/run.sh; when missing the statusbar UI renders an inline
+// error page so the failure mode is visible at a glance.
+constexpr char kSlayzoneWebUIBundleDirSwitch[] = "slayzone-webui-bundle-dir";
+
+// Inline fallback served when the bundle dir is missing or the file read
+// fails. Deliberately minimal — a non-empty body so the WebView shows
+// something, and a clear message pointing at the probable root cause.
+constexpr std::string_view kStatusbarMissingBundleHtml =
+    R"HTML(<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <title>SlayZone · statusbar</title>
+  <style>
+    :root { color-scheme: light dark; }
+    html, body { margin: 0; height: 100%; font: 11px/1.3 system-ui, sans-serif; }
+    body {
+      display: flex; align-items: center; padding: 0 10px;
+      background: #3a1a1a; color: #fca5a5;
+      border-top: 1px solid #6b2020;
+    }
+  </style>
+</head>
+<body>
+  <span>statusbar: bundle missing — pass --slayzone-webui-bundle-dir=&lt;repo&gt;/packages/webui</span>
+</body>
+</html>)HTML";
+
+base::FilePath ResolveBundleRoot() {
+  const base::CommandLine* cli = base::CommandLine::ForCurrentProcess();
+  if (!cli->HasSwitch(kSlayzoneWebUIBundleDirSwitch)) {
+    return base::FilePath();
+  }
+  return cli->GetSwitchValuePath(kSlayzoneWebUIBundleDirSwitch);
+}
+
+// Blocking file read — hopped to a MayBlock worker below. Returns the file
+// bytes or the fallback HTML when the file is missing.
+scoped_refptr<base::RefCountedMemory> ReadBundleFileOnWorker(
+    base::FilePath full_path,
+    bool is_index) {
+  std::string contents;
+  if (base::ReadFileToString(full_path, &contents)) {
+    return base::MakeRefCounted<base::RefCountedString>(std::move(contents));
+  }
+  if (is_index) {
+    return base::MakeRefCounted<base::RefCountedString>(
+        std::string(kStatusbarMissingBundleHtml));
+  }
+  // Non-index miss — let the resource 404 with an empty body; the page
+  // itself already loaded so the asset miss becomes a console error, not
+  // a WebContents-level failure.
+  return base::MakeRefCounted<base::RefCountedString>(std::string());
+}
+
+bool ShouldHandleAnyPath(const std::string& path) {
+  return true;
+}
+
+void HandleStatusbarRequest(const std::string& path,
+                            content::WebUIDataSource::GotDataCallback callback) {
+  base::FilePath bundle_root = ResolveBundleRoot();
+  if (bundle_root.empty()) {
+    std::move(callback).Run(base::MakeRefCounted<base::RefCountedString>(
+        std::string(kStatusbarMissingBundleHtml)));
+    return;
+  }
+
+  // `path` is the request path after the host, e.g. "" for the document
+  // root, "assets/index-XXXX.js" for an emitted asset. Strip any leading
+  // slash defensively and map empty → index.html.
+  std::string rel = path;
+  if (!rel.empty() && rel.front() == '/') {
+    rel.erase(0, 1);
+  }
+  const bool is_index = rel.empty();
+  if (is_index) {
+    rel = "index.html";
+  }
+
+  const base::FilePath full = bundle_root.AppendASCII("statusbar")
+                                   .AppendASCII("dist")
+                                   .AppendASCII(rel);
+
+  base::ThreadPool::PostTaskAndReplyWithResult(
+      FROM_HERE, {base::MayBlock(), base::TaskPriority::USER_VISIBLE},
+      base::BindOnce(&ReadBundleFileOnWorker, full, is_index),
+      std::move(callback));
+}
+
+}  // namespace
+
+SlayzoneStatusbarUI::SlayzoneStatusbarUI(content::WebUI* web_ui)
+    : content::WebUIController(web_ui) {
+  auto* source = content::WebUIDataSource::CreateAndAdd(
+      Profile::FromWebUI(web_ui), chrome::kChromeUISlayzoneStatusbarHost);
+  source->SetRequestFilter(base::BindRepeating(&ShouldHandleAnyPath),
+                           base::BindRepeating(&HandleStatusbarRequest));
+  // The Vite-built bundle emits a hashed <script> + <link rel=stylesheet>
+  // under /assets/. Allow those from the same chrome:// origin, plus
+  // chrome://resources/ for the Mojo JS runtime that the generated
+  // statusbar bindings import at module evaluation time.
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::ScriptSrc,
+      "script-src 'self' chrome://resources;");
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::StyleSrc,
+      "style-src 'self' 'unsafe-inline';");
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::FontSrc,
+      "font-src 'self' data:;");
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::ImgSrc,
+      "img-src 'self' data:;");
+  source->DisableTrustedTypesCSP();
+}
+
+SlayzoneStatusbarUI::~SlayzoneStatusbarUI() = default;
+
+WEB_UI_CONTROLLER_TYPE_IMPL(SlayzoneStatusbarUI)
+
+void SlayzoneStatusbarUI::BindInterface(
+    mojo::PendingReceiver<slayzone::statusbar::mojom::StatusbarHost>
+        receiver) {
+  SlayzoneBrowserView* view =
+      SlayzoneBrowserView::FromRegionWebContents(web_ui()->GetWebContents());
+  if (!view || !view->statusbar_host()) {
+    // No owning view — happens when chrome://slayzone-statusbar/ is loaded
+    // in a regular tab (e.g. for manual inspection) rather than as a region
+    // WebView. Drop the receiver; callers retry or surface the gap in UI.
+    return;
+  }
+  view->statusbar_host()->Bind(std::move(receiver));
+}
