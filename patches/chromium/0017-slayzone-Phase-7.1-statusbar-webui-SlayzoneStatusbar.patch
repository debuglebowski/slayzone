-    while (!cl_value.empty() && (cl_value.front() == ' ' ||
-                                  cl_value.front() == '\t')) {
-      cl_value.remove_prefix(1);
-    }
-    size_t cl_end = cl_value.find_first_of("\r\n");
-    if (cl_end != std::string_view::npos) {
-      cl_value = cl_value.substr(0, cl_end);
-    }
-    size_t body_len = 0;
-    if (!base::StringToSizeT(cl_value, &body_len) ||
-        body_len > kMaxRecvBuffer) {
-      consumed += header_end + 4;
-      continue;
-    }
-    if (view.size() < header_end + 4 + body_len) {
-      break;  // incomplete
-    }
-    std::string_view body = view.substr(header_end + 4, body_len);
-    std::optional<base::DictValue> parsed =
-        base::JSONReader::ReadDict(body, base::JSON_PARSE_RFC);
-    if (parsed) {
-      out.push_back(std::move(*parsed));
-    }
-    consumed += header_end + 4 + body_len;
+  while (consumed < buffer.size()) {
+    size_t newline = buffer.find('\n', consumed);
+    if (newline == std::string::npos) {
+      break;  // incomplete line; wait for more bytes
+    }
+    std::string_view line(buffer);
+    line = line.substr(consumed, newline - consumed);
+    if (!line.empty()) {
+      std::optional<base::DictValue> parsed =
+          base::JSONReader::ReadDict(line, base::JSON_PARSE_RFC);
+      if (parsed) {
+        out.push_back(std::move(*parsed));
+      }
+      // Malformed lines are dropped — single corrupt line should not kill
+      // the connection; the sidecar uses the same lenient policy.
+    }
+    consumed = newline + 1;
   }
   return consumed;
 }
diff --git a/chrome/browser/slayzone/slayzone_statusbar_host.cc b/chrome/browser/slayzone/slayzone_statusbar_host.cc
new file mode 100644
index 0000000000000..2216b20806919
--- /dev/null
+++ b/chrome/browser/slayzone/slayzone_statusbar_host.cc
@@ -0,0 +1,73 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/slayzone/slayzone_statusbar_host.h"
+
+#include <string>
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "base/values.h"
+#include "chrome/browser/slayzone/sidecar_client.h"
+
+namespace slayzone {
+
+namespace {
+
+// Translate the sidecar's JSON response into a Mojo snapshot. The sidecar
+// sends `{ activeTaskTitle, openTaskCount, sidecarConnected }`; missing
+// fields fall back to neutral defaults so we can still render a frame even
+// if the sidecar is handshaking or mid-reconnect.
+statusbar::mojom::StatusbarSnapshotPtr FromDict(
+    const base::DictValue& response,
+    bool connected) {
+  auto snapshot = statusbar::mojom::StatusbarSnapshot::New();
+  const base::Value* result = response.Find("result");
+  const base::DictValue* dict =
+      (result && result->is_dict()) ? &result->GetDict() : nullptr;
+  if (dict) {
+    if (const std::string* title = dict->FindString("activeTaskTitle")) {
+      snapshot->active_task_title = *title;
+    }
+    if (std::optional<int> count = dict->FindInt("openTaskCount")) {
+      snapshot->open_task_count = static_cast<uint32_t>(*count);
+    }
+  }
+  // Trust the transport: if we got a response at all the sidecar is
+  // connected. An explicit `sidecarConnected=false` in the payload overrides
+  // that (e.g. sidecar reports a degraded state); otherwise default to
+  // `connected` from the caller's context.
+  if (dict && dict->contains("sidecarConnected")) {
+    snapshot->sidecar_connected = dict->FindBool("sidecarConnected").value_or(connected);
+  } else {
+    snapshot->sidecar_connected = connected;
+  }
+  return snapshot;
+}
+
+}  // namespace
+
+SlayzoneStatusbarHost::SlayzoneStatusbarHost() = default;
+SlayzoneStatusbarHost::~SlayzoneStatusbarHost() = default;
+
+void SlayzoneStatusbarHost::Bind(
+    mojo::PendingReceiver<statusbar::mojom::StatusbarHost> receiver) {
+  receivers_.Add(this, std::move(receiver));
+}
+
+void SlayzoneStatusbarHost::GetSnapshot(GetSnapshotCallback callback) {
+  SidecarClient::GetInstance()->Call(
+      "statusbar:get-snapshot", base::DictValue(),
+      base::BindOnce(
+          [](GetSnapshotCallback cb, base::DictValue response) {
+            // SidecarClient drops pending callbacks with an empty dict on
+            // disconnect — treat that as a disconnected snapshot rather
+            // than blocking forever.
+            const bool connected = !response.empty();
+            std::move(cb).Run(FromDict(response, connected));
+          },
+          std::move(callback)));
+}
+
+}  // namespace slayzone
