+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_SLAYZONE_SLAYZONE_STATUSBAR_HOST_H_
+#define CHROME_BROWSER_SLAYZONE_SLAYZONE_STATUSBAR_HOST_H_
+
+#include "chrome/browser/slayzone/mojom/statusbar.mojom.h"
+#include "mojo/public/cpp/bindings/pending_receiver.h"
+#include "mojo/public/cpp/bindings/receiver_set.h"
+
+namespace slayzone {
+
+// Phase 7.1 — browser-side implementation of
+// `slayzone::statusbar::mojom::StatusbarHost`. One instance per
+// `SlayzoneBrowserView`. `GetSnapshot` forwards to the process-wide
+// `SidecarClient` (Phase 2.3) via JSON-RPC method `statusbar:get-snapshot`;
+// the sidecar keeps the authoritative state in-process (see
+// `packages/sidecar/src/handlers/statusbar.ts`).
+class SlayzoneStatusbarHost
+    : public slayzone::statusbar::mojom::StatusbarHost {
+ public:
+  SlayzoneStatusbarHost();
+  SlayzoneStatusbarHost(const SlayzoneStatusbarHost&) = delete;
+  SlayzoneStatusbarHost& operator=(const SlayzoneStatusbarHost&) = delete;
+  ~SlayzoneStatusbarHost() override;
+
+  void Bind(
+      mojo::PendingReceiver<slayzone::statusbar::mojom::StatusbarHost>
+          receiver);
+
+  // slayzone::statusbar::mojom::StatusbarHost:
+  void GetSnapshot(GetSnapshotCallback callback) override;
+
+ private:
+  mojo::ReceiverSet<slayzone::statusbar::mojom::StatusbarHost> receivers_;
+};
+
+}  // namespace slayzone
+
+#endif  // CHROME_BROWSER_SLAYZONE_SLAYZONE_STATUSBAR_HOST_H_
