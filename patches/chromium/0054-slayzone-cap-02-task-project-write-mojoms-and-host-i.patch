 module slayzone.projects.mojom;
 
@@ -37,9 +41,28 @@ struct ProjectsSnapshot {
   string active_project_id;
 };
 
+// Result envelope for every write method. `ok`=false with non-empty `error`
+// when the sidecar refuses. On ok, `project` is the freshly-written row; on
+// delete, `project.id` echoes the deleted id, other fields empty.
+struct ProjectWriteResult {
+  bool ok;
+  string error;
+  ProjectEntry project;
+};
+
 // Browser-side projects data provider. One remote per region WebUI that
-// mounts. The browser forwards snapshot queries to the sidecar over the
-// existing Unix-socket JSON-RPC channel (projects:get-snapshot method).
+// mounts. The browser forwards snapshot queries + writes to the sidecar over
+// the existing Unix-socket JSON-RPC channel.
 interface ProjectsHost {
   GetSnapshot() => (ProjectsSnapshot snapshot);
+
+  // Create a new project. `color` is a hex string; empty = unset.
+  CreateProject(string name, string color) => (ProjectWriteResult result);
+
+  // Rename / recolor an existing project.
+  UpdateProject(string project_id, string name, string color)
+      => (ProjectWriteResult result);
+
+  // Remove a project. Orphaned tasks cascade-delete (matches Electron shape).
+  DeleteProject(string project_id) => (ProjectWriteResult result);
 };
