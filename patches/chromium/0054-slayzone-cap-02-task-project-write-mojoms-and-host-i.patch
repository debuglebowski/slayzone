+  bool ok;
+  string error;
+  TaskEntry task;
+};
+
 // Browser-side tasklist data provider. One remote per region WebUI mount.
-// Forwards snapshot queries to the sidecar (tasklist:get-snapshot).
+// Forwards snapshot queries + writes to the sidecar JSON-RPC channel.
 interface TasklistHost {
   GetSnapshot() => (TasklistSnapshot snapshot);
+
+  // Create a new task in `project_id` under column `column_id` with `title`.
+  // Description is created empty; sidebar edit wires up the description set.
