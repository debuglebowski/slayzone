+                                          UpdateProjectCallback callback) {
+  base::DictValue params;
+  params.Set("projectId", project_id);
+  params.Set("name", name);
+  params.Set("color", color);
+  CallWrite("projects:update", std::move(params), std::move(callback));
+}
+
+void SlayzoneProjectsHost::DeleteProject(const std::string& project_id,
+                                          DeleteProjectCallback callback) {
+  base::DictValue params;
+  params.Set("projectId", project_id);
+  CallWrite("projects:delete", std::move(params), std::move(callback));
+}
+
 }  // namespace slayzone
