--- a/chrome/browser/slayzone/slayzone_projects_host.cc
+++ b/chrome/browser/slayzone/slayzone_projects_host.cc
@@ -55,6 +55,63 @@ projects::mojom::ProjectsSnapshotPtr FromDict(const base::DictValue& response) {
   return snapshot;
 }
 
+// Translate `{ ok, error, project: { id, name, color } }` into a
+// ProjectWriteResult. On JSON-RPC error envelope, surface the RPC error.
+projects::mojom::ProjectWriteResultPtr WriteResultFromDict(
+    const base::DictValue& response) {
+  auto out = projects::mojom::ProjectWriteResult::New();
+  out->project = projects::mojom::ProjectEntry::New();
+
+  const base::Value* result = response.Find("result");
+  const base::DictValue* dict =
+      (result && result->is_dict()) ? &result->GetDict() : nullptr;
+  if (!dict) {
+    if (const base::Value* err = response.Find("error");
+        err && err->is_dict()) {
+      if (const std::string* msg = err->GetDict().FindString("message")) {
+        out->error = *msg;
+      } else {
+        out->error = "sidecar error";
+      }
+    } else {
+      out->error = "no response";
+    }
+    return out;
+  }
+
+  out->ok = dict->FindBool("ok").value_or(false);
+  if (const std::string* err = dict->FindString("error")) {
+    out->error = *err;
+  }
+  if (const base::Value* project = dict->Find("project");
+      project && project->is_dict()) {
+    const base::DictValue& p = project->GetDict();
+    if (const std::string* id = p.FindString("id")) {
+      out->project->id = *id;
+    }
+    if (const std::string* name = p.FindString("name")) {
+      out->project->name = *name;
+    }
+    if (const std::string* color = p.FindString("color")) {
+      out->project->color = *color;
+    }
+  }
+  return out;
+}
+
+template <typename Callback>
+void CallWrite(std::string_view method,
+               base::DictValue params,
+               Callback callback) {
+  SidecarClient::GetInstance()->Call(
+      method, std::move(params),
+      base::BindOnce(
+          [](Callback cb, base::DictValue response) {
+            std::move(cb).Run(WriteResultFromDict(response));
+          },
+          std::move(callback)));
+}
+
 }  // namespace
 
 SlayzoneProjectsHost::SlayzoneProjectsHost() = default;
