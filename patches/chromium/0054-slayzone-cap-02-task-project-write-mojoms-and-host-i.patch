+// Translate a `{ ok, error, task: { id, title, status } }` sidecar reply into
+// a `TaskWriteResult`. Missing fields fall back to neutral defaults so the
+// renderer gets a well-formed struct even when the sidecar response is
+// truncated; `ok=false` is the fail path.
+tasklist::mojom::TaskWriteResultPtr WriteResultFromDict(
+    const base::DictValue& response) {
+  auto out = tasklist::mojom::TaskWriteResult::New();
+  out->task = tasklist::mojom::TaskEntry::New();
+
+  const base::Value* result = response.Find("result");
+  const base::DictValue* dict =
+      (result && result->is_dict()) ? &result->GetDict() : nullptr;
+  if (!dict) {
+    // JSON-RPC error envelope — surface the RPC error if present.
+    if (const base::Value* err = response.Find("error");
+        err && err->is_dict()) {
+      if (const std::string* msg = err->GetDict().FindString("message")) {
+        out->error = *msg;
+      } else {
+        out->error = "sidecar error";
+      }
+    } else {
+      out->error = "no response";
+    }
+    return out;
+  }
+
+  out->ok = dict->FindBool("ok").value_or(false);
+  if (const std::string* err = dict->FindString("error")) {
+    out->error = *err;
+  }
+  if (const base::Value* task = dict->Find("task"); task && task->is_dict()) {
+    const base::DictValue& t = task->GetDict();
+    if (const std::string* id = t.FindString("id")) {
+      out->task->id = *id;
+    }
+    if (const std::string* title = t.FindString("title")) {
+      out->task->title = *title;
+    }
+    if (const std::string* status = t.FindString("status")) {
+      out->task->status = *status;
+    }
+  }
+  return out;
+}
+
+// Helper to bind a write callback against the common sidecar reply shape.
+template <typename Callback>
+void CallWrite(std::string_view method,
+               base::DictValue params,
+               Callback callback) {
+  SidecarClient::GetInstance()->Call(
+      method, std::move(params),
+      base::BindOnce(
+          [](Callback cb, base::DictValue response) {
+            std::move(cb).Run(WriteResultFromDict(response));
+          },
+          std::move(callback)));
+}
+
 }  // namespace
 
