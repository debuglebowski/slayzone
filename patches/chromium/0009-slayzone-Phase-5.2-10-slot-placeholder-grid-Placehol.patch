@@ -0,0 +1,109 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/ui/views/frame/slayzone_region_container.h"
+
+#include <memory>
+#include <string>
+#include <string_view>
+#include <utility>
+
+#include "base/strings/strcat.h"
+#include "chrome/common/webui_url_constants.h"
+#include "content/public/browser/browser_context.h"
+#include "ui/base/metadata/metadata_impl_macros.h"
+#include "ui/gfx/geometry/size.h"
+#include "ui/views/controls/webview/webview.h"
+#include "ui/views/layout/box_layout.h"
+#include "ui/views/layout/box_layout_view.h"
+#include "ui/views/view.h"
+#include "url/gurl.h"
+
+namespace {
+
+GURL PlaceholderUrl(std::string_view region_id) {
+  return GURL(
+      base::StrCat({chrome::kChromeUISlayzonePlaceholderURL, region_id}));
+}
+
+}  // namespace
+
+SlayzoneRegionContainer::SlayzoneRegionContainer(
+    content::BrowserContext* browser_context) {
+  // Tracks every WebView we create so the parent BoxLayoutView can flag
+  // individual children as flex.
+  auto add_region =
+      [this, browser_context](views::BoxLayoutView* parent,
+                              std::string_view id, int fixed_axis_px,
+                              int flex_weight) -> views::WebView* {
+    auto webview = std::make_unique<views::WebView>(browser_context);
+    webview->LoadInitialURL(PlaceholderUrl(id));
+    if (fixed_axis_px > 0) {
+      webview->SetPreferredSize(gfx::Size(fixed_axis_px, fixed_axis_px));
+    }
+    views::WebView* raw = webview.get();
+    parent->AddChildView(std::move(webview));
+    if (flex_weight > 0) {
+      parent->SetFlexForView(raw, flex_weight);
+    }
+    regions_.emplace(std::string(id), raw);
+    return raw;
+  };
+
+  // Outer: vertical — shell | tabbar | body | statusbar.
+  SetOrientation(views::BoxLayout::Orientation::kVertical);
+  SetCrossAxisAlignment(views::BoxLayout::CrossAxisAlignment::kStretch);
+
+  add_region(this, "shell", /*fixed_axis_px=*/20, /*flex_weight=*/0);
+  add_region(this, "tabbar", /*fixed_axis_px=*/36, /*flex_weight=*/0);
+
+  // body: horizontal — projects | center | sidebar | tools.
+  auto body_owned = std::make_unique<views::BoxLayoutView>();
+  body_owned->SetOrientation(views::BoxLayout::Orientation::kHorizontal);
+  body_owned->SetCrossAxisAlignment(
+      views::BoxLayout::CrossAxisAlignment::kStretch);
+  views::BoxLayoutView* body = AddChildView(std::move(body_owned));
+  SetFlexForView(body, 1);
+
+  add_region(body, "projects", /*fixed_axis_px=*/56, /*flex_weight=*/0);
+
+  // center: vertical — taskheader | mid | terminal.
+  auto center_owned = std::make_unique<views::BoxLayoutView>();
+  center_owned->SetOrientation(views::BoxLayout::Orientation::kVertical);
+  center_owned->SetCrossAxisAlignment(
+      views::BoxLayout::CrossAxisAlignment::kStretch);
+  views::BoxLayoutView* center = body->AddChildView(std::move(center_owned));
+  body->SetFlexForView(center, 1);
+
+  add_region(center, "taskheader", /*fixed_axis_px=*/40, /*flex_weight=*/0);
+
+  // mid: horizontal — tasklist | browserchrome (each ~50%).
+  auto mid_owned = std::make_unique<views::BoxLayoutView>();
+  mid_owned->SetOrientation(views::BoxLayout::Orientation::kHorizontal);
+  mid_owned->SetCrossAxisAlignment(
+      views::BoxLayout::CrossAxisAlignment::kStretch);
+  views::BoxLayoutView* mid = center->AddChildView(std::move(mid_owned));
+  center->SetFlexForView(mid, 2);
+
+  add_region(mid, "tasklist", /*fixed_axis_px=*/0, /*flex_weight=*/1);
+  add_region(mid, "browserchrome", /*fixed_axis_px=*/0, /*flex_weight=*/1);
+
+  // terminal takes the bottom third of center.
+  add_region(center, "terminal", /*fixed_axis_px=*/0, /*flex_weight=*/1);
+
+  add_region(body, "sidebar", /*fixed_axis_px=*/280, /*flex_weight=*/0);
+  add_region(body, "tools", /*fixed_axis_px=*/48, /*flex_weight=*/0);
+
+  add_region(this, "statusbar", /*fixed_axis_px=*/24, /*flex_weight=*/0);
+}
+
+SlayzoneRegionContainer::~SlayzoneRegionContainer() = default;
+
+views::WebView* SlayzoneRegionContainer::GetRegion(std::string_view region_id) {
+  auto it = regions_.find(std::string(region_id));
+  return it == regions_.end() ? nullptr : it->second.get();
+}
+
+BEGIN_METADATA(SlayzoneRegionContainer)
+END_METADATA
