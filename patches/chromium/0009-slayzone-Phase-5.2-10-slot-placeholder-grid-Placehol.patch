+#ifndef CHROME_BROWSER_UI_VIEWS_FRAME_SLAYZONE_REGION_CONTAINER_H_
+#define CHROME_BROWSER_UI_VIEWS_FRAME_SLAYZONE_REGION_CONTAINER_H_
+
+#include <array>
