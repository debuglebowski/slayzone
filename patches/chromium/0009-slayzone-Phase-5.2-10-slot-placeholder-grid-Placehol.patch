 #include "ui/base/metadata/metadata_impl_macros.h"
 
 SlayzoneBrowserView::SlayzoneBrowserView(Browser* browser)
@@ -11,5 +16,26 @@ SlayzoneBrowserView::SlayzoneBrowserView(Browser* browser)
 
 SlayzoneBrowserView::~SlayzoneBrowserView() = default;
 
+void SlayzoneBrowserView::AddedToWidget() {
+  BrowserView::AddedToWidget();
+
+  // Upstream chrome stays parented + visible — `BrowserViewTabbedLayoutImpl`
+  // CHECKs that `contents_container_` is visible + parented, and similar
+  // invariants apply to the toolbar tree. Our region grid is added as a later
+  // sibling and overlays the whole BrowserView, so the upstream views remain
+  // but are never seen. Phase 5.6 takes them out of the flow properly once
+  // the layout intent API + Mojo channel land.
+  region_container_ = AddChildView(std::make_unique<SlayzoneRegionContainer>(
+      browser()->profile()));
+  region_container_->SetBoundsRect(GetLocalBounds());
+}
+
+void SlayzoneBrowserView::OnBoundsChanged(const gfx::Rect& previous_bounds) {
+  BrowserView::OnBoundsChanged(previous_bounds);
+  if (region_container_) {
+    region_container_->SetBoundsRect(GetLocalBounds());
+  }
+}
+
 BEGIN_METADATA(SlayzoneBrowserView)
 END_METADATA
