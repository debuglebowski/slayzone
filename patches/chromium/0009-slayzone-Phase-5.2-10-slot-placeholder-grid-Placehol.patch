+namespace views {
+class WebView;
+}
+
+// Phase 5.2 — native layout grid hosting one `views::WebView` per SlayZone
+// region. Every slot loads `chrome://slayzone-placeholder/?region=<id>` until
+// Phase 7 swaps individual slots for their real WebUIs.
+class SlayzoneRegionContainer : public views::BoxLayoutView {
+  METADATA_HEADER(SlayzoneRegionContainer, views::BoxLayoutView)
+
+ public:
+  // Region IDs shared with Phase 7 surfaces. Order is layout-agnostic;
+  // the visible grid is wired in the ctor.
+  static constexpr std::array<std::string_view, 10> kRegionIds = {
+      "shell",      "tabbar",        "projects", "tasklist", "sidebar",
+      "taskheader", "browserchrome", "terminal", "tools",    "statusbar",
+  };
+
+  explicit SlayzoneRegionContainer(content::BrowserContext* browser_context);
+  SlayzoneRegionContainer(const SlayzoneRegionContainer&) = delete;
+  SlayzoneRegionContainer& operator=(const SlayzoneRegionContainer&) = delete;
+  ~SlayzoneRegionContainer() override;
+
+  // Returns the WebView for `region_id`, or nullptr if unknown. Phase 5.3+
+  // uses this to inject real WebContents into the feasibility slot.
+  views::WebView* GetRegion(std::string_view region_id);
+
+ private:
+  base::flat_map<std::string, raw_ptr<views::WebView>> regions_;
+};
+
+#endif  // CHROME_BROWSER_UI_VIEWS_FRAME_SLAYZONE_REGION_CONTAINER_H_
