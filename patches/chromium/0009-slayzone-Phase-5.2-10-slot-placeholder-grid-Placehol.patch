-bool ShouldHandleShellRequest(const std::string& path) {
+// Phase 5.2 placeholder — renders the region id baked into the URL path:
+// `chrome://slayzone-placeholder/<id>`. Query strings are rejected by the
+// chrome:// scheme router on some builds, and inline script is blocked by
+// default WebUIDataSource CSP; embedding the region server-side sidesteps
+// both. Phase 7 replaces individual slots with their real WebUIs.
+constexpr std::string_view kPlaceholderHtmlPrefix = R"HTML(<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <title>SlayZone · )HTML";
+
+constexpr std::string_view kPlaceholderHtmlMid = R"HTML(</title>
+  <style>
+    :root { color-scheme: light dark; }
+    html, body { margin: 0; height: 100%; font: 13px/1.3 system-ui, sans-serif; }
+    body {
+      display: flex; flex-direction: column; align-items: center;
+      justify-content: center; gap: 4px;
+      background: color-mix(in oklab, Canvas, CanvasText 6%);
+      color: CanvasText;
+      outline: 1px solid color-mix(in oklab, Canvas, CanvasText 14%);
+      outline-offset: -1px;
+    }
+    .region { font-weight: 600; letter-spacing: 0.04em; }
+    .tag { opacity: 0.55; font-size: 11px; }
+  </style>
+</head>
+<body>
+  <div class="region">)HTML";
+
+constexpr std::string_view kPlaceholderHtmlSuffix = R"HTML(</div>
+  <div class="tag">placeholder</div>
+</body>
+</html>)HTML";
+
+bool ShouldHandleEmptyPath(const std::string& path) {
   return path.empty();
 }
 
+bool ShouldHandleAnyPath(const std::string& path) {
+  return true;
+}
+
 void HandleShellRequest(const std::string& path,
                         content::WebUIDataSource::GotDataCallback callback) {
   std::move(callback).Run(base::MakeRefCounted<base::RefCountedString>(
       std::string(kShellHtml)));
 }
 
+void HandlePlaceholderRequest(
+    const std::string& path,
+    content::WebUIDataSource::GotDataCallback callback) {
+  std::string region = path;
+  if (!region.empty() && region.front() == '/') {
+    region.erase(0, 1);
+  }
+  if (region.empty()) {
+    region = "placeholder";
+  }
+  std::string html =
+      base::StrCat({kPlaceholderHtmlPrefix, region, kPlaceholderHtmlMid,
+                    region, kPlaceholderHtmlSuffix});
+  std::move(callback).Run(
+      base::MakeRefCounted<base::RefCountedString>(std::move(html)));
+}
+
 class ShellUI : public content::WebUIController {
  public:
   explicit ShellUI(content::WebUI* web_ui) : content::WebUIController(web_ui) {
     auto* source = content::WebUIDataSource::CreateAndAdd(
         Profile::FromWebUI(web_ui), chrome::kChromeUISlayzoneShellHost);
-    source->SetRequestFilter(base::BindRepeating(&ShouldHandleShellRequest),
+    source->SetRequestFilter(base::BindRepeating(&ShouldHandleEmptyPath),
                              base::BindRepeating(&HandleShellRequest));
   }
 
@@ -67,10 +124,33 @@ class ShellUIConfig : public content::DefaultWebUIConfig<ShellUI> {
                            chrome::kChromeUISlayzoneShellHost) {}
 };
 
+class PlaceholderUI : public content::WebUIController {
+ public:
+  explicit PlaceholderUI(content::WebUI* web_ui)
+      : content::WebUIController(web_ui) {
+    auto* source = content::WebUIDataSource::CreateAndAdd(
+        Profile::FromWebUI(web_ui), chrome::kChromeUISlayzonePlaceholderHost);
+    source->SetRequestFilter(base::BindRepeating(&ShouldHandleAnyPath),
+                             base::BindRepeating(&HandlePlaceholderRequest));
+  }
+
+  PlaceholderUI(const PlaceholderUI&) = delete;
+  PlaceholderUI& operator=(const PlaceholderUI&) = delete;
+  ~PlaceholderUI() override = default;
+};
+
+class PlaceholderUIConfig : public content::DefaultWebUIConfig<PlaceholderUI> {
+ public:
+  PlaceholderUIConfig()
+      : DefaultWebUIConfig(content::kChromeUIScheme,
+                           chrome::kChromeUISlayzonePlaceholderHost) {}
+};
+
 }  // namespace
 
 void RegisterSlayzoneWebUIConfigs(content::WebUIConfigMap& map) {
   map.AddWebUIConfig(std::make_unique<ShellUIConfig>());
+  map.AddWebUIConfig(std::make_unique<PlaceholderUIConfig>());
 }
 
 }  // namespace slayzone
