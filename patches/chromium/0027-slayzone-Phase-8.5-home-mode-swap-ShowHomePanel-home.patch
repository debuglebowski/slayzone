+void SlayzoneLayoutHost::ShowHomePanel(const std::string& panel_id,
+                                       ShowHomePanelCallback callback) {
+  // Empty panel_id = back to task-detail mode; allowed ids live on
+  // SlayzoneBrowserView::kHomePanelIds. Returning false here leaves the UI
+  // in its current mode so the caller can render an inline error.
+  if (!view_) {
+    std::move(callback).Run(false);
+    return;
+  }
+  std::move(callback).Run(view_->SetHomePanel(panel_id));
+}
