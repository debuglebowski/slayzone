     return git_host_.get();
   }
 
+  // Phase 8.5 — home-tab mode. `kTaskDetail` (default) shows the
+  // 10-region grid. `kHome` hides the grid and renders a single home
+  // panel (one of `kHomePanelIds`) full-bleed.
+  enum class Mode {
+    kTaskDetail,
+    kHome,
+  };
+
+  // The panel IDs accepted by `SetHomePanel`. Order is fixed so downstream
+  // UI (e.g. Phase 17 panel rail) can present a stable cycle.
+  static constexpr std::array<std::string_view, 4> kHomePanelIds = {
+      "automations", "processes", "test", "git",
+  };
+
+  Mode mode() const { return mode_; }
+
+  // Phase 8.5 — swap into home mode with the given `panel_id` loaded in the
+  // home WebView. `panel_id` must be in `kHomePanelIds`; empty string
+  // returns to task-detail mode. Returns `true` on successful mode change,
+  // `false` when `panel_id` is unknown (mode unchanged).
+  bool SetHomePanel(std::string_view panel_id);
+
   // Phase 6.3 — returns the SlayzoneBrowserView that owns `wc` as a region
   // WebView's WebContents (e.g. chrome://slayzone-tabbar/ or
   // chrome://slayzone-browserchrome/), or nullptr if `wc` is not a region
@@ -133,6 +162,16 @@ class SlayzoneBrowserView : public BrowserView {
   std::unique_ptr<slayzone::SlayzoneProcessesHost> processes_host_;
   std::unique_ptr<slayzone::SlayzoneTestHost> test_host_;
   std::unique_ptr<slayzone::SlayzoneGitHost> git_host_;
+
+  // Phase 8.5 — home-tab mode state. `home_panel_webview_` is lazily
+  // created the first time `SetHomePanel()` is called with a known id,
+  // parented as a BrowserView child overlaying the region grid, and
+  // retained for subsequent swaps. When `mode_ == kTaskDetail` the WebView
+  // is hidden (if present) and the region grid is visible; in `kHome` the
+  // inverse.
+  Mode mode_ = Mode::kTaskDetail;
+  raw_ptr<views::WebView> home_panel_webview_ = nullptr;
+  std::string active_home_panel_;
 };
 
