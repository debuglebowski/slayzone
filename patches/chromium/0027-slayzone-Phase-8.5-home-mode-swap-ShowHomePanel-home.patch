 namespace {
 
+// Phase 8.5 — command-line switch for dev smoke. When present,
+// AddedToWidget calls SetHomePanel(value) once the region grid is up.
+constexpr char kSlayzoneHomePanelSwitch[] = "slayzone-home-panel";
+
 // Back-pointer attached to every region WebView's WebContents so Phase 6.3's
 // Mojo binders can route TabsHost receivers to the owning SlayzoneBrowserView
 // from just the WebContents.
@@ -115,6 +124,69 @@ void SlayzoneBrowserView::AddedToWidget() {
   // paint since the first tab typically exists by AddedToWidget; subsequent
   // activations (and any late initial tab) flow through the override.
   SyncInlineTabWebView();
+
+  // Phase 8.5 — honor `--slayzone-home-panel=<id>` for dev smoke. Invalid
+  // ids are silently ignored; the grid stays up. Used by the verify
+  // harness + docs/chromium/phase-8-smoke.md.
+  const base::CommandLine* cli = base::CommandLine::ForCurrentProcess();
+  if (cli->HasSwitch(kSlayzoneHomePanelSwitch)) {
+    SetHomePanel(cli->GetSwitchValueASCII(kSlayzoneHomePanelSwitch));
+  }
+}
+
+bool SlayzoneBrowserView::SetHomePanel(std::string_view panel_id) {
+  // Empty id = back to task-detail mode.
+  if (panel_id.empty()) {
+    if (home_panel_webview_) {
+      home_panel_webview_->SetVisible(false);
+    }
+    if (region_container_) {
+      region_container_->SetVisible(true);
+    }
+    mode_ = Mode::kTaskDetail;
+    active_home_panel_.clear();
+    return true;
+  }
+
+  // Allowlist — reject unknown ids without changing mode. Explicit list
+  // rather than a "anything goes" policy so a typo doesn't silently yield
+  // a blank region pointing at a bogus chrome:// host.
+  const bool known = std::any_of(
+      kHomePanelIds.begin(), kHomePanelIds.end(),
+      [panel_id](std::string_view known_id) { return known_id == panel_id; });
+  if (!known) {
+    return false;
+  }
+
+  // Lazily create the home WebView. Sized to match the region grid; when
+  // active it covers the grid completely. Owned by the BrowserView view
+  // tree — no separate lifetime management.
+  if (!home_panel_webview_) {
+    auto webview_owned = std::make_unique<views::WebView>(browser()->profile());
+    home_panel_webview_ = AddChildView(std::move(webview_owned));
+    home_panel_webview_->SetBoundsRect(GetLocalBounds());
+    // Phase 8.5 — give the home WebContents a RegionData back-pointer so
+    // the per-BrowserView Mojo binders (SlayzoneAutomationsUI etc.) can
+    // resolve via `FromRegionWebContents` exactly as region WebContents do.
+    // Installed before the first navigation so the BindInterface path
+    // triggered by the initial page load finds the host. Re-installed on
+    // every panel swap below since SetWebContents may cycle contents.
+  }
+
+  const std::string url =
+      base::StrCat({"chrome://slayzone-", panel_id, "/"});
+  home_panel_webview_->LoadInitialURL(GURL(url));
+  if (content::WebContents* contents = home_panel_webview_->GetWebContents()) {
+    RegionData::CreateForWebContents(contents, this);
+  }
+  home_panel_webview_->SetBoundsRect(GetLocalBounds());
+  home_panel_webview_->SetVisible(true);
+  if (region_container_) {
+    region_container_->SetVisible(false);
+  }
+  mode_ = Mode::kHome;
+  active_home_panel_ = std::string(panel_id);
+  return true;
 }
 
 // static
@@ -157,6 +229,9 @@ void SlayzoneBrowserView::OnBoundsChanged(const gfx::Rect& previous_bounds) {
   if (region_container_) {
     region_container_->SetBoundsRect(GetLocalBounds());
   }
+  if (home_panel_webview_) {
+    home_panel_webview_->SetBoundsRect(GetLocalBounds());
+  }
 }
 
