+// Phase 8.3 test region data contract (in-tree mirror).
+// Source of truth: packages/shared/mojo-bindings/mojom/test.mojom.
+// Keep diff-identical below the module line.
+
+module slayzone.test.mojom;
+
+struct TestFile {
+  string path;
+  string category;
+  string status;
+  int32 duration_ms;
+};
+
+struct TestCategory {
+  string id;
+  string label;
+  int32 file_count;
+};
+
+struct TestSnapshot {
+  string active_project_id;
+  string last_scan_at;
+  array<TestCategory> categories;
+  array<TestFile> files;
+};
+
+interface TestHost {
+  GetSnapshot() => (TestSnapshot snapshot);
+};
