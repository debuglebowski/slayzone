+
+namespace {
+
+constexpr std::string_view kTestMissingBundleHtml =
+    R"HTML(<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <title>SlayZone · test</title>
+  <style>
+    :root { color-scheme: light dark; }
+    html, body { margin: 0; height: 100%; font: 11px/1.3 system-ui, sans-serif; }
+    body {
+      display: flex; align-items: center; padding: 0 10px;
+      background: #3a1a1a; color: #fca5a5;
+      border-left: 1px solid #6b2020;
+    }
+  </style>
+</head>
+<body>
+  <span>test: bundle missing — pass --slayzone-webui-bundle-dir=&lt;repo&gt;/packages/webui</span>
+</body>
+</html>)HTML";
+
+}  // namespace
+
+SlayzoneTestUI::SlayzoneTestUI(content::WebUI* web_ui)
+    : content::WebUIController(web_ui) {
+  auto* source = content::WebUIDataSource::CreateAndAdd(
+      Profile::FromWebUI(web_ui), chrome::kChromeUISlayzoneTestHost);
+  slayzone::ConfigureBundleSource(source, "test", kTestMissingBundleHtml);
+}
+
+SlayzoneTestUI::~SlayzoneTestUI() = default;
+
+WEB_UI_CONTROLLER_TYPE_IMPL(SlayzoneTestUI)
+
+void SlayzoneTestUI::BindInterface(
+    mojo::PendingReceiver<slayzone::test::mojom::TestHost> receiver) {
+  SlayzoneBrowserView* view =
+      SlayzoneBrowserView::FromRegionWebContents(web_ui()->GetWebContents());
+  if (!view || !view->test_host()) {
+    return;
+  }
+  view->test_host()->Bind(std::move(receiver));
+}
