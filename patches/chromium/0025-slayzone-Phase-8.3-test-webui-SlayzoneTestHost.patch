@@ -0,0 +1,98 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/slayzone/slayzone_test_host.h"
+
+#include <string>
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "base/values.h"
+#include "chrome/browser/slayzone/sidecar_client.h"
+
+namespace slayzone {
+
+namespace {
+
+test::mojom::TestSnapshotPtr FromDict(const base::DictValue& response) {
+  auto snapshot = test::mojom::TestSnapshot::New();
+  const base::Value* result = response.Find("result");
+  const base::DictValue* dict =
+      (result && result->is_dict()) ? &result->GetDict() : nullptr;
+  if (!dict) {
+    return snapshot;
+  }
+
+  if (const std::string* active = dict->FindString("activeProjectId")) {
+    snapshot->active_project_id = *active;
+  }
+  if (const std::string* scan = dict->FindString("lastScanAt")) {
+    snapshot->last_scan_at = *scan;
+  }
+
+  const base::ListValue* cats = dict->FindList("categories");
+  if (cats) {
+    for (const base::Value& cat_entry : *cats) {
+      if (!cat_entry.is_dict()) {
+        continue;
+      }
+      const base::DictValue& c = cat_entry.GetDict();
+      auto cat = test::mojom::TestCategory::New();
+      if (const std::string* id = c.FindString("id")) {
+        cat->id = *id;
+      }
+      if (const std::string* label = c.FindString("label")) {
+        cat->label = *label;
+      }
+      cat->file_count = c.FindInt("fileCount").value_or(0);
+      snapshot->categories.push_back(std::move(cat));
+    }
+  }
+
+  const base::ListValue* files = dict->FindList("files");
+  if (files) {
+    for (const base::Value& file_entry : *files) {
+      if (!file_entry.is_dict()) {
+        continue;
+      }
+      const base::DictValue& f = file_entry.GetDict();
+      auto file = test::mojom::TestFile::New();
+      if (const std::string* path = f.FindString("path")) {
+        file->path = *path;
+      }
+      if (const std::string* cat = f.FindString("category")) {
+        file->category = *cat;
+      }
+      if (const std::string* st = f.FindString("status")) {
+        file->status = *st;
+      }
+      file->duration_ms = f.FindInt("durationMs").value_or(-1);
+      snapshot->files.push_back(std::move(file));
+    }
+  }
+
+  return snapshot;
+}
+
+}  // namespace
+
+SlayzoneTestHost::SlayzoneTestHost() = default;
+SlayzoneTestHost::~SlayzoneTestHost() = default;
+
+void SlayzoneTestHost::Bind(
+    mojo::PendingReceiver<test::mojom::TestHost> receiver) {
+  receivers_.Add(this, std::move(receiver));
+}
+
+void SlayzoneTestHost::GetSnapshot(GetSnapshotCallback callback) {
+  SidecarClient::GetInstance()->Call(
+      "test:get-snapshot", base::DictValue(),
+      base::BindOnce(
+          [](GetSnapshotCallback cb, base::DictValue response) {
+            std::move(cb).Run(FromDict(response));
+          },
+          std::move(callback)));
+}
+
+}  // namespace slayzone
