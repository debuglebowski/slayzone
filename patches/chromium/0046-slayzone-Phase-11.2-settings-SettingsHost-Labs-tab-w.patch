+namespace slayzone {
+
+// Phase 11.2 — browser-side SettingsHost. Owned by SlayzoneSettingsUI
+// (one per WebContents). Settings is a modal overlay surface with no
+// BrowserView identity requirement; singleton sidecar calls suffice.
+class SlayzoneSettingsHost : public slayzone::settings::mojom::SettingsHost {
+ public:
+  SlayzoneSettingsHost();
+  SlayzoneSettingsHost(const SlayzoneSettingsHost&) = delete;
+  SlayzoneSettingsHost& operator=(const SlayzoneSettingsHost&) = delete;
+  ~SlayzoneSettingsHost() override;
+
+  void Bind(
+      mojo::PendingReceiver<slayzone::settings::mojom::SettingsHost> receiver);
+
+  // slayzone::settings::mojom::SettingsHost:
+  void GetString(const std::string& key, GetStringCallback callback) override;
+  void SetString(const std::string& key,
+                 const std::string& value,
+                 SetStringCallback callback) override;
+
+ private:
+  mojo::ReceiverSet<slayzone::settings::mojom::SettingsHost> receivers_;
+};
+
+}  // namespace slayzone
+
+#endif  // CHROME_BROWSER_SLAYZONE_SLAYZONE_SETTINGS_HOST_H_
