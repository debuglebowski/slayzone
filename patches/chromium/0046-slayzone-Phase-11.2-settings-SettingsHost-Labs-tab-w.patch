+// Phase 11.2 settings region data contract (in-tree mirror).
+// Source of truth: packages/shared/mojo-bindings/mojom/settings.mojom.
+// Keep diff-identical below the module line.
+
+module slayzone.settings.mojom;
+
+interface SettingsHost {
+  GetString(string key) => (string value);
+  SetString(string key, string value) => (bool ok);
+};
diff --git a/chrome/browser/slayzone/slayzone_settings_host.cc b/chrome/browser/slayzone/slayzone_settings_host.cc
new file mode 100644
index 0000000000000..8220e7bd1b832
--- /dev/null
+++ b/chrome/browser/slayzone/slayzone_settings_host.cc
@@ -0,0 +1,85 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/slayzone/slayzone_settings_host.h"
+
+#include <string>
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "base/values.h"
+#include "chrome/browser/slayzone/sidecar_client.h"
+
+namespace slayzone {
+
+namespace {
+
+// settings:get returns a bare string under "result" — no wrapping struct.
+// Missing / wrong-type responses collapse to empty string so the JS side
+// renders its "no value" path uniformly.
+std::string StringFromResponse(const base::DictValue& response) {
+  const base::Value* result = response.Find("result");
+  if (!result) {
+    return std::string();
+  }
+  if (const std::string* s = result->GetIfString()) {
+    return *s;
+  }
+  return std::string();
+}
+
+// settings:set returns `{ ok: bool }` under "result".
+bool OkFromResponse(const base::DictValue& response) {
+  const base::Value* result = response.Find("result");
+  const base::DictValue* dict =
+      (result && result->is_dict()) ? &result->GetDict() : nullptr;
+  if (!dict) {
+    return false;
+  }
+  return dict->FindBool("ok").value_or(false);
+}
+
+}  // namespace
+
+SlayzoneSettingsHost::SlayzoneSettingsHost() = default;
+SlayzoneSettingsHost::~SlayzoneSettingsHost() = default;
+
+void SlayzoneSettingsHost::Bind(
+    mojo::PendingReceiver<settings::mojom::SettingsHost> receiver) {
+  receivers_.Add(this, std::move(receiver));
+}
+
+void SlayzoneSettingsHost::GetString(const std::string& key,
+                                     GetStringCallback callback) {
+  base::ListValue params;
+  params.Append(key);
+  base::DictValue request;
+  request.Set("params", std::move(params));
+  SidecarClient::GetInstance()->Call(
+      "settings:get", std::move(request),
+      base::BindOnce(
+          [](GetStringCallback cb, base::DictValue response) {
+            std::move(cb).Run(StringFromResponse(response));
+          },
+          std::move(callback)));
+}
+
+void SlayzoneSettingsHost::SetString(const std::string& key,
+                                     const std::string& value,
+                                     SetStringCallback callback) {
+  base::ListValue params;
+  params.Append(key);
+  params.Append(value);
+  base::DictValue request;
+  request.Set("params", std::move(params));
+  SidecarClient::GetInstance()->Call(
+      "settings:set", std::move(request),
+      base::BindOnce(
+          [](SetStringCallback cb, base::DictValue response) {
+            std::move(cb).Run(OkFromResponse(response));
+          },
+          std::move(callback)));
+}
+
+}  // namespace slayzone
