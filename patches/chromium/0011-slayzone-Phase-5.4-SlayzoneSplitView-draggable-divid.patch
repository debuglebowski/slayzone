+
+#ifndef CHROME_BROWSER_UI_VIEWS_FRAME_SLAYZONE_SPLIT_VIEW_H_
+#define CHROME_BROWSER_UI_VIEWS_FRAME_SLAYZONE_SPLIT_VIEW_H_
+
+#include <memory>
+
+#include "base/memory/raw_ptr.h"
+#include "ui/base/metadata/metadata_header_macros.h"
+#include "ui/views/controls/resize_area.h"
+#include "ui/views/controls/resize_area_delegate.h"
+#include "ui/views/view.h"
+
+// Phase 5.4 — two-pane split container with a draggable `views::ResizeArea`
+// divider, snap points at 0 / 50 / 100 %, and Alt+Arrow keyboard resize.
+// Hosted inside `SlayzoneRegionContainer` where two region WebViews meet.
+class SlayzoneSplitView : public views::View,
+                          public views::ResizeAreaDelegate {
+  METADATA_HEADER(SlayzoneSplitView, views::View)
+
+ public:
+  enum class Orientation { kHorizontal, kVertical };
+
+  // Creates a split view. `first` is laid out to the left / top, `second` to
+  // the right / bottom. `initial_fraction` is the size of the first pane as a
+  // fraction of the available main-axis length.
+  SlayzoneSplitView(Orientation orientation,
+                    std::unique_ptr<views::View> first,
+                    std::unique_ptr<views::View> second,
+                    double initial_fraction = 0.5);
+
+  SlayzoneSplitView(const SlayzoneSplitView&) = delete;
+  SlayzoneSplitView& operator=(const SlayzoneSplitView&) = delete;
+  ~SlayzoneSplitView() override;
+
+  double fraction() const { return fraction_; }
+  void SetFraction(double fraction);
+
+  // views::View:
+  void Layout(PassKey key) override;
+  bool OnKeyPressed(const ui::KeyEvent& event) override;
+  gfx::Size CalculatePreferredSize(
+      const views::SizeBounds& available_size) const override;
+
+  // views::ResizeAreaDelegate:
+  void OnResize(int resize_amount, bool done_resizing) override;
+
+ private:
+  // Along-axis thickness of the drag handle, in DIP.
+  static constexpr int kDividerThicknessDip = 6;
+  // Snap window around 0 / 0.5 / 1.
+  static constexpr double kSnapThreshold = 0.04;
+  // Fraction delta per Alt+Arrow tap.
+  static constexpr double kKeyboardStep = 0.05;
+
+  int MainAxisLength() const;
+  void ApplySnap();
+
+  const Orientation orientation_;
+  double fraction_;
+  double fraction_at_drag_start_ = 0.0;
+  raw_ptr<views::View> first_;
+  raw_ptr<views::ResizeArea> divider_;
+  raw_ptr<views::View> second_;
+};
+
+#endif  // CHROME_BROWSER_UI_VIEWS_FRAME_SLAYZONE_SPLIT_VIEW_H_
