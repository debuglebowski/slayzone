+namespace slayzone {
+
+// Browser-process client for the Bun sidecar.
+//
+// Connects to `$SLAYZONE_RUNTIME_DIR/sidecar.sock` (Unix domain socket) and
+// speaks LSP-framed JSON-RPC 2.0 (Content-Length header + `\r\n\r\n` + body).
+// Requests get a monotonic id; responses with matching id invoke the paired
+// callback on the caller's sequence. On disconnect the client reconnects
+// with exponential backoff (500 ms -> 30 s cap). A `sidecar.ping` keepalive
+// is sent every 30 s once connected.
+//
+// Phase 2 scope: the sidecar process itself doesn't exist yet (Phase 3
+// lifts it out of Electron main). This client will therefore log connect
+// attempts and retry forever. Once the Bun sidecar is running the hello
+// handshake completes silently and downstream RPC callers (Phase 3.6
+// proxies) start working without further wiring here.
+//
+// Lifetime: singleton owned by BrowserProcessImpl. Created in browser
+// init, shut down in BrowserProcessImpl::StartTearDown().
+class SidecarClient {
+ public:
+  using ResponseCallback = base::OnceCallback<void(base::DictValue)>;
+
+  // Returns the process-wide instance. Safe to call on any thread; the
+  // instance itself is thread-safe via its internal sequence.
+  static SidecarClient* GetInstance();
+
+  SidecarClient(const SidecarClient&) = delete;
+  SidecarClient& operator=(const SidecarClient&) = delete;
+
+  // Starts the IO thread and kicks off the connect loop. Idempotent.
+  void Start();
+
+  // Stops the IO thread, closes the socket, drops pending callbacks.
+  // Idempotent.
+  void Stop();
+
+  // Sends a JSON-RPC request. `callback` runs on the caller's sequence
+  // when the matching response arrives or when the request is dropped
+  // (empty dict) due to disconnect / shutdown.
+  void Call(std::string_view method,
+            base::DictValue params,
+            ResponseCallback callback);
+
+ private:
+  friend class base::NoDestructor<SidecarClient>;
+
+  SidecarClient();
+  ~SidecarClient();
+
+  class IOState;
+
+  std::unique_ptr<base::Thread> io_thread_;
+  std::unique_ptr<IOState, base::OnTaskRunnerDeleter> io_state_;
+  SEQUENCE_CHECKER(owner_sequence_);
+};
+
+}  // namespace slayzone
+
+#endif  // CHROME_BROWSER_SLAYZONE_SIDECAR_CLIENT_H_
