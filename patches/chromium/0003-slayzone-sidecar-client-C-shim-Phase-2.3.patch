+namespace slayzone {
+
+namespace {
+
+constexpr char kLogTag[] = "[sidecar]";
+constexpr size_t kMaxRecvBuffer = 16 * 1024 * 1024;  // 16 MiB
+constexpr base::TimeDelta kKeepaliveInterval = base::Seconds(30);
+constexpr base::TimeDelta kInitialBackoff = base::Milliseconds(500);
+constexpr base::TimeDelta kMaxBackoff = base::Seconds(30);
+
+// Resolves $SLAYZONE_RUNTIME_DIR/sidecar.sock with platform defaults.
+//   - $SLAYZONE_RUNTIME_DIR if set.
+//   - macOS: $HOME/Library/Application Support/SlayZone/run/
+//   - Linux: $XDG_RUNTIME_DIR/slayzone/ (falls back to /tmp/slayzone-$UID/)
+// Windows uses a named pipe and is not wired in Phase 2.
+base::FilePath ResolveSocketPath() {
+  auto env = base::Environment::Create();
+  std::optional<std::string> override_dir =
+      env->GetVar("SLAYZONE_RUNTIME_DIR");
+  if (override_dir && !override_dir->empty()) {
+    return base::FilePath(*override_dir).Append("sidecar.sock");
+  }
+
+#if BUILDFLAG(IS_MAC)
+  base::FilePath home;
+  if (!base::PathService::Get(base::DIR_HOME, &home)) {
+    return base::FilePath();
+  }
+  return home.Append("Library")
+      .Append("Application Support")
+      .Append("SlayZone")
+      .Append("run")
+      .Append("sidecar.sock");
+#elif BUILDFLAG(IS_LINUX)
+  base::FilePath runtime_dir = base::nix::GetXDGDirectory(
+      env.get(), "XDG_RUNTIME_DIR", nullptr);
+  if (runtime_dir.empty()) {
+    runtime_dir = base::FilePath(
+        base::StrCat({"/tmp/slayzone-", base::NumberToString(getuid())}));
+  } else {
+    runtime_dir = runtime_dir.Append("slayzone");
+  }
+  return runtime_dir.Append("sidecar.sock");
+#else
+  // Phase 2 doesn't wire Windows (named pipes, different transport).
+  return base::FilePath();
+#endif
+}
+
+// Serializes a JSON-RPC request to LSP framing:
+//   Content-Length: N\r\n\r\n{...json...}
+std::string FrameMessage(const base::DictValue& message) {
+  std::string body;
+  base::JSONWriter::Write(message, &body);
+  return base::StrCat({"Content-Length: ", base::NumberToString(body.size()),
+                       "\r\n\r\n", body});
+}
+
+// Parses zero or more LSP-framed messages from a buffer in-place.
+// Appends each parsed message to `out`; returns the number of bytes
+// consumed from the front of `buffer`.
+size_t ConsumeFramedMessages(std::string& buffer,
+                             std::vector<base::DictValue>& out) {
+  size_t consumed = 0;
+  while (true) {
+    std::string_view view(buffer);
+    view.remove_prefix(consumed);
+    size_t header_end = view.find("\r\n\r\n");
+    if (header_end == std::string_view::npos) {
+      break;
+    }
+    std::string_view headers = view.substr(0, header_end);
+    constexpr std::string_view kCL = "Content-Length:";
+    size_t cl_pos = headers.find(kCL);
+    if (cl_pos == std::string_view::npos) {
+      // Malformed frame; skip header block to recover.
+      consumed += header_end + 4;
+      continue;
+    }
+    std::string_view cl_value = headers.substr(cl_pos + kCL.size());
+    while (!cl_value.empty() && (cl_value.front() == ' ' ||
+                                  cl_value.front() == '\t')) {
+      cl_value.remove_prefix(1);
+    }
+    size_t cl_end = cl_value.find_first_of("\r\n");
+    if (cl_end != std::string_view::npos) {
+      cl_value = cl_value.substr(0, cl_end);
+    }
+    size_t body_len = 0;
+    if (!base::StringToSizeT(cl_value, &body_len) ||
+        body_len > kMaxRecvBuffer) {
+      consumed += header_end + 4;
+      continue;
+    }
+    if (view.size() < header_end + 4 + body_len) {
+      break;  // incomplete
+    }
+    std::string_view body = view.substr(header_end + 4, body_len);
+    std::optional<base::DictValue> parsed =
+        base::JSONReader::ReadDict(body, base::JSON_PARSE_RFC);
+    if (parsed) {
+      out.push_back(std::move(*parsed));
+    }
+    consumed += header_end + 4 + body_len;
+  }
+  return consumed;
+}
+
+}  // namespace
+
+// IOState lives on the sidecar IO thread. Owns the socket fd, pending
+// callbacks, and the reconnect/keepalive timers.
+class SidecarClient::IOState {
+ public:
+  IOState() = default;
+  ~IOState() { CloseSocket(); }
+
+  IOState(const IOState&) = delete;
+  IOState& operator=(const IOState&) = delete;
+
+  void Start() {
+    DCHECK(owning_task_runner_ == nullptr ||
+           owning_task_runner_->RunsTasksInCurrentSequence());
+    if (!owning_task_runner_) {
+      owning_task_runner_ = base::SingleThreadTaskRunner::GetCurrentDefault();
+    }
+    if (connect_pending_) {
+      return;
+    }
+    socket_path_ = ResolveSocketPath();
+    if (socket_path_.empty()) {
+      LOG(WARNING) << kLogTag
+                   << " no runtime dir resolved; disabling sidecar client";
+      return;
+    }
+    LOG(INFO) << kLogTag << " runtime socket = " << socket_path_.value();
+    ScheduleConnect(base::TimeDelta());
+  }
+
+  void Stop() {
+    if (owning_task_runner_ &&
+        !owning_task_runner_->RunsTasksInCurrentSequence()) {
+      owning_task_runner_->PostTask(
+          FROM_HERE, base::BindOnce(&IOState::Stop, base::Unretained(this)));
+      return;
+    }
+    stopped_ = true;
+    CloseSocket();
+    keepalive_timer_.Stop();
+    reconnect_timer_.Stop();
+    for (auto& [id, cb] : pending_) {
+      if (cb) {
+        std::move(cb).Run(base::DictValue());
+      }
+    }
+    pending_.clear();
+  }
+
+  void Call(std::string method,
+            base::DictValue params,
+            ResponseCallback callback) {
+    if (!owning_task_runner_) {
+      // Client never started; drop.
+      if (callback) {
+        std::move(callback).Run(base::DictValue());
+      }
+      return;
+    }
+    if (!owning_task_runner_->RunsTasksInCurrentSequence()) {
+      owning_task_runner_->PostTask(
+          FROM_HERE,
+          base::BindOnce(&IOState::Call, base::Unretained(this),
+                         std::move(method), std::move(params),
+                         std::move(callback)));
+      return;
+    }
+    int64_t id = ++next_id_;
+    base::DictValue request;
+    request.Set("jsonrpc", "2.0");
+    request.Set("method", method);
+    request.Set("params", std::move(params));
+    request.Set("id", static_cast<double>(id));
+    if (callback) {
+      pending_[id] = std::move(callback);
+    }
+    if (socket_fd_ < 0) {
+      // Will be replayed once connected? For Phase 2 we fail-fast: Phase 3
+      // sidecar lifecycle owns reliable replay. Drop with empty dict so
+      // callers don't hang.
+      if (auto it = pending_.find(id); it != pending_.end()) {
+        ResponseCallback cb = std::move(it->second);
+        pending_.erase(it);
+        if (cb) {
+          std::move(cb).Run(base::DictValue());
+        }
+      }
+      return;
+    }
+    WriteAll(FrameMessage(request));
+  }
+
+ private:
+  void ScheduleConnect(base::TimeDelta delay) {
+    if (stopped_) {
+      return;
+    }
+    connect_pending_ = true;
+    reconnect_timer_.Start(
+        FROM_HERE, delay,
+        base::BindOnce(&IOState::DoConnect, base::Unretained(this)));
+  }
+
+  void DoConnect() {
+    connect_pending_ = false;
+    if (stopped_) {
+      return;
+    }
+    int fd = socket(AF_UNIX, SOCK_STREAM, 0);
+    if (fd < 0) {
+      LOG(WARNING) << kLogTag << " socket() failed: " << strerror(errno);
+      RetryBackoff();
+      return;
+    }
+    struct sockaddr_un addr = {};
+    addr.sun_family = AF_UNIX;
+    const std::string path = socket_path_.value();
+    if (path.size() >= sizeof(addr.sun_path)) {
+      LOG(ERROR) << kLogTag << " socket path too long: " << path;
+      close(fd);
+      return;  // permanent failure
+    }
+    UNSAFE_TODO(memcpy(addr.sun_path, path.c_str(), path.size()));
+    LOG(INFO) << kLogTag << " connect attempt -> " << path;
+    int rv = HANDLE_EINTR(connect(fd, reinterpret_cast<struct sockaddr*>(&addr),
+                                  sizeof(addr)));
+    if (rv != 0) {
+      LOG(INFO) << kLogTag << " connect failed: " << strerror(errno)
+                << " (will retry)";
+      close(fd);
+      RetryBackoff();
+      return;
+    }
+    socket_fd_ = fd;
+    backoff_ = kInitialBackoff;
+    LOG(INFO) << kLogTag << " connected fd=" << fd;
+    SendHandshake();
+    StartReading();
+    keepalive_timer_.Start(FROM_HERE, kKeepaliveInterval,
+                           base::BindRepeating(&IOState::SendKeepalive,
+                                               base::Unretained(this)));
+  }
+
+  void SendHandshake() {
+    base::DictValue params;
+    params.Set("version", "phase-2");
+    base::DictValue hello;
+    hello.Set("jsonrpc", "2.0");
+    hello.Set("method", "sidecar.hello");
+    hello.Set("params", std::move(params));
+    hello.Set("id", static_cast<double>(++next_id_));
+    WriteAll(FrameMessage(hello));
+  }
+
+  void SendKeepalive() {
+    if (socket_fd_ < 0) {
+      return;
+    }
+    base::DictValue ping;
+    ping.Set("jsonrpc", "2.0");
+    ping.Set("method", "sidecar.ping");
+    ping.Set("params", base::DictValue());
+    ping.Set("id", static_cast<double>(++next_id_));
+    WriteAll(FrameMessage(ping));
+  }
+
+  void StartReading() {
+    // Phase 2: blocking read on the IO thread. The thread has no other
+    // work, so a blocking recv is acceptable. Phase 3 swaps this for
+    // base::FileDescriptorWatcher once the sidecar is real and we need
+    // graceful shutdown mid-read.
+    owning_task_runner_->PostTask(
+        FROM_HERE,
+        base::BindOnce(&IOState::ReadLoop, base::Unretained(this)));
+  }
+
+  void ReadLoop() {
+    if (stopped_ || socket_fd_ < 0) {
+      return;
+    }
+    char buf[8192];
+    ssize_t n = HANDLE_EINTR(recv(socket_fd_, buf, sizeof(buf), 0));
+    if (n <= 0) {
+      LOG(INFO) << kLogTag << " disconnected"
+                << (n == 0 ? " (eof)"
+                           : (std::string(" (") + strerror(errno) + ")"));
+      OnDisconnected();
+      return;
+    }
+    recv_buffer_.append(buf, static_cast<size_t>(n));
+    if (recv_buffer_.size() > kMaxRecvBuffer) {
+      LOG(ERROR) << kLogTag << " recv buffer overflow; resetting";
+      recv_buffer_.clear();
+      OnDisconnected();
+      return;
+    }
+    std::vector<base::DictValue> messages;
+    size_t consumed = ConsumeFramedMessages(recv_buffer_, messages);
+    if (consumed > 0) {
+      recv_buffer_.erase(0, consumed);
+    }
+    for (auto& msg : messages) {
+      DispatchMessage(std::move(msg));
+    }
+    // Continue reading.
+    owning_task_runner_->PostTask(
+        FROM_HERE,
+        base::BindOnce(&IOState::ReadLoop, base::Unretained(this)));
+  }
+
+  void DispatchMessage(base::DictValue msg) {
+    const base::Value* id_val = msg.Find("id");
+    if (!id_val) {
+      // Notification (no id). Phase 3 wires notifications into a dispatcher;
+      // Phase 2 just logs.
+      const std::string* method = msg.FindString("method");
+      LOG(INFO) << kLogTag << " notification "
+                << (method ? *method : "<unknown>");
+      return;
+    }
+    int64_t id = 0;
+    if (id_val->is_int()) {
+      id = id_val->GetInt();
+    } else if (id_val->is_double()) {
+      id = static_cast<int64_t>(id_val->GetDouble());
+    } else {
+      return;
+    }
+    auto it = pending_.find(id);
+    if (it == pending_.end()) {
+      return;  // stale or handshake reply we don't track
+    }
+    ResponseCallback cb = std::move(it->second);
+    pending_.erase(it);
+    if (cb) {
+      std::move(cb).Run(std::move(msg));
+    }
+  }
+
+  void WriteAll(std::string payload) {
+    if (socket_fd_ < 0) {
+      return;
+    }
+    size_t written = 0;
+    while (written < payload.size()) {
+      ssize_t n = HANDLE_EINTR(send(socket_fd_,
+                                    UNSAFE_TODO(payload.data() + written),
+                                    payload.size() - written, 0));
+      if (n < 0) {
+        LOG(INFO) << kLogTag << " send failed: " << strerror(errno);
+        OnDisconnected();
+        return;
+      }
+      written += static_cast<size_t>(n);
+    }
+  }
+
+  void OnDisconnected() {
+    CloseSocket();
+    keepalive_timer_.Stop();
+    recv_buffer_.clear();
+    for (auto& [id, cb] : pending_) {
+      if (cb) {
+        std::move(cb).Run(base::DictValue());
+      }
+    }
+    pending_.clear();
+    RetryBackoff();
+  }
+
+  void RetryBackoff() {
+    if (stopped_) {
+      return;
+    }
+    base::TimeDelta delay = backoff_;
+    backoff_ = std::min(backoff_ * 2, kMaxBackoff);
+    ScheduleConnect(delay);
+  }
+
+  void CloseSocket() {
+    if (socket_fd_ >= 0) {
+      close(socket_fd_);
+      socket_fd_ = -1;
+    }
+  }
+
+  scoped_refptr<base::SingleThreadTaskRunner> owning_task_runner_;
+  base::FilePath socket_path_;
+  int socket_fd_ = -1;
+  std::string recv_buffer_;
+  base::flat_map<int64_t, ResponseCallback> pending_;
+  int64_t next_id_ = 0;
+  base::TimeDelta backoff_ = kInitialBackoff;
+  base::OneShotTimer reconnect_timer_;
+  base::RepeatingTimer keepalive_timer_;
+  bool connect_pending_ = false;
+  bool stopped_ = false;
+};
+
+// static
+SidecarClient* SidecarClient::GetInstance() {
+  static base::NoDestructor<SidecarClient> instance;
+  return instance.get();
+}
+
+SidecarClient::SidecarClient()
+    : io_state_(nullptr, base::OnTaskRunnerDeleter(nullptr)) {}
+
+SidecarClient::~SidecarClient() = default;
+
+void SidecarClient::Start() {
+  DCHECK_CALLED_ON_VALID_SEQUENCE(owner_sequence_);
+  if (io_thread_) {
+    return;
+  }
+  io_thread_ = std::make_unique<base::Thread>("Slayzone.Sidecar");
+  base::Thread::Options options(base::MessagePumpType::DEFAULT, 0);
+  io_thread_->StartWithOptions(std::move(options));
+  io_state_ = std::unique_ptr<IOState, base::OnTaskRunnerDeleter>(
+      new IOState(), base::OnTaskRunnerDeleter(io_thread_->task_runner()));
+  io_thread_->task_runner()->PostTask(
+      FROM_HERE, base::BindOnce(&IOState::Start,
+                                base::Unretained(io_state_.get())));
+}
+
+void SidecarClient::Stop() {
+  DCHECK_CALLED_ON_VALID_SEQUENCE(owner_sequence_);
+  if (!io_thread_) {
+    return;
+  }
+  io_thread_->task_runner()->PostTask(
+      FROM_HERE,
+      base::BindOnce(&IOState::Stop, base::Unretained(io_state_.get())));
+  io_thread_->Stop();
+  io_state_.reset();
+  io_thread_.reset();
+}
+
+void SidecarClient::Call(std::string_view method,
+                         base::DictValue params,
+                         ResponseCallback callback) {
+  if (!io_thread_ || !io_state_) {
+    if (callback) {
+      std::move(callback).Run(base::DictValue());
+    }
+    return;
+  }
+  io_thread_->task_runner()->PostTask(
+      FROM_HERE,
+      base::BindOnce(&IOState::Call, base::Unretained(io_state_.get()),
+                     std::string(method), std::move(params),
+                     std::move(callback)));
+}
+
+}  // namespace slayzone
