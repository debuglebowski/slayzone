index 676998a61f432..3ef0db472a43a 100644
--- a/ui/gfx/image/image_ios.mm
+++ b/ui/gfx/image/image_ios.mm
@@ -34,7 +34,7 @@ UIImage* CreateErrorUIImage(float scale) {
