+namespace slayzone {
+
+// Phase 8.4 — browser-side implementation of
+// `slayzone::git::mojom::GitHost`. One instance per `SlayzoneBrowserView`.
+// Forwards to the process-wide `SidecarClient` via JSON-RPC method
+// `git:get-snapshot`. Read-only in 8.4; mutations (checkout, stash drop,
+// worktree create) land alongside Phase 8.5 / Phase 10.
+class SlayzoneGitHost : public slayzone::git::mojom::GitHost {
+ public:
+  SlayzoneGitHost();
+  SlayzoneGitHost(const SlayzoneGitHost&) = delete;
+  SlayzoneGitHost& operator=(const SlayzoneGitHost&) = delete;
+  ~SlayzoneGitHost() override;
+
+  void Bind(
+      mojo::PendingReceiver<slayzone::git::mojom::GitHost> receiver);
+
+  // slayzone::git::mojom::GitHost:
+  void GetSnapshot(GetSnapshotCallback callback) override;
+
+ private:
+  mojo::ReceiverSet<slayzone::git::mojom::GitHost> receivers_;
+};
+
+}  // namespace slayzone
+
+#endif  // CHROME_BROWSER_SLAYZONE_SLAYZONE_GIT_HOST_H_
