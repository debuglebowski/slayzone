diff --git a/chrome/browser/slayzone/mojom/git.mojom b/chrome/browser/slayzone/mojom/git.mojom
new file mode 100644
index 0000000000000..c4ca9c7a50493
--- /dev/null
+++ b/chrome/browser/slayzone/mojom/git.mojom
@@ -0,0 +1,44 @@
+// Phase 8.4 git region data contract (in-tree mirror).
+// Source of truth: packages/shared/mojo-bindings/mojom/git.mojom.
+// Keep diff-identical below the module line.
+
+module slayzone.git.mojom;
+
+struct GitWorktree {
+  string id;
+  string path;
+  string branch;
+  bool is_current;
+  int32 ahead;
+  int32 behind;
+  int32 dirty_file_count;
+};
+
+struct GitBranch {
+  string name;
+  bool is_current;
+  string upstream;
+  int32 ahead;
+  int32 behind;
+  string last_commit_at;
+};
+
+struct GitStash {
+  string id;
+  string message;
+  string created_at;
+  int32 file_count;
+};
+
+struct GitSnapshot {
+  string active_project_id;
+  string repo_path;
+  string active_tab;
+  array<GitWorktree> worktrees;
+  array<GitBranch> branches;
+  array<GitStash> stashes;
+};
+
+interface GitHost {
+  GetSnapshot() => (GitSnapshot snapshot);
+};
diff --git a/chrome/browser/slayzone/slayzone_git_host.cc b/chrome/browser/slayzone/slayzone_git_host.cc
new file mode 100644
index 0000000000000..79142ae707fc9
--- /dev/null
+++ b/chrome/browser/slayzone/slayzone_git_host.cc
@@ -0,0 +1,115 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/slayzone/slayzone_git_host.h"
+
+#include <string>
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "base/values.h"
+#include "chrome/browser/slayzone/sidecar_client.h"
+
+namespace slayzone {
+
+namespace {
+
+git::mojom::GitWorktreePtr WorktreeFromDict(const base::DictValue& w) {
+  auto wt = git::mojom::GitWorktree::New();
+  if (const std::string* id = w.FindString("id")) wt->id = *id;
+  if (const std::string* path = w.FindString("path")) wt->path = *path;
+  if (const std::string* branch = w.FindString("branch")) wt->branch = *branch;
+  wt->is_current = w.FindBool("isCurrent").value_or(false);
+  wt->ahead = w.FindInt("ahead").value_or(0);
+  wt->behind = w.FindInt("behind").value_or(0);
+  wt->dirty_file_count = w.FindInt("dirtyFileCount").value_or(0);
+  return wt;
+}
+
+git::mojom::GitBranchPtr BranchFromDict(const base::DictValue& b) {
+  auto br = git::mojom::GitBranch::New();
+  if (const std::string* name = b.FindString("name")) br->name = *name;
+  br->is_current = b.FindBool("isCurrent").value_or(false);
+  if (const std::string* up = b.FindString("upstream")) br->upstream = *up;
+  br->ahead = b.FindInt("ahead").value_or(0);
+  br->behind = b.FindInt("behind").value_or(0);
+  if (const std::string* last = b.FindString("lastCommitAt")) {
+    br->last_commit_at = *last;
+  }
+  return br;
+}
+
+git::mojom::GitStashPtr StashFromDict(const base::DictValue& s) {
+  auto st = git::mojom::GitStash::New();
+  if (const std::string* id = s.FindString("id")) st->id = *id;
+  if (const std::string* msg = s.FindString("message")) st->message = *msg;
+  if (const std::string* created = s.FindString("createdAt")) {
+    st->created_at = *created;
+  }
+  st->file_count = s.FindInt("fileCount").value_or(0);
+  return st;
+}
+
+git::mojom::GitSnapshotPtr FromDict(const base::DictValue& response) {
+  auto snapshot = git::mojom::GitSnapshot::New();
+  const base::Value* result = response.Find("result");
+  const base::DictValue* dict =
+      (result && result->is_dict()) ? &result->GetDict() : nullptr;
+  if (!dict) {
+    return snapshot;
+  }
+
+  if (const std::string* active = dict->FindString("activeProjectId")) {
+    snapshot->active_project_id = *active;
+  }
+  if (const std::string* repo = dict->FindString("repoPath")) {
+    snapshot->repo_path = *repo;
+  }
+  if (const std::string* tab = dict->FindString("activeTab")) {
+    snapshot->active_tab = *tab;
+  }
+
+  if (const base::ListValue* worktrees = dict->FindList("worktrees")) {
+    for (const base::Value& entry : *worktrees) {
+      if (!entry.is_dict()) continue;
+      snapshot->worktrees.push_back(WorktreeFromDict(entry.GetDict()));
+    }
+  }
+  if (const base::ListValue* branches = dict->FindList("branches")) {
+    for (const base::Value& entry : *branches) {
+      if (!entry.is_dict()) continue;
+      snapshot->branches.push_back(BranchFromDict(entry.GetDict()));
+    }
+  }
+  if (const base::ListValue* stashes = dict->FindList("stashes")) {
+    for (const base::Value& entry : *stashes) {
+      if (!entry.is_dict()) continue;
+      snapshot->stashes.push_back(StashFromDict(entry.GetDict()));
+    }
+  }
+
+  return snapshot;
+}
+
+}  // namespace
+
+SlayzoneGitHost::SlayzoneGitHost() = default;
+SlayzoneGitHost::~SlayzoneGitHost() = default;
+
+void SlayzoneGitHost::Bind(
+    mojo::PendingReceiver<git::mojom::GitHost> receiver) {
+  receivers_.Add(this, std::move(receiver));
+}
+
+void SlayzoneGitHost::GetSnapshot(GetSnapshotCallback callback) {
+  SidecarClient::GetInstance()->Call(
+      "git:get-snapshot", base::DictValue(),
+      base::BindOnce(
+          [](GetSnapshotCallback cb, base::DictValue response) {
+            std::move(cb).Run(FromDict(response));
+          },
+          std::move(callback)));
+}
+
+}  // namespace slayzone
