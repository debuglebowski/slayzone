+SlayzoneGitUI::SlayzoneGitUI(content::WebUI* web_ui)
+    : content::WebUIController(web_ui) {
+  auto* source = content::WebUIDataSource::CreateAndAdd(
+      Profile::FromWebUI(web_ui), chrome::kChromeUISlayzoneGitHost);
+  slayzone::ConfigureBundleSource(source, "git", kGitMissingBundleHtml);
+}
+
+SlayzoneGitUI::~SlayzoneGitUI() = default;
+
+WEB_UI_CONTROLLER_TYPE_IMPL(SlayzoneGitUI)
+
+void SlayzoneGitUI::BindInterface(
+    mojo::PendingReceiver<slayzone::git::mojom::GitHost> receiver) {
+  SlayzoneBrowserView* view =
+      SlayzoneBrowserView::FromRegionWebContents(web_ui()->GetWebContents());
+  if (!view || !view->git_host()) {
+    return;
+  }
+  view->git_host()->Bind(std::move(receiver));
+}
