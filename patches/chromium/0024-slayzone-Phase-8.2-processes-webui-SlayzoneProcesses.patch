@@ -0,0 +1,27 @@
+// Phase 8.2 processes region data contract (in-tree mirror).
+// Source of truth: packages/shared/mojo-bindings/mojom/processes.mojom.
+// Keep diff-identical below the module line.
+
+module slayzone.processes.mojom;
+
+struct Process {
+  string id;
+  string label;
+  string command;
+  string cwd;
+  string status;
+  int32 pid;
+  int32 exit_code;
+  int32 restart_count;
+  bool auto_restart;
+  string started_at;
+};
+
+struct ProcessesSnapshot {
+  string active_project_id;
+  array<Process> processes;
+};
+
+interface ProcessesHost {
+  GetSnapshot() => (ProcessesSnapshot snapshot);
+};
diff --git a/chrome/browser/slayzone/slayzone_processes_host.cc b/chrome/browser/slayzone/slayzone_processes_host.cc
new file mode 100644
index 0000000000000..777fc5f4e01a0
--- /dev/null
+++ b/chrome/browser/slayzone/slayzone_processes_host.cc
@@ -0,0 +1,89 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/slayzone/slayzone_processes_host.h"
+
+#include <string>
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "base/values.h"
+#include "chrome/browser/slayzone/sidecar_client.h"
+
+namespace slayzone {
+
+namespace {
+
+processes::mojom::ProcessesSnapshotPtr FromDict(
+    const base::DictValue& response) {
+  auto snapshot = processes::mojom::ProcessesSnapshot::New();
+  const base::Value* result = response.Find("result");
+  const base::DictValue* dict =
+      (result && result->is_dict()) ? &result->GetDict() : nullptr;
+  if (!dict) {
+    return snapshot;
+  }
+
+  if (const std::string* active = dict->FindString("activeProjectId")) {
+    snapshot->active_project_id = *active;
+  }
+
+  const base::ListValue* list = dict->FindList("processes");
+  if (list) {
+    for (const base::Value& entry : *list) {
+      if (!entry.is_dict()) {
+        continue;
+      }
+      const base::DictValue& e = entry.GetDict();
+      auto proc = processes::mojom::Process::New();
+      if (const std::string* id = e.FindString("id")) {
+        proc->id = *id;
+      }
+      if (const std::string* label = e.FindString("label")) {
+        proc->label = *label;
+      }
+      if (const std::string* cmd = e.FindString("command")) {
+        proc->command = *cmd;
+      }
+      if (const std::string* cwd = e.FindString("cwd")) {
+        proc->cwd = *cwd;
+      }
+      if (const std::string* st = e.FindString("status")) {
+        proc->status = *st;
+      }
+      proc->pid = e.FindInt("pid").value_or(-1);
+      proc->exit_code = e.FindInt("exitCode").value_or(-1);
+      proc->restart_count = e.FindInt("restartCount").value_or(0);
+      proc->auto_restart = e.FindBool("autoRestart").value_or(false);
+      if (const std::string* started = e.FindString("startedAt")) {
+        proc->started_at = *started;
+      }
+      snapshot->processes.push_back(std::move(proc));
+    }
+  }
+
+  return snapshot;
+}
+
+}  // namespace
+
+SlayzoneProcessesHost::SlayzoneProcessesHost() = default;
+SlayzoneProcessesHost::~SlayzoneProcessesHost() = default;
+
+void SlayzoneProcessesHost::Bind(
+    mojo::PendingReceiver<processes::mojom::ProcessesHost> receiver) {
+  receivers_.Add(this, std::move(receiver));
+}
+
+void SlayzoneProcessesHost::GetSnapshot(GetSnapshotCallback callback) {
+  SidecarClient::GetInstance()->Call(
+      "processes:get-snapshot", base::DictValue(),
+      base::BindOnce(
+          [](GetSnapshotCallback cb, base::DictValue response) {
+            std::move(cb).Run(FromDict(response));
+          },
+          std::move(callback)));
+}
+
+}  // namespace slayzone
