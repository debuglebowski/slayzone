+      border-left: 1px solid #6b2020;
+    }
+  </style>
+</head>
+<body>
+  <span>processes: bundle missing — pass --slayzone-webui-bundle-dir=&lt;repo&gt;/packages/webui</span>
+</body>
+</html>)HTML";
+
+}  // namespace
+
+SlayzoneProcessesUI::SlayzoneProcessesUI(content::WebUI* web_ui)
+    : content::WebUIController(web_ui) {
+  auto* source = content::WebUIDataSource::CreateAndAdd(
+      Profile::FromWebUI(web_ui), chrome::kChromeUISlayzoneProcessesHost);
+  slayzone::ConfigureBundleSource(source, "processes",
+                                  kProcessesMissingBundleHtml);
+}
+
+SlayzoneProcessesUI::~SlayzoneProcessesUI() = default;
+
+WEB_UI_CONTROLLER_TYPE_IMPL(SlayzoneProcessesUI)
+
+void SlayzoneProcessesUI::BindInterface(
+    mojo::PendingReceiver<slayzone::processes::mojom::ProcessesHost> receiver) {
+  SlayzoneBrowserView* view =
+      SlayzoneBrowserView::FromRegionWebContents(web_ui()->GetWebContents());
+  if (!view || !view->processes_host()) {
+    return;
+  }
+  view->processes_host()->Bind(std::move(receiver));
+}
