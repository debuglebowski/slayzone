diff --git a/chrome/browser/slayzone/mojom/tabs.mojom b/chrome/browser/slayzone/mojom/tabs.mojom
index ad2aada804f14..9db53b1a0370b 100644
--- a/chrome/browser/slayzone/mojom/tabs.mojom
+++ b/chrome/browser/slayzone/mojom/tabs.mojom
@@ -29,4 +29,13 @@ interface TabsHost {
   Reload();
   Stop();
   Subscribe(pending_remote<TabObserver> observer);
+
+  // Phase 7.2 — tab-switch instrumentation for the <50ms benchmark deferred
+  // from Phase 6. Returns the currently active tab's handle id plus the
+  // monotonic timestamp (in microseconds since some arbitrary browser-process
+  // epoch) at which it most recently became active. Tabbar JS subtracts its
+  // own `performance.now()` at the moment it issued `SelectTab` from this
+  // timestamp to derive end-to-end switch latency; the epoch cancels in the
+  // delta so the absolute value is irrelevant.
+  GetActiveTabTiming() => (int32 active_id, int64 activated_at_us);
 };
diff --git a/chrome/browser/slayzone/slayzone_tabs_host.cc b/chrome/browser/slayzone/slayzone_tabs_host.cc
index 38e1238451df0..3d84507c8bb94 100644
--- a/chrome/browser/slayzone/slayzone_tabs_host.cc
+++ b/chrome/browser/slayzone/slayzone_tabs_host.cc
@@ -193,9 +193,34 @@ void SlayzoneTabsHost::OnTabStripModelChanged(
     TabStripModel* tab_strip_model,
     const TabStripModelChange& change,
     const TabStripSelectionChange& selection) {
+  // Phase 7.2 — capture the moment an active-tab flip becomes observable.
+  // The tabbar JS correlates its call-site `performance.now()` against this
+  // timestamp (via GetActiveTabTiming) to derive the <50ms switch benchmark.
+  if (selection.active_tab_changed()) {
+    last_activation_tick_ = base::TimeTicks::Now();
+    content::WebContents* active = tab_strip_model->GetActiveWebContents();
+    if (active) {
+      tabs::TabInterface* tab =
+          tabs::TabInterface::MaybeGetFromContents(active);
+      last_active_id_ =
+          tab ? tab->GetHandle().raw_value() : TabHandle::NullValue;
+    } else {
+      last_active_id_ = TabHandle::NullValue;
+    }
+  }
   BroadcastSnapshots();
 }
 
+void SlayzoneTabsHost::GetActiveTabTiming(GetActiveTabTimingCallback callback) {
+  // Microseconds since TimeTicks' arbitrary epoch. Callers only use this in
+  // deltas against their own sample, so the epoch being arbitrary is fine.
+  const int64_t activated_at_us =
+      last_activation_tick_.is_null()
+          ? 0
+          : (last_activation_tick_ - base::TimeTicks()).InMicroseconds();
+  std::move(callback).Run(last_active_id_, activated_at_us);
+}
+
 void SlayzoneTabsHost::OnTabChangedAt(tabs::TabInterface* tab,
                                      int index,
                                      TabChangeType change_type) {
