index c97164e3b0e51..313a3c7db4693 100644
--- a/chrome/browser/slayzone/slayzone_tabs_host.h
+++ b/chrome/browser/slayzone/slayzone_tabs_host.h
@@ -9,6 +9,7 @@
 #include <string>
 
 #include "base/memory/raw_ptr.h"
+#include "base/time/time.h"
 #include "chrome/browser/slayzone/mojom/tabs.mojom.h"
 #include "chrome/browser/ui/tabs/tab_change_type.h"
 #include "chrome/browser/ui/tabs/tab_strip_model_observer.h"
@@ -58,6 +59,7 @@ class SlayzoneTabsHost : public slayzone::tabs::mojom::TabsHost,
   void Stop() override;
   void Subscribe(mojo::PendingRemote<slayzone::tabs::mojom::TabObserver>
                      observer) override;
+  void GetActiveTabTiming(GetActiveTabTimingCallback callback) override;
 
   // TabStripModelObserver:
   void OnTabStripModelChanged(
@@ -80,6 +82,13 @@ class SlayzoneTabsHost : public slayzone::tabs::mojom::TabsHost,
   const raw_ptr<Browser> browser_;
   mojo::ReceiverSet<slayzone::tabs::mojom::TabsHost> receivers_;
   mojo::RemoteSet<slayzone::tabs::mojom::TabObserver> observers_;
+
+  // Phase 7.2 — monotonic timestamp captured whenever the active tab id
+  // flips (observed via `OnTabStripModelChanged` → `BroadcastSnapshots`).
+  // Exposed through `GetActiveTabTiming` so tabbar JS can derive end-to-end
+  // switch latency against its own `performance.now()` at call-site.
+  base::TimeTicks last_activation_tick_;
+  int32_t last_active_id_ = 0;
 };
 
 #endif  // CHROME_BROWSER_SLAYZONE_SLAYZONE_TABS_HOST_H_
