+// Copyright 2026 The Chromium Authors (SlayZone fork)
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_UI_WEBUI_SLAYZONE_SLAYZONE_WEBUI_BUNDLE_SOURCE_H_
+#define CHROME_BROWSER_UI_WEBUI_SLAYZONE_SLAYZONE_WEBUI_BUNDLE_SOURCE_H_
+
+#include <string>
+#include <string_view>
+
+#include "content/public/browser/web_ui_data_source.h"
+
+namespace slayzone {
+
+// Phase 7 recipe extraction — every region WebUI mounts a Vite-built bundle
+// from `--slayzone-webui-bundle-dir/<region>/dist/` with the same CSP,
+// missing-bundle fallback, and async file-read plumbing. Instead of
+// duplicating ~100 LoC per region (0017 statusbar + 0018 projects + 0019
+// tools all inlined this), regions now call:
+//
+//     slayzone::ConfigureBundleSource(source, "<region>",
+//                                     kMissingBundleHtml);
+//
+// and the helper installs a request filter that resolves the region's
+// `<bundle-dir>/<region>/dist/<rel>` file on a MayBlock worker, plus the
+// standard SlayZone CSP (script-src 'self' chrome://resources,
+// style-src 'self' 'unsafe-inline', font/img 'self' data:, TrustedTypes
+// disabled for the Mojo JS runtime).
+//
+// `missing_bundle_html` is the region-specific inline body rendered when
+// `--slayzone-webui-bundle-dir` is absent or the file read misses. Kept
+// per-region so each region's error state can match its chrome (border
+// side, color palette, copy).
+void ConfigureBundleSource(content::WebUIDataSource* source,
+                           std::string_view region,
+                           std::string_view missing_bundle_html);
+
+}  // namespace slayzone
+
+#endif  // CHROME_BROWSER_UI_WEBUI_SLAYZONE_SLAYZONE_WEBUI_BUNDLE_SOURCE_H_
