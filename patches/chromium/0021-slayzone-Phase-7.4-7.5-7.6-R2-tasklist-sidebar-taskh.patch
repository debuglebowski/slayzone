+  // slayzone::sidebar::mojom::SidebarHost:
+  void GetSnapshot(GetSnapshotCallback callback) override;
+
+ private:
+  mojo::ReceiverSet<slayzone::sidebar::mojom::SidebarHost> receivers_;
