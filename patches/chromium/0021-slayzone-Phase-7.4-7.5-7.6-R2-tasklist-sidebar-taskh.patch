diff --git a/chrome/browser/slayzone/slayzone_tasklist_host.cc b/chrome/browser/slayzone/slayzone_tasklist_host.cc
new file mode 100644
index 0000000000000..300fdb0f8e946
--- /dev/null
+++ b/chrome/browser/slayzone/slayzone_tasklist_host.cc
@@ -0,0 +1,94 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/slayzone/slayzone_tasklist_host.h"
+
+#include <string>
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "base/values.h"
+#include "chrome/browser/slayzone/sidecar_client.h"
+
+namespace slayzone {
+
+namespace {
+
+tasklist::mojom::TasklistSnapshotPtr FromDict(const base::DictValue& response) {
+  auto snapshot = tasklist::mojom::TasklistSnapshot::New();
+  const base::Value* result = response.Find("result");
+  const base::DictValue* dict =
+      (result && result->is_dict()) ? &result->GetDict() : nullptr;
+  if (!dict) {
+    return snapshot;
+  }
+
+  if (const std::string* filter = dict->FindString("filter")) {
+    snapshot->filter = *filter;
+  }
+
+  const base::Value::List* columns = dict->FindList("columns");
+  if (columns) {
+    for (const base::Value& col_entry : *columns) {
+      if (!col_entry.is_dict()) {
+        continue;
+      }
+      const base::DictValue& col = col_entry.GetDict();
+      auto column = tasklist::mojom::TasklistColumn::New();
+      if (const std::string* id = col.FindString("id")) {
+        column->id = *id;
+      }
+      if (const std::string* title = col.FindString("title")) {
+        column->title = *title;
+      }
+      const base::Value::List* tasks = col.FindList("tasks");
+      if (tasks) {
+        for (const base::Value& task_entry : *tasks) {
+          if (!task_entry.is_dict()) {
+            continue;
+          }
+          const base::DictValue& task = task_entry.GetDict();
+          auto task_ptr = tasklist::mojom::TaskEntry::New();
+          if (const std::string* id = task.FindString("id")) {
+            task_ptr->id = *id;
+          }
+          if (const std::string* title = task.FindString("title")) {
+            task_ptr->title = *title;
+          }
+          if (const std::string* status = task.FindString("status")) {
+            task_ptr->status = *status;
+          } else {
+            task_ptr->status = column->id;
+          }
+          column->tasks.push_back(std::move(task_ptr));
+        }
+      }
+      snapshot->columns.push_back(std::move(column));
+    }
+  }
+
+  return snapshot;
+}
+
+}  // namespace
+
+SlayzoneTasklistHost::SlayzoneTasklistHost() = default;
+SlayzoneTasklistHost::~SlayzoneTasklistHost() = default;
+
+void SlayzoneTasklistHost::Bind(
+    mojo::PendingReceiver<tasklist::mojom::TasklistHost> receiver) {
+  receivers_.Add(this, std::move(receiver));
+}
+
+void SlayzoneTasklistHost::GetSnapshot(GetSnapshotCallback callback) {
+  SidecarClient::GetInstance()->Call(
+      "tasklist:get-snapshot", base::DictValue(),
+      base::BindOnce(
+          [](GetSnapshotCallback cb, base::DictValue response) {
+            std::move(cb).Run(FromDict(response));
+          },
+          std::move(callback)));
+}
+
+}  // namespace slayzone
