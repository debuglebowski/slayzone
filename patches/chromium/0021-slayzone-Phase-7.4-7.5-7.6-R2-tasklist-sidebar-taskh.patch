index 0000000000000..593eae94c2f9b
--- /dev/null
+++ b/chrome/browser/ui/webui/slayzone/slayzone_webui_bundle_source.cc
@@ -0,0 +1,132 @@
+// Copyright 2026 The Chromium Authors (SlayZone fork)
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/ui/webui/slayzone/slayzone_webui_bundle_source.h"
+
+#include <string>
+#include <utility>
+
+#include "base/command_line.h"
+#include "base/files/file_path.h"
+#include "base/files/file_util.h"
+#include "base/functional/bind.h"
+#include "base/memory/ref_counted_memory.h"
+#include "base/task/thread_pool.h"
+#include "services/network/public/mojom/content_security_policy.mojom.h"
+
+namespace slayzone {
+
+namespace {
+
+// CLI switch pointing at the outer-repo `packages/webui/` root. Set by
+// scripts/chromium/run.sh; when missing a region renders its inline error
+// page.
+constexpr char kSlayzoneWebUIBundleDirSwitch[] = "slayzone-webui-bundle-dir";
+
+base::FilePath ResolveBundleRoot() {
+  const base::CommandLine* cli = base::CommandLine::ForCurrentProcess();
+  if (!cli->HasSwitch(kSlayzoneWebUIBundleDirSwitch)) {
+    return base::FilePath();
+  }
+  return cli->GetSwitchValuePath(kSlayzoneWebUIBundleDirSwitch);
+}
+
+// Blocking file read — hopped to a MayBlock worker below. Returns the file
+// bytes or the region-specific fallback HTML when the index file is missing.
+// Non-index misses resolve to an empty body; the page already loaded so the
+// asset miss becomes a console error rather than a WebContents failure.
+scoped_refptr<base::RefCountedMemory> ReadBundleFileOnWorker(
+    base::FilePath full_path,
+    bool is_index,
+    std::string missing_bundle_html) {
+  std::string contents;
+  if (base::ReadFileToString(full_path, &contents)) {
+    return base::MakeRefCounted<base::RefCountedString>(std::move(contents));
+  }
+  if (is_index) {
+    return base::MakeRefCounted<base::RefCountedString>(
+        std::move(missing_bundle_html));
+  }
+  return base::MakeRefCounted<base::RefCountedString>(std::string());
+}
+
+bool ShouldHandleAnyPath(const std::string& path) {
+  return true;
+}
+
+struct RegionBundleCtx {
+  std::string region;
+  std::string missing_html;
+};
+
+void HandleRegionRequest(
+    const RegionBundleCtx& ctx,
+    const std::string& path,
+    content::WebUIDataSource::GotDataCallback callback) {
+  base::FilePath bundle_root = ResolveBundleRoot();
+  if (bundle_root.empty()) {
+    std::move(callback).Run(base::MakeRefCounted<base::RefCountedString>(
+        ctx.missing_html));
+    return;
+  }
+
+  std::string rel = path;
+  if (!rel.empty() && rel.front() == '/') {
+    rel.erase(0, 1);
+  }
+  const bool is_index = rel.empty();
+  if (is_index) {
+    rel = "index.html";
+  }
+
+  const base::FilePath full = bundle_root.AppendASCII(ctx.region)
+                                   .AppendASCII("dist")
+                                   .AppendASCII(rel);
+
+  base::ThreadPool::PostTaskAndReplyWithResult(
+      FROM_HERE, {base::MayBlock(), base::TaskPriority::USER_VISIBLE},
+      base::BindOnce(&ReadBundleFileOnWorker, full, is_index, ctx.missing_html),
+      std::move(callback));
+}
+
+}  // namespace
+
+void ConfigureBundleSource(content::WebUIDataSource* source,
+                           std::string_view region,
+                           std::string_view missing_bundle_html) {
+  auto ctx = std::make_shared<RegionBundleCtx>();
+  ctx->region = std::string(region);
+  ctx->missing_html = std::string(missing_bundle_html);
+
+  source->SetRequestFilter(
+      base::BindRepeating(&ShouldHandleAnyPath),
+      base::BindRepeating(
+          [](std::shared_ptr<RegionBundleCtx> bound_ctx,
+             const std::string& path,
+             content::WebUIDataSource::GotDataCallback callback) {
+            HandleRegionRequest(*bound_ctx, path, std::move(callback));
+          },
+          ctx));
+
+  // Vite-built bundle emits a hashed <script> + <link rel=stylesheet> under
+  // /assets/. Allow those from the same chrome:// origin, plus
+  // chrome://resources/ for the Mojo JS runtime that generated bindings
+  // import at module evaluation time. Inline styles are emitted by some
+  // Radix components, so style-src allows 'unsafe-inline'.
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::ScriptSrc,
+      "script-src 'self' chrome://resources;");
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::StyleSrc,
+      "style-src 'self' 'unsafe-inline';");
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::FontSrc,
+      "font-src 'self' data:;");
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::ImgSrc,
+      "img-src 'self' data:;");
+  source->DisableTrustedTypesCSP();
+}
+
+}  // namespace slayzone
