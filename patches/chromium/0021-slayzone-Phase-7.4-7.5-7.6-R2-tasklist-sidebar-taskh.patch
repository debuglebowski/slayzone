@@ -0,0 +1,44 @@
+// Phase 7.4 tasklist region data contract.
+//
+// Scope note: lives in packages/shared/mojo-bindings/ (Phase 4.3 territory)
+// as a coordinated exception, following the 5.6 / 6.1 / 7.1 pattern. In-tree
+// mirror at chrome/browser/slayzone/mojom/tasklist.mojom compiles to C++;
+// Phase 4.3 regenerates TS bindings from this outer file. The two must stay
+// diff-identical below the module line.
+//
+// The tasklist region is the kanban board / list view — the biggest surface
+// in Phase 7. The minimal spike surface here is enough to render one column
+// per task status with a title + count, so the region shows real data from
+// the sidecar. Drag-drop + full kanban card contents + filter-bar state come
+// as follow-up work (tracked separately once the parity harness flags the
+// gap visually).
+
+module slayzone.tasklist.mojom;
+
+// One task row — the bare minimum to render a kanban card.
+struct TaskEntry {
+  string id;
+  string title;
+  string status;
+};
+
+// One column (status lane). `id` is the status key; `title` is the user-
+// facing column header; `tasks` is the tasks currently in that column.
+struct TasklistColumn {
+  string id;
+  string title;
+  array<TaskEntry> tasks;
+};
+
+// Full tasklist snapshot — the columns in display order plus the current
+// filter text (surfaced so the filter-bar region can reflect state).
+struct TasklistSnapshot {
+  array<TasklistColumn> columns;
+  string filter;
+};
+
+// Browser-side tasklist data provider. One remote per region WebUI mount.
+// Forwards snapshot queries to the sidecar (tasklist:get-snapshot).
+interface TasklistHost {
+  GetSnapshot() => (TasklistSnapshot snapshot);
+};
diff --git a/chrome/browser/slayzone/slayzone_sidebar_host.cc b/chrome/browser/slayzone/slayzone_sidebar_host.cc
new file mode 100644
index 0000000000000..4ecd09f5c6eb7
--- /dev/null
+++ b/chrome/browser/slayzone/slayzone_sidebar_host.cc
@@ -0,0 +1,79 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/slayzone/slayzone_sidebar_host.h"
+
+#include <string>
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "base/values.h"
+#include "chrome/browser/slayzone/sidecar_client.h"
+
+namespace slayzone {
+
+namespace {
+
+sidebar::mojom::SidebarSnapshotPtr FromDict(const base::DictValue& response) {
+  auto snapshot = sidebar::mojom::SidebarSnapshot::New();
+  const base::Value* result = response.Find("result");
+  const base::DictValue* dict =
+      (result && result->is_dict()) ? &result->GetDict() : nullptr;
+  if (!dict) {
+    return snapshot;
+  }
+
+  if (const std::string* id = dict->FindString("activeTaskId")) {
+    snapshot->active_task_id = *id;
+  }
+  if (const std::string* desc = dict->FindString("description")) {
+    snapshot->description = *desc;
+  }
+  snapshot->priority = dict->FindInt("priority").value_or(0);
+
+  const base::Value::List* tags = dict->FindList("tags");
+  if (tags) {
+    for (const base::Value& tag_entry : *tags) {
+      if (!tag_entry.is_dict()) {
+        continue;
+      }
+      const base::DictValue& t = tag_entry.GetDict();
+      auto tag = sidebar::mojom::SidebarTag::New();
+      if (const std::string* id = t.FindString("id")) {
+        tag->id = *id;
+      }
+      if (const std::string* label = t.FindString("label")) {
+        tag->label = *label;
+      }
+      if (const std::string* color = t.FindString("color")) {
+        tag->color = *color;
+      }
+      snapshot->tags.push_back(std::move(tag));
+    }
+  }
+
+  return snapshot;
+}
+
+}  // namespace
+
+SlayzoneSidebarHost::SlayzoneSidebarHost() = default;
+SlayzoneSidebarHost::~SlayzoneSidebarHost() = default;
+
+void SlayzoneSidebarHost::Bind(
+    mojo::PendingReceiver<sidebar::mojom::SidebarHost> receiver) {
+  receivers_.Add(this, std::move(receiver));
+}
+
+void SlayzoneSidebarHost::GetSnapshot(GetSnapshotCallback callback) {
+  SidecarClient::GetInstance()->Call(
+      "sidebar:get-snapshot", base::DictValue(),
+      base::BindOnce(
+          [](GetSnapshotCallback cb, base::DictValue response) {
+            std::move(cb).Run(FromDict(response));
+          },
+          std::move(callback)));
+}
+
+}  // namespace slayzone
