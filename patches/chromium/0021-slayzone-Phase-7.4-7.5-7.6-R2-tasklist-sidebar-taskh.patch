+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/slayzone/slayzone_taskheader_host.h"
+
+#include <string>
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "base/values.h"
+#include "chrome/browser/slayzone/sidecar_client.h"
+
+namespace slayzone {
+
+namespace {
+
+taskheader::mojom::TaskheaderSnapshotPtr FromDict(
+    const base::DictValue& response) {
+  auto snapshot = taskheader::mojom::TaskheaderSnapshot::New();
+  const base::Value* result = response.Find("result");
+  const base::DictValue* dict =
+      (result && result->is_dict()) ? &result->GetDict() : nullptr;
+  if (!dict) {
+    return snapshot;
+  }
+
+  if (const std::string* id = dict->FindString("activeTaskId")) {
+    snapshot->active_task_id = *id;
+  }
+  if (const std::string* title = dict->FindString("title")) {
+    snapshot->title = *title;
+  }
+  if (const std::string* status = dict->FindString("status")) {
+    snapshot->status = *status;
+  }
+
+  const base::Value::List* options = dict->FindList("statusOptions");
+  if (options) {
+    for (const base::Value& opt_entry : *options) {
+      if (!opt_entry.is_dict()) {
+        continue;
+      }
+      const base::DictValue& o = opt_entry.GetDict();
+      auto opt = taskheader::mojom::StatusOption::New();
+      if (const std::string* id = o.FindString("id")) {
+        opt->id = *id;
+      }
+      if (const std::string* label = o.FindString("label")) {
+        opt->label = *label;
+      }
+      snapshot->status_options.push_back(std::move(opt));
+    }
+  }
+
+  return snapshot;
+}
+
+}  // namespace
+
+SlayzoneTaskheaderHost::SlayzoneTaskheaderHost() = default;
+SlayzoneTaskheaderHost::~SlayzoneTaskheaderHost() = default;
+
+void SlayzoneTaskheaderHost::Bind(
+    mojo::PendingReceiver<taskheader::mojom::TaskheaderHost> receiver) {
+  receivers_.Add(this, std::move(receiver));
+}
+
