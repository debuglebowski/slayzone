diff --git a/chrome/browser/slayzone/mojom/dialog.mojom b/chrome/browser/slayzone/mojom/dialog.mojom
index ab41c3a05df6b..892d729a314c7 100644
--- a/chrome/browser/slayzone/mojom/dialog.mojom
+++ b/chrome/browser/slayzone/mojom/dialog.mojom
@@ -8,3 +8,25 @@ interface DialogHost {
   Resolve(string invocation_id, string result_json) => ();
   Cancel(string invocation_id) => ();
 };
+
+// cap-shell-dialog — native OS file/folder picker. Separate from the in-app
+// DialogHost above (which fronts React-rendered modals); this one fronts
+// `ui::SelectFileDialog`. Renderer calls `window.api.dialog.showOpenDialog`
+// in the window-api-shim; that fans out to `NativeDialogHost.ShowOpenDialog`
+// on the browser side. cap-shell-dialog ships only open (+ SELECT_FOLDER);
+// save + message dialogs stay STUB until cap-shell-6 proper.
+struct ShowOpenDialogOptions {
+  array<string> properties;
+  string default_path;
+  string title;
+};
+
+struct ShowOpenDialogResult {
+  bool canceled;
+  array<string> file_paths;
+};
+
+interface NativeDialogHost {
+  ShowOpenDialog(ShowOpenDialogOptions options)
+      => (ShowOpenDialogResult result);
+};
