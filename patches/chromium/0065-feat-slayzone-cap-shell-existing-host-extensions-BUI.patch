+      .Add<slayzone::json_rpc::mojom::JsonRpcHost>();
   // Phase 7.7 — chrome://slayzone-terminal/ binds to a per-frame
   // SlayzoneTerminalHost owned by the UI controller (one pty per frame).
   registry.ForWebUI<SlayzoneTerminalUI>()
