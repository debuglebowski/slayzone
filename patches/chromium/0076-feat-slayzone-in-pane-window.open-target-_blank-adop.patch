+void SlayzoneEmbeddedTabHost::OnTabStripModelChanged(
+    TabStripModel* tab_strip_model,
+    const TabStripModelChange& change,
+    const TabStripSelectionChange& selection) {
+  if (change.type() != TabStripModelChange::kInserted || creating_owned_tab_) {
+    return;  // not an insert, or it's a tab WE created (CreateView)
+  }
+  const TabStripModelChange::Insert* insert = change.GetInsert();
+  if (!insert) {
+    return;
+  }
+  // Which task owns this model?
+  Browser* owner = nullptr;
+  std::string task_id;
+  for (const auto& [tid, browser] : task_browsers_) {
+    if (browser && browser->tab_strip_model() == tab_strip_model) {
+      owner = browser;
+      task_id = tid;
+      break;
+    }
+  }
+  if (!owner) {
+    return;
+  }
+  for (const auto& cwi : insert->contents) {
+    AdoptForeignTab(task_id, owner, cwi.contents);
+  }
+}
+
+void SlayzoneEmbeddedTabHost::AdoptForeignTab(
+    const std::string& task_id,
+    Browser* browser,
+    content::WebContents* contents) {
+  if (!contents) {
+    return;
+  }
+  // Mint a view for the page-opened tab and tell the renderer to show it as a
+  // new tab in the task's pane (via AttachView, not CreateView).
+  const std::string view_id = "etab-" + base::NumberToString(next_id_++);
+  const std::string tab_id = "popup-" + view_id;
+  entries_.emplace(view_id,
+                   std::make_unique<Entry>(this, view_id, task_id, tab_id,
+                                           browser, contents));
+  lru_.push_back(view_id);
+  EvictIfOverCap();
+  const std::string url = contents->GetVisibleURL().possibly_invalid_spec();
+  LOG(INFO) << "[embedded_tab] adopted page-opened view " << view_id
+            << " task=" << task_id << " url=" << url;
+  if (observer_) {
+    observer_->OnNewView(task_id, view_id, url);
+  }
+}
+
+void SlayzoneEmbeddedTabHost::AttachView(
+    const std::string& view_id,
+    slayzone::embedded_tab::mojom::EmbeddedTabBoundsPtr bounds) {
+  if (!FindEntry(view_id)) {
+    LOG(WARNING) << "[embedded_tab] AttachView — unknown view " << view_id;
+    return;
+  }
+  active_bounds_ = ToRect(bounds);
+  active_visible_ = true;
+  TouchLru(view_id);
+  SetActiveViewId(view_id);  // composite the already-existing WebContents
+}
