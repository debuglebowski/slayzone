+// Copyright 2026 The Chromium Authors (SlayZone fork)
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_SLAYZONE_CRASH_SINK_H_
+#define CHROME_BROWSER_SLAYZONE_CRASH_SINK_H_
+
+namespace slayzone {
+
+// Phase 16.4 local-only crash sink.
+//
+// Crashpad upload was stripped in Phase 2.4 to keep Google phone-home off the
+// wire. This is the replacement: SIGSEGV / SIGABRT / SIGBUS / SIGILL handlers
+// that write a JSON-ish stack trace to
+// ~/Library/Application Support/SlayZone/crashes/<ISO-timestamp>.json.
+//
+// Local file only for Phase 16 — the sidecar HTTP endpoint is a Phase 19
+// follow-up per the task plan.
+//
+// Install() is idempotent and must be called exactly once on the browser
+// process main thread before any worker threads are spawned.
+class CrashSink {
+ public:
+  // Installs signal handlers + pre-composes the JSON prefix (app version,
+  // user-data-dir) so the handler itself can stay async-signal-safe.
+  static void Install();
+
+  // Honors --slayzone-test-crash by aborting with a known signature so the
+  // sink path can be exercised from the run script.
+  static void MaybeTriggerTestCrash();
+
+  CrashSink() = delete;
+};
+
+}  // namespace slayzone
+
+#endif  // CHROME_BROWSER_SLAYZONE_CRASH_SINK_H_
