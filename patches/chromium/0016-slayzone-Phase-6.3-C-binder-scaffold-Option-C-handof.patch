+namespace {
+
+// Phase 6.3 body is intentionally trivial — JS URL bar lands in 7.8.
+// The Mojo binder is reachable regardless so Phase 6 verification can
+// drive TabsHost via CDP / programmatic paths.
+constexpr std::string_view kBrowserchromeHtml = R"HTML(<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <title>SlayZone · browserchrome</title>
+  <style>
+    :root { color-scheme: light dark; }
+    html, body { margin: 0; height: 100%; font: 12px/1.3 system-ui, sans-serif; }
+    body {
+      display: flex; align-items: center; padding: 0 8px;
+      background: color-mix(in oklab, Canvas, CanvasText 4%);
+      color: CanvasText;
+      outline: 1px solid color-mix(in oklab, Canvas, CanvasText 12%);
+      outline-offset: -1px;
+    }
+    .tag { opacity: 0.55; font-size: 11px; }
+  </style>
+</head>
+<body>
+  <span class="tag">browserchrome · Mojo TabsHost bound · UI lands in 7.8</span>
+</body>
+</html>)HTML";
+
+bool ShouldHandleEmptyPath(const std::string& path) {
+  return path.empty();
+}
+
+void HandleRequest(const std::string& path,
+                   content::WebUIDataSource::GotDataCallback callback) {
+  std::move(callback).Run(base::MakeRefCounted<base::RefCountedString>(
+      std::string(kBrowserchromeHtml)));
+}
+
+}  // namespace
+
+SlayzoneBrowserchromeUI::SlayzoneBrowserchromeUI(content::WebUI* web_ui)
+    : content::WebUIController(web_ui) {
+  auto* source = content::WebUIDataSource::CreateAndAdd(
+      Profile::FromWebUI(web_ui),
+      chrome::kChromeUISlayzoneBrowserchromeHost);
+  source->SetRequestFilter(base::BindRepeating(&ShouldHandleEmptyPath),
+                           base::BindRepeating(&HandleRequest));
+}
+
+SlayzoneBrowserchromeUI::~SlayzoneBrowserchromeUI() = default;
+
+WEB_UI_CONTROLLER_TYPE_IMPL(SlayzoneBrowserchromeUI)
+
+void SlayzoneBrowserchromeUI::BindInterface(
+    mojo::PendingReceiver<slayzone::tabs::mojom::TabsHost> receiver) {
+  SlayzoneBrowserView* view =
+      SlayzoneBrowserView::FromRegionWebContents(web_ui()->GetWebContents());
+  if (!view || !view->tabs_host()) {
+    // No owning view found — let the receiver close with a disconnect. This
+    // happens if the browserchrome region is hosted outside a
+    // SlayzoneBrowserView (e.g. direct `chrome://slayzone-browserchrome/`
+    // navigation in a regular tab). Callers retry or surface a UI error.
+    return;
+  }
+  view->tabs_host()->Bind(std::move(receiver));
+}
