+// Back-pointer attached to every region WebView's WebContents so Phase 6.3's
+// Mojo binders can route TabsHost receivers to the owning SlayzoneBrowserView
+// from just the WebContents.
+class RegionData : public content::WebContentsUserData<RegionData> {
+ public:
+  RegionData(const RegionData&) = delete;
+  RegionData& operator=(const RegionData&) = delete;
+  ~RegionData() override = default;
+
+  SlayzoneBrowserView* view() const { return view_; }
+
+ private:
+  friend content::WebContentsUserData<RegionData>;
+  RegionData(content::WebContents* contents, SlayzoneBrowserView* view)
+      : content::WebContentsUserData<RegionData>(*contents), view_(view) {}
+
+  const raw_ptr<SlayzoneBrowserView> view_;
+
+  WEB_CONTENTS_USER_DATA_KEY_DECL();
+};
+
+WEB_CONTENTS_USER_DATA_KEY_IMPL(RegionData);
+
+}  // namespace
+
 SlayzoneBrowserView::SlayzoneBrowserView(Browser* browser)
     : BrowserView(browser),
       layout_host_(std::make_unique<SlayzoneLayoutHost>(this)),
@@ -42,6 +70,23 @@ void SlayzoneBrowserView::AddedToWidget() {
 
   RegisterRegionFocusAccelerators();
 
+  // Phase 6.3 — install a back-pointer on every region WebView's WebContents
+  // so `SlayzoneBrowserView::FromRegionWebContents` can route Mojo binder
+  // calls (e.g. TabsHost receivers from chrome://slayzone-browserchrome/)
+  // back to `this`. Covers every named region — cheap + uniform, costs one
+  // pointer per region WebContents.
+  for (std::string_view id : SlayzoneRegionContainer::kRegionIds) {
+    views::WebView* wv = region_container_->GetRegion(id);
+    if (!wv) {
+      continue;
+    }
+    content::WebContents* contents = wv->GetWebContents();
+    if (!contents) {
+      continue;
+    }
+    RegionData::CreateForWebContents(contents, this);
+  }
+
   // Phase 6.2 — BrowserView is already a TabStripModelObserver and already
   // registered against the strip; we just override OnTabStripModelChanged
   // below and chain to the base. Sync once synchronously for the initial
@@ -50,6 +95,13 @@ void SlayzoneBrowserView::AddedToWidget() {
   SyncInlineTabWebView();
 }
 
+// static
+SlayzoneBrowserView* SlayzoneBrowserView::FromRegionWebContents(
+    content::WebContents* wc) {
+  RegionData* data = wc ? RegionData::FromWebContents(wc) : nullptr;
+  return data ? data->view() : nullptr;
+}
