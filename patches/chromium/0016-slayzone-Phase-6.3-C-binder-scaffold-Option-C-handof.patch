+// Phase 6.3 — chrome://slayzone-browserchrome/ WebUI controller.
+//
+// Scope (Option C handoff): ships the C++ side only — host + WebUIConfig +
+// `BindInterface(TabsHost)` that forwards to the owning
+// `SlayzoneBrowserView`'s `SlayzoneTabsHost`. The bundled TS/JS URL bar UI
+// that consumes the binding lands in Phase 7.8 alongside the rest of the
+// surface migration. Until then the served HTML is a trivial placeholder
+// and the Mojo interface is reachable for programmatic / CDP-driven
+// Phase 6 verification (extensions, SSO, tab-switch perf).
+class SlayzoneBrowserchromeUI : public content::WebUIController {
+ public:
+  explicit SlayzoneBrowserchromeUI(content::WebUI* web_ui);
+  SlayzoneBrowserchromeUI(const SlayzoneBrowserchromeUI&) = delete;
+  SlayzoneBrowserchromeUI& operator=(const SlayzoneBrowserchromeUI&) = delete;
+  ~SlayzoneBrowserchromeUI() override;
+
+  // Called by the WebUI binder registry when a frame under this host
+  // requests `slayzone::tabs::mojom::TabsHost`. Forwards the receiver to
+  // the owning `SlayzoneBrowserView`'s `SlayzoneTabsHost`.
+  void BindInterface(
+      mojo::PendingReceiver<slayzone::tabs::mojom::TabsHost> receiver);
+
+ private:
+  WEB_UI_CONTROLLER_TYPE_DECL();
+};
+
+class SlayzoneBrowserchromeUIConfig
+    : public content::DefaultWebUIConfig<SlayzoneBrowserchromeUI> {
+ public:
+  SlayzoneBrowserchromeUIConfig()
+      : DefaultWebUIConfig(content::kChromeUIScheme,
+                           chrome::kChromeUISlayzoneBrowserchromeHost) {}
+};
+
+#endif  // CHROME_BROWSER_UI_WEBUI_SLAYZONE_SLAYZONE_BROWSERCHROME_UI_H_
