 namespace {
 
-GURL PlaceholderUrl(std::string_view region_id) {
+// Returns the URL that a region WebView should load. Phase 6.3 swaps
+// browserchrome + tabbar off the shared placeholder onto their own hosts
+// so they can bind the Phase 6.1 TabsHost Mojo interface; everything else
+// stays on the placeholder until Phase 7.
+GURL RegionUrl(std::string_view region_id) {
+  if (region_id == "browserchrome") {
+    return GURL(chrome::kChromeUISlayzoneBrowserchromeURL);
