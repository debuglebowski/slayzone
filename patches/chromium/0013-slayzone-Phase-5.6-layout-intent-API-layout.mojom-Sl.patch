+++ b/chrome/browser/slayzone/mojom/layout.mojom
@@ -0,0 +1,18 @@
+// Phase 5.6 layout intent API (C++ side). Mirrors
+// packages/shared/mojo-bindings/mojom/layout.mojom — Phase 4.3 generates TS
+// bindings from the outer file; this tree-local copy is what Chromium's
+// mojom() target consumes. Keep in sync (diff is an invariant).
+
+module slayzone.layout.mojom;
+
+enum RegionAxis {
+  kMain,
+  kCross,
+};
+
+// Owned by the browser process; one remote per region.
+interface LayoutHost {
+  SetRegionVisible(string region_id, bool visible);
+  SetRegionSize(string region_id, uint32 px, RegionAxis axis) => ();
+  FocusRegion(string region_id) => (bool ok);
+};
diff --git a/chrome/browser/slayzone/slayzone_layout_host.cc b/chrome/browser/slayzone/slayzone_layout_host.cc
new file mode 100644
index 0000000000000..1c8fc64c96512
--- /dev/null
+++ b/chrome/browser/slayzone/slayzone_layout_host.cc
@@ -0,0 +1,60 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/slayzone/slayzone_layout_host.h"
+
+#include "base/logging.h"
+#include "chrome/browser/ui/views/frame/slayzone_browser_view.h"
+#include "chrome/browser/ui/views/frame/slayzone_region_container.h"
+#include "ui/views/controls/webview/webview.h"
+#include "ui/views/view.h"
+
+SlayzoneLayoutHost::SlayzoneLayoutHost(SlayzoneBrowserView* view)
+    : view_(view) {}
+
+SlayzoneLayoutHost::~SlayzoneLayoutHost() = default;
+
+void SlayzoneLayoutHost::Bind(
+    mojo::PendingReceiver<slayzone::layout::mojom::LayoutHost> receiver) {
+  receivers_.Add(this, std::move(receiver));
+}
+
+views::WebView* Slot(SlayzoneBrowserView* view, const std::string& id) {
+  if (!view || !view->region_container_for_test()) {
+    return nullptr;
+  }
+  return view->region_container_for_test()->GetRegion(id);
+}
+
+void SlayzoneLayoutHost::SetRegionVisible(const std::string& region_id,
+                                          bool visible) {
+  if (auto* slot = Slot(view_, region_id)) {
+    slot->SetVisible(visible);
+  } else {
+    LOG(WARNING) << "[slayzone] SetRegionVisible: unknown region " << region_id;
+  }
+}
+
+void SlayzoneLayoutHost::SetRegionSize(
+    const std::string& region_id,
+    uint32_t px,
+    slayzone::layout::mojom::RegionAxis axis,
+    SetRegionSizeCallback callback) {
+  // Size is advisory — the enclosing SplitView or BoxLayoutView owns the
+  // authoritative size. Phase 7 wires per-container resize hooks here.
+  (void)region_id;
+  (void)px;
+  (void)axis;
+  std::move(callback).Run();
+}
+
+void SlayzoneLayoutHost::FocusRegion(const std::string& region_id,
+                                     FocusRegionCallback callback) {
+  if (auto* slot = Slot(view_, region_id)) {
+    slot->RequestFocus();
+    std::move(callback).Run(true);
+  } else {
+    std::move(callback).Run(false);
+  }
+}
