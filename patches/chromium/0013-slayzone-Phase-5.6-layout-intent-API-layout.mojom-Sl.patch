+++ b/chrome/browser/slayzone/slayzone_layout_host.h
@@ -0,0 +1,48 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_SLAYZONE_SLAYZONE_LAYOUT_HOST_H_
+#define CHROME_BROWSER_SLAYZONE_SLAYZONE_LAYOUT_HOST_H_
+
+#include <cstdint>
+#include <string>
+
+#include "base/memory/raw_ptr.h"
+#include "chrome/browser/slayzone/mojom/layout.mojom.h"
+#include "mojo/public/cpp/bindings/pending_receiver.h"
+#include "mojo/public/cpp/bindings/receiver_set.h"
+
+class SlayzoneBrowserView;
+
+// Phase 5.6 — browser-side implementation of `slayzone::layout::mojom::LayoutHost`.
+// Owned by `SlayzoneBrowserView`; accepts bindings from region WebUIs and
+// translates calls into native views::View operations on the region container.
+// Binder wiring from chrome://slayzone-* hosts lands alongside Phase 7 when
+// the first real region consumes the interface — until then the impl exists
+// but is unreachable from JS.
+class SlayzoneLayoutHost : public slayzone::layout::mojom::LayoutHost {
+ public:
+  explicit SlayzoneLayoutHost(SlayzoneBrowserView* view);
+  SlayzoneLayoutHost(const SlayzoneLayoutHost&) = delete;
+  SlayzoneLayoutHost& operator=(const SlayzoneLayoutHost&) = delete;
+  ~SlayzoneLayoutHost() override;
+
+  void Bind(mojo::PendingReceiver<slayzone::layout::mojom::LayoutHost>
+                receiver);
+
+  // slayzone::layout::mojom::LayoutHost:
+  void SetRegionVisible(const std::string& region_id, bool visible) override;
+  void SetRegionSize(const std::string& region_id,
+                     uint32_t px,
+                     slayzone::layout::mojom::RegionAxis axis,
+                     SetRegionSizeCallback callback) override;
+  void FocusRegion(const std::string& region_id,
+                   FocusRegionCallback callback) override;
+
+ private:
+  const raw_ptr<SlayzoneBrowserView> view_;
+  mojo::ReceiverSet<slayzone::layout::mojom::LayoutHost> receivers_;
+};
+
+#endif  // CHROME_BROWSER_SLAYZONE_SLAYZONE_LAYOUT_HOST_H_
