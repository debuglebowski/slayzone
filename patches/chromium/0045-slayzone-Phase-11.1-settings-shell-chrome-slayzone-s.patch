+</head>
+<body>
+  <strong>settings: bundle missing</strong>
+  <div class="hint">
+    Start SlayZone with
+    <code>--slayzone-webui-bundle-dir=&lt;repo&gt;/packages/webui</code>
+    and ensure <code>packages/webui/settings/dist</code> has been built
+    (<code>pnpm --filter @slayzone/webui-settings build</code>).
+  </div>
+</body>
+</html>)HTML";
+
+}  // namespace
+
+SlayzoneSettingsUI::SlayzoneSettingsUI(content::WebUI* web_ui)
+    : content::WebUIController(web_ui) {
+  auto* source = content::WebUIDataSource::CreateAndAdd(
+      Profile::FromWebUI(web_ui), chrome::kChromeUISlayzoneSettingsHost);
+  slayzone::ConfigureBundleSource(source, "settings",
+                                  kSettingsMissingBundleHtml);
+}
+
+SlayzoneSettingsUI::~SlayzoneSettingsUI() = default;
+
+WEB_UI_CONTROLLER_TYPE_IMPL(SlayzoneSettingsUI)
