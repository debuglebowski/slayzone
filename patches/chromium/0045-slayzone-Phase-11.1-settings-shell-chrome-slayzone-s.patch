+#ifndef CHROME_BROWSER_UI_WEBUI_SLAYZONE_SLAYZONE_SETTINGS_UI_H_
+#define CHROME_BROWSER_UI_WEBUI_SLAYZONE_SLAYZONE_SETTINGS_UI_H_
+
+#include "chrome/common/webui_url_constants.h"
+#include "content/public/browser/web_ui_controller.h"
+#include "content/public/browser/webui_config.h"
+#include "content/public/common/url_constants.h"
+
+// Phase 11.1 — chrome://slayzone-settings/ WebUI controller.
+//
+// Shell-only in 11.1: the React app owns tab navigation entirely client-side
+// and renders per-tab placeholders. Follow-up patches in Phase 11 (.2–.5) add
+// per-tab Mojo hosts as each tab's data contract lands. A dedicated
+// SlayzoneSettingsHost is intentionally NOT introduced here — settings get/set
+// is a generic string-keyed RPC that each tab's UI can call directly through
+// the SidecarClient once the relevant sub-host is wired. Keeping 11.1 free of
+// mojom plumbing makes the shell a pure layout+routing surface that can be
+// parity-verified without gating on the 468-handler ledger.
+class SlayzoneSettingsUI : public content::WebUIController {
+ public:
+  explicit SlayzoneSettingsUI(content::WebUI* web_ui);
+  SlayzoneSettingsUI(const SlayzoneSettingsUI&) = delete;
+  SlayzoneSettingsUI& operator=(const SlayzoneSettingsUI&) = delete;
+  ~SlayzoneSettingsUI() override;
+
+ private:
+  WEB_UI_CONTROLLER_TYPE_DECL();
+};
+
+class SlayzoneSettingsUIConfig
+    : public content::DefaultWebUIConfig<SlayzoneSettingsUI> {
+ public:
+  SlayzoneSettingsUIConfig()
+      : DefaultWebUIConfig(content::kChromeUIScheme,
+                           chrome::kChromeUISlayzoneSettingsHost) {}
+};
+
+#endif  // CHROME_BROWSER_UI_WEBUI_SLAYZONE_SLAYZONE_SETTINGS_UI_H_
