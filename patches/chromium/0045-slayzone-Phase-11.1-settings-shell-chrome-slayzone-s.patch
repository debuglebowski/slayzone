+constexpr std::string_view kSettingsMissingBundleHtml =
+    R"HTML(<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <title>SlayZone · settings</title>
+  <style>
+    :root { color-scheme: light dark; }
+    html, body { margin: 0; height: 100%; font: 12px/1.4 system-ui, sans-serif; }
+    body {
+      display: flex; flex-direction: column; align-items: center;
+      justify-content: center; gap: 8px; padding: 24px;
+      background: #1c1d20; color: #d4d4d8;
+    }
+    code { background: #2a2b2e; padding: 2px 6px; border-radius: 3px; }
+    .hint { opacity: 0.7; font-size: 11px; max-width: 520px; text-align: center; }
