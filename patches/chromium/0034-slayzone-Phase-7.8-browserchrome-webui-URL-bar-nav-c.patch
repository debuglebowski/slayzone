From: SlayZone Dev <dev@slayzone.local>
Date: Mon, 20 Apr 2026 07:30:27 +0200
Subject: [PATCH] =?UTF-8?q?slayzone:=20Phase=207.8=20browserchrome=20webui?=
 =?UTF-8?q?=20=E2=80=94=20URL=20bar=20+=20nav=20controls?=
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Swap Phase 6.3 placeholder HTML for Vite-built React bundle served via
slayzone::ConfigureBundleSource. The bound TabsHost stays wired — no
new navigation.mojom (all URL-bar state is already on TabSnapshot and
the nav actions are already on TabsHost; a split would duplicate
subscribe plumbing without adding data).
---
 .../slayzone/slayzone_browserchrome_ui.cc     | 38 ++++++-------------
 1 file changed, 12 insertions(+), 26 deletions(-)

diff --git a/chrome/browser/ui/webui/slayzone/slayzone_browserchrome_ui.cc b/chrome/browser/ui/webui/slayzone/slayzone_browserchrome_ui.cc
index f7bc97e7bad9b..52477e673b512 100644
--- a/chrome/browser/ui/webui/slayzone/slayzone_browserchrome_ui.cc
+++ b/chrome/browser/ui/webui/slayzone/slayzone_browserchrome_ui.cc
@@ -8,11 +8,10 @@
 #include <string_view>
 #include <utility>
 
-#include "base/functional/bind.h"
-#include "base/memory/ref_counted_memory.h"
 #include "chrome/browser/profiles/profile.h"
 #include "chrome/browser/slayzone/slayzone_tabs_host.h"
 #include "chrome/browser/ui/views/frame/slayzone_browser_view.h"
+#include "chrome/browser/ui/webui/slayzone/slayzone_webui_bundle_source.h"
 #include "chrome/common/webui_url_constants.h"
 #include "content/public/browser/web_contents.h"
 #include "content/public/browser/web_ui.h"
@@ -20,42 +19,29 @@
 
 namespace {
 
-// Phase 6.3 body is intentionally trivial — JS URL bar lands in 7.8.
-// The Mojo binder is reachable regardless so Phase 6 verification can
-// drive TabsHost via CDP / programmatic paths.
-constexpr std::string_view kBrowserchromeHtml = R"HTML(<!doctype html>
+// Phase 7.8 — bundle-missing fallback. Red-on-dark so a bad run.sh
+// invocation surfaces loudly in the browserchrome strip.
+constexpr std::string_view kBrowserchromeMissingBundleHtml =
+    R"HTML(<!doctype html>
 <html lang="en">
 <head>
   <meta charset="utf-8">
   <title>SlayZone · browserchrome</title>
   <style>
     :root { color-scheme: light dark; }
-    html, body { margin: 0; height: 100%; font: 12px/1.3 system-ui, sans-serif; }
+    html, body { margin: 0; height: 100%; font: 11px/1.3 system-ui, sans-serif; }
     body {
-      display: flex; align-items: center; padding: 0 8px;
-      background: color-mix(in oklab, Canvas, CanvasText 4%);
-      color: CanvasText;
-      outline: 1px solid color-mix(in oklab, Canvas, CanvasText 12%);
-      outline-offset: -1px;
+      display: flex; align-items: center; padding: 0 10px;
+      background: #3a1a1a; color: #fca5a5;
+      border-bottom: 1px solid #6b2020;
     }
-    .tag { opacity: 0.55; font-size: 11px; }
   </style>
 </head>
 <body>
-  <span class="tag">browserchrome · Mojo TabsHost bound · UI lands in 7.8</span>
+  <span>browserchrome: bundle missing — pass --slayzone-webui-bundle-dir=&lt;repo&gt;/packages/webui</span>
 </body>
 </html>)HTML";
 
-bool ShouldHandleEmptyPath(const std::string& path) {
-  return path.empty();
-}
-
-void HandleRequest(const std::string& path,
-                   content::WebUIDataSource::GotDataCallback callback) {
-  std::move(callback).Run(base::MakeRefCounted<base::RefCountedString>(
-      std::string(kBrowserchromeHtml)));
-}
-
 }  // namespace
 
 SlayzoneBrowserchromeUI::SlayzoneBrowserchromeUI(content::WebUI* web_ui)
@@ -63,8 +49,8 @@ SlayzoneBrowserchromeUI::SlayzoneBrowserchromeUI(content::WebUI* web_ui)
   auto* source = content::WebUIDataSource::CreateAndAdd(
       Profile::FromWebUI(web_ui),
       chrome::kChromeUISlayzoneBrowserchromeHost);
-  source->SetRequestFilter(base::BindRepeating(&ShouldHandleEmptyPath),
-                           base::BindRepeating(&HandleRequest));
+  slayzone::ConfigureBundleSource(source, "browserchrome",
+                                  kBrowserchromeMissingBundleHtml);
 }
 
 SlayzoneBrowserchromeUI::~SlayzoneBrowserchromeUI() = default;
-- 
