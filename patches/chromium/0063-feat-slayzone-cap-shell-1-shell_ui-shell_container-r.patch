+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_UI_WEBUI_SLAYZONE_SLAYZONE_SHELL_UI_H_
+#define CHROME_BROWSER_UI_WEBUI_SLAYZONE_SLAYZONE_SHELL_UI_H_
+
+#include <list>
+#include <memory>
+
+#include "base/memory/weak_ptr.h"
+#include "chrome/browser/slayzone/mojom/dialog.mojom.h"
+#include "chrome/browser/slayzone/mojom/embedded_tab.mojom.h"
+#include "chrome/browser/slayzone/mojom/json_rpc.mojom.h"
+#include "chrome/browser/slayzone/mojom/projects.mojom.h"
+#include "chrome/browser/slayzone/mojom/settings.mojom.h"
+#include "chrome/browser/slayzone/mojom/tags.mojom.h"
+#include "chrome/browser/slayzone/mojom/tasklist.mojom.h"
+#include "chrome/browser/slayzone/mojom/terminal.mojom.h"
+#include "chrome/browser/slayzone/mojom/windows.mojom.h"
+#include "chrome/common/webui_url_constants.h"
+#include "content/public/browser/web_ui_controller.h"
+#include "content/public/browser/webui_config.h"
+#include "content/public/common/url_constants.h"
+#include "mojo/public/cpp/bindings/pending_receiver.h"
+
+namespace slayzone {
+class SlayzoneEmbeddedTabHost;
+class SlayzoneJsonRpcHost;
+class SlayzoneNativeDialogHost;
+class SlayzoneSettingsHost;
+class SlayzoneTagsHost;
+class SlayzoneTerminalHost;
+}  // namespace slayzone
+
+// cap-shell-1 — chrome://slayzone-shell/ WebUI. Hosts the extracted Electron
+// renderer (`packages/renderer-app/`) via the Vite-built shell bundle at
+// `packages/apps/shell/dist/`. The bundle directory is passed via the
+// dedicated `--slayzone-shell-bundle-dir` CLI switch (see run.sh).
+//
+// cap-shell-2 — wires the four priority Mojo hosts (TasklistHost / ProjectsHost
+// via the active SlayzoneBrowserView, TagsHost / SettingsHost owned by this
+// UI controller) so the window-api-shim resolves db/tags/settings reads and
+// writes. cap-shell-3..7 add per-feature hosts (terminal, browser-view,
+// windows, dialogs, long-tail JSON-RPC) as each cap lands.
+class SlayzoneShellUI : public content::WebUIController {
+ public:
+  explicit SlayzoneShellUI(content::WebUI* web_ui);
+  SlayzoneShellUI(const SlayzoneShellUI&) = delete;
+  SlayzoneShellUI& operator=(const SlayzoneShellUI&) = delete;
+  ~SlayzoneShellUI() override;
+
+  // cap-shell-2 — Mojo binder entry points. The four hosts are all the
+  // cap-shell-2 shim needs; the shell's in-page `window.api.*` calls fan
+  // out to these plus the JS-side stub-factory for every other namespace.
+  void BindInterface(
+      mojo::PendingReceiver<slayzone::tasklist::mojom::TasklistHost> receiver);
+  void BindInterface(
+      mojo::PendingReceiver<slayzone::projects::mojom::ProjectsHost> receiver);
+  void BindInterface(
+      mojo::PendingReceiver<slayzone::tags::mojom::TagsHost> receiver);
+  void BindInterface(
+      mojo::PendingReceiver<slayzone::settings::mojom::SettingsHost> receiver);
+
+  // cap-shell-3 — each getRemote() call on the JS side allocates a fresh
+  // SlayzoneTerminalHost (one pty per pipe). The shim multiplexes N sessions
+  // client-side by opening N remotes. Hosts self-erase from `terminal_hosts_`
+  // on pipe disconnect via a WeakPtr-anchored PostTask.
+  void BindInterface(
+      mojo::PendingReceiver<slayzone::terminal::mojom::TerminalHost> receiver);
+
+  // cap-shell-dialog — native OS open-folder / open-file picker. One host
+  // per SlayzoneShellUI (dialogs are serial). Sibling of the Phase 10.1
+  // `DialogHost` (same .mojom module, different interface).
+  void BindInterface(
+      mojo::PendingReceiver<slayzone::dialog::mojom::NativeDialogHost>
+          receiver);
+
+  // cap-shell-4 — inline task browser host. One per shell UI; lazily created
+  // on first bind so we don't allocate a WebContents cache until the renderer
+  // actually mounts a <TaskBrowserView>.
+  void BindInterface(
+      mojo::PendingReceiver<slayzone::embedded_tab::mojom::EmbeddedTabHost>
+          receiver);
+
+  // cap-shell-5 — aux-window host. Routes every bind to the process-global
+  // singleton so window_ids stay unique across every SlayzoneShellUI
+  // instance (main shell + spawned aux shells all share one window map).
+  void BindInterface(
+      mojo::PendingReceiver<slayzone::windows::mojom::WindowsHost> receiver);
+
+  // cap-shell-6 — generic JSON-RPC passthrough to the sidecar. Long-tail
+  // shims (fs, feedback, cli-install, changelog, search, ...) call into
+  // this host instead of getting a dedicated mojom. One host per shell
+  // UI, lazily constructed.
+  void BindInterface(
+      mojo::PendingReceiver<slayzone::json_rpc::mojom::JsonRpcHost> receiver);
+
+ private:
+  void EraseTerminalHost(slayzone::SlayzoneTerminalHost* host);
+
+  // Per-WebContents hosts (no BrowserView identity required — scalar KV /
+  // project-scoped lookups). Matches the SlayzoneSettingsUI pattern for
+  // settings_host and the SlayzoneTasklistUI pattern for tags_host.
+  std::unique_ptr<slayzone::SlayzoneTagsHost> tags_host_;
+  std::unique_ptr<slayzone::SlayzoneSettingsHost> settings_host_;
+
+  // cap-shell-3 — N-at-a-time terminal hosts. std::list so raw pointers stay
+  // stable across insert/erase (BindOnce captures the pointer as the erase
+  // key). Pipe disconnect posts a task on the current sequence which calls
+  // EraseTerminalHost(this); posting avoids destroying the receiver from
+  // inside its own disconnect handler.
+  std::list<std::unique_ptr<slayzone::SlayzoneTerminalHost>> terminal_hosts_;
+
+  // cap-shell-dialog — one native dialog host per shell UI instance. Lazily
+  // constructed on first bind so every SlayzoneShellUI has access but we
+  // don't allocate a ui::SelectFileDialog factory listener until the
+  // renderer actually calls `window.api.dialog.showOpenDialog`.
+  std::unique_ptr<slayzone::SlayzoneNativeDialogHost> native_dialog_host_;
+
+  // cap-shell-4 — one inline-task-browser host per shell UI instance. Lazily
+  // constructed on first bind so idle shells (no task-detail mounted) don't
+  // allocate a WebContents cache.
+  std::unique_ptr<slayzone::SlayzoneEmbeddedTabHost> embedded_tab_host_;
+
+  // cap-shell-6 — one JSON-RPC passthrough host per shell UI instance.
+  std::unique_ptr<slayzone::SlayzoneJsonRpcHost> json_rpc_host_;
+
+  base::WeakPtrFactory<SlayzoneShellUI> weak_factory_{this};
+
+  WEB_UI_CONTROLLER_TYPE_DECL();
+};
+
+class SlayzoneShellUIConfig
+    : public content::DefaultWebUIConfig<SlayzoneShellUI> {
+ public:
+  SlayzoneShellUIConfig()
+      : DefaultWebUIConfig(content::kChromeUIScheme,
+                           chrome::kChromeUISlayzoneShellHost) {}
+};
+
+#endif  // CHROME_BROWSER_UI_WEBUI_SLAYZONE_SLAYZONE_SHELL_UI_H_
