+#include "content/public/browser/web_ui_data_source.h"
+#include "services/network/public/mojom/content_security_policy.mojom.h"
+
+namespace {
+
+// cap-shell-1 dedicated switch. Separate from --slayzone-webui-bundle-dir so
+// the per-region bundle source (packages/webui/<region>/dist/) stays untouched
+// while the shell points at packages/apps/shell/dist/. Path-B takeover later
+// can retire the per-region flag once the last region WebUIs are unplumbed.
+constexpr char kSlayzoneShellBundleDirSwitch[] = "slayzone-shell-bundle-dir";
+
+// cap-shell-dx-hmr — server-side proxy to a Vite dev server. When set, every
+// request on chrome://slayzone-shell/<path> is fetched browser-side from
+// <dev_server>/<path> via SimpleURLLoader and the body returned to the
+// renderer as if served from chrome://slayzone-shell/. Same-origin to the
+// renderer, so Mojo bindings still work. Vite's HMR WebSocket goes direct
+// from the page to ws://localhost:5173 (CSP widened in dev mode).
+constexpr char kSlayzoneShellDevServerSwitch[] = "slayzone-shell-dev-server";
+
+constexpr net::NetworkTrafficAnnotationTag kShellDevServerProxyAnnotation =
+    net::DefineNetworkTrafficAnnotation("slayzone_shell_dev_server_proxy", R"(
+        semantics {
+          sender: "SlayZone Shell WebUI"
+          description:
+            "Proxies requests from chrome://slayzone-shell/ to a developer-"
+            "supplied Vite dev server (--slayzone-shell-dev-server) so that "
+            "renderer source edits hot-swap without rebuilding the shell "
+            "bundle. Only enabled when the developer explicitly opts in via "
+            "the command-line switch."
+          trigger:
+            "Each chrome://slayzone-shell/* request when the dev-server "
+            "switch is set."
+          data: "Original request URL path (forwarded as-is to dev server)."
+          destination: OTHER
+          destination_other: "Local Vite dev server, typically localhost."
+        }
+        policy {
+          cookies_allowed: NO
+          setting:
+            "This feature is off by default. Enable by passing "
+            "--slayzone-shell-dev-server=<url> at launch."
+          policy_exception_justification:
+            "Local development tooling, no network reach beyond localhost."
+        })");
+
+constexpr std::string_view kShellMissingBundleHtml =
+    R"HTML(<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <title>SlayZone · shell</title>
+  <style>
+    :root { color-scheme: light dark; }
+    html, body { margin: 0; height: 100%;
+                 font: 12px/1.4 system-ui, sans-serif; }
+    body {
+      display: flex; align-items: center; justify-content: center;
+      background: #3a1a1a; color: #fca5a5; padding: 16px;
+      text-align: center;
+    }
+  </style>
+</head>
+<body>
+  <div>
+    shell bundle missing — pass
+    <code>--slayzone-shell-bundle-dir=&lt;repo&gt;/packages/apps/shell</code>
+    and build the bundle with
+    <code>pnpm --filter @slayzone/shell build</code>.
+  </div>
+</body>
+</html>)HTML";
+
+base::FilePath ResolveShellBundleRoot() {
+  const base::CommandLine* cli = base::CommandLine::ForCurrentProcess();
+  if (!cli->HasSwitch(kSlayzoneShellBundleDirSwitch)) {
+    return base::FilePath();
+  }
+  return cli->GetSwitchValuePath(kSlayzoneShellBundleDirSwitch);
+}
+
+GURL ResolveShellDevServer() {
+  const base::CommandLine* cli = base::CommandLine::ForCurrentProcess();
+  if (!cli->HasSwitch(kSlayzoneShellDevServerSwitch)) return GURL();
+  GURL url(cli->GetSwitchValueASCII(kSlayzoneShellDevServerSwitch));
+  if (!url.is_valid() || !url.SchemeIsHTTPOrHTTPS()) return GURL();
+  return url;
+}
+
+// Holds the per-loader state for an in-flight proxy fetch so it lives until
+// the SimpleURLLoader callback fires.
+struct DevProxyState {
+  std::unique_ptr<network::SimpleURLLoader> loader;
+};
+
+void OnDevProxyComplete(std::unique_ptr<DevProxyState> state,
+                        content::WebUIDataSource::GotDataCallback callback,
+                        std::optional<std::string> body) {
+  if (body.has_value()) {
+    std::move(callback).Run(
+        base::MakeRefCounted<base::RefCountedString>(std::move(*body)));
+  } else {
+    std::move(callback).Run(
+        base::MakeRefCounted<base::RefCountedString>(std::string()));
+  }
+}
+
+void ProxyShellRequestToDevServer(
+    scoped_refptr<network::SharedURLLoaderFactory> loader_factory,
+    const GURL& dev_server,
+    const std::string& path,
+    content::WebUIDataSource::GotDataCallback callback) {
+  std::string rel = path;
+  if (!rel.empty() && rel.front() == '/') rel.erase(0, 1);
+  // Empty path = index document; Vite serves it at "/".
+  GURL target = rel.empty() ? dev_server : dev_server.Resolve(rel);
+
+  auto request = std::make_unique<network::ResourceRequest>();
+  request->url = target;
+  request->method = "GET";
+  request->credentials_mode = network::mojom::CredentialsMode::kOmit;
+  // Tell Vite to skip its index-html injection of dev-only iframes; we want
+  // the same response a browser would get on first navigation.
+  request->headers.SetHeader("Accept", "*/*");
+
+  auto state = std::make_unique<DevProxyState>();
+  state->loader = network::SimpleURLLoader::Create(
+      std::move(request), kShellDevServerProxyAnnotation);
+  // Up to 16 MiB per asset (covers source-mapped chunks comfortably).
+  network::SimpleURLLoader* raw_loader = state->loader.get();
+  raw_loader->DownloadToString(
+      loader_factory.get(),
+      base::BindOnce(&OnDevProxyComplete, std::move(state),
+                     std::move(callback)),
+      /*max_body_size=*/16 * 1024 * 1024);
+}
+
+scoped_refptr<base::RefCountedMemory> ReadShellFileOnWorker(
+    base::FilePath full_path,
+    bool is_index) {
+  std::string contents;
+  if (base::ReadFileToString(full_path, &contents)) {
+    return base::MakeRefCounted<base::RefCountedString>(std::move(contents));
+  }
+  if (is_index) {
+    return base::MakeRefCounted<base::RefCountedString>(
+        std::string(kShellMissingBundleHtml));
+  }
+  // Non-index miss — return empty so the page (already loaded) surfaces the
+  // asset miss as a console error rather than a WebContents load failure.
+  return base::MakeRefCounted<base::RefCountedString>(std::string());
+}
+
+bool ShouldHandleAnyPath(const std::string& path) {
+  return true;
+}
+
+void HandleShellRequest(
+    scoped_refptr<network::SharedURLLoaderFactory> loader_factory,
+    const std::string& path,
+    content::WebUIDataSource::GotDataCallback callback) {
+  // cap-shell-dx-hmr — when a dev server is configured, proxy the request to
+  // it server-side. The renderer sees the result on chrome://slayzone-shell/
+  // origin so Mojo bindings keep working; Vite's HMR WebSocket connects
+  // directly from the page (CSP allows ws://localhost:* in dev mode).
+  GURL dev_server = ResolveShellDevServer();
+  if (dev_server.is_valid() && loader_factory) {
+    ProxyShellRequestToDevServer(std::move(loader_factory), dev_server, path,
+                                 std::move(callback));
+    return;
+  }
+
+  base::FilePath bundle_root = ResolveShellBundleRoot();
+  if (bundle_root.empty()) {
+    std::move(callback).Run(base::MakeRefCounted<base::RefCountedString>(
+        std::string(kShellMissingBundleHtml)));
+    return;
+  }
+
+  std::string rel = path;
+  if (!rel.empty() && rel.front() == '/') {
+    rel.erase(0, 1);
+  }
+  const bool is_index = rel.empty();
+  if (is_index) {
+    rel = "index.html";
+  }
+
+  const base::FilePath full = bundle_root.AppendASCII("dist").AppendASCII(rel);
+
+  base::ThreadPool::PostTaskAndReplyWithResult(
+      FROM_HERE, {base::MayBlock(), base::TaskPriority::USER_VISIBLE},
+      base::BindOnce(&ReadShellFileOnWorker, full, is_index),
+      std::move(callback));
+}
+
+}  // namespace
+
+SlayzoneShellUI::SlayzoneShellUI(content::WebUI* web_ui)
+    : content::WebUIController(web_ui),
+      tags_host_(std::make_unique<slayzone::SlayzoneTagsHost>()),
+      settings_host_(std::make_unique<slayzone::SlayzoneSettingsHost>()) {
+  Profile* profile = Profile::FromWebUI(web_ui);
+  auto* source = content::WebUIDataSource::CreateAndAdd(
+      profile, chrome::kChromeUISlayzoneShellHost);
+
+  // cap-shell-dx-hmr — capture browser-process URLLoaderFactory so the request
+  // filter can fetch from the dev server when --slayzone-shell-dev-server is
+  // set. In prod (no dev-server switch), the factory is unused.
+  scoped_refptr<network::SharedURLLoaderFactory> loader_factory =
+      profile->GetDefaultStoragePartition()
+          ->GetURLLoaderFactoryForBrowserProcess();
+
+  source->SetRequestFilter(
+      base::BindRepeating(&ShouldHandleAnyPath),
+      base::BindRepeating(&HandleShellRequest, std::move(loader_factory)));
+
+  // cap-shell-dx-hmr — widen CSP for the Vite HMR WebSocket and the inline
+  // setup script Vite injects in dev. In prod (no --slayzone-shell-dev-server)
+  // the directives collapse to the original 'self'-anchored set.
+  const bool dev_mode = ResolveShellDevServer().is_valid();
+  const std::string dev_connect_extra =
+      dev_mode ? " ws://localhost:* wss://localhost:* http://localhost:*"
+               : std::string();
+  const std::string dev_script_extra =
+      dev_mode ? " 'unsafe-inline' 'unsafe-eval'" : std::string();
+
+  // CSP mirrors the per-region ConfigureBundleSource: Vite emits a hashed
+  // <script> + stylesheet under /assets/, and radix-ui components emit inline
+  // styles. chrome://resources is needed once cap-shell-2 wires mojo.
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::ScriptSrc,
+      "script-src 'self' chrome://resources" + dev_script_extra + ";");
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::StyleSrc,
+      "style-src 'self' 'unsafe-inline';");
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::FontSrc,
+      "font-src 'self' data:;");
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::ImgSrc,
+      "img-src 'self' data: blob:;");
+  // cap-shell-1: worker-src needed because React 19 + PostHog instrument via
+  // Web Workers. blob: covers the Vite-emitted chunks. Revisit in cap-shell-3
+  // when terminal xterm.js mounts.
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::WorkerSrc,
+      "worker-src 'self' blob:;");
+  // Convex (cap-shell-2) + PostHog will need connect-src; keep 'self' + https:
+  // so the bundle stops at a cap-shell-2 problem, not a CSP one.
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::ConnectSrc,
+      "connect-src 'self' https: wss:" + dev_connect_extra + ";");
+  source->DisableTrustedTypesCSP();
+}
+
+SlayzoneShellUI::~SlayzoneShellUI() = default;
+
+WEB_UI_CONTROLLER_TYPE_IMPL(SlayzoneShellUI)
+
+void SlayzoneShellUI::BindInterface(
+    mojo::PendingReceiver<slayzone::tasklist::mojom::TasklistHost> receiver) {
+  // Tasklist state is per-BrowserView (cap-02 wiring); route to the active
+  // instance so the shell shares the same snapshot / write pipe as the legacy
+  // tasklist WebUI. Silent drop if no active view — the shell is per-window.
+  SlayzoneBrowserView* view = SlayzoneBrowserView::GetActiveInstance();
+  if (!view || !view->tasklist_host()) {
+    return;
+  }
+  view->tasklist_host()->Bind(std::move(receiver));
+}
+
+void SlayzoneShellUI::BindInterface(
+    mojo::PendingReceiver<slayzone::projects::mojom::ProjectsHost> receiver) {
+  SlayzoneBrowserView* view = SlayzoneBrowserView::GetActiveInstance();
+  if (!view || !view->projects_host()) {
+    return;
+  }
+  view->projects_host()->Bind(std::move(receiver));
+}
+
+void SlayzoneShellUI::BindInterface(
+    mojo::PendingReceiver<slayzone::tags::mojom::TagsHost> receiver) {
+  tags_host_->Bind(std::move(receiver));
+}
+
+void SlayzoneShellUI::BindInterface(
+    mojo::PendingReceiver<slayzone::settings::mojom::SettingsHost> receiver) {
+  settings_host_->Bind(std::move(receiver));
+}
+
+void SlayzoneShellUI::BindInterface(
+    mojo::PendingReceiver<slayzone::dialog::mojom::NativeDialogHost> receiver) {
+  if (!native_dialog_host_) {
+    native_dialog_host_ =
+        std::make_unique<slayzone::SlayzoneNativeDialogHost>(
+            web_ui()->GetWebContents());
+  }
+  native_dialog_host_->Bind(std::move(receiver));
+}
+
+void SlayzoneShellUI::BindInterface(
+    mojo::PendingReceiver<slayzone::embedded_tab::mojom::EmbeddedTabHost>
+        receiver) {
+  if (!embedded_tab_host_) {
+    // The embedded tab overlay lives inside SlayzoneShellContainer, which is
+    // owned by the active SlayzoneBrowserView. Shell UIs without an active
+    // browser view (headless / teardown races) get a host with no container
+    // — every call becomes a silent no-op until teardown.
+    SlayzoneBrowserView* view = SlayzoneBrowserView::GetActiveInstance();
+    SlayzoneShellContainer* container =
+        view ? view->shell_container() : nullptr;
+    embedded_tab_host_ = std::make_unique<slayzone::SlayzoneEmbeddedTabHost>(
+        Profile::FromWebUI(web_ui()), container);
+  }
+  embedded_tab_host_->Bind(std::move(receiver));
+}
+
+void SlayzoneShellUI::BindInterface(
+    mojo::PendingReceiver<slayzone::terminal::mojom::TerminalHost> receiver) {
+  auto host = std::make_unique<slayzone::SlayzoneTerminalHost>();
+  slayzone::SlayzoneTerminalHost* host_ptr = host.get();
+  host->Bind(std::move(receiver));
+  terminal_hosts_.push_back(std::move(host));
+  // Disconnect -> defer erase via PostTask so we don't destroy the receiver
+  // from inside its own disconnect handler. WeakPtr anchors on `this` so a
+  // late-firing callback after controller teardown is a safe no-op.
+  host_ptr->SetOnDisconnect(base::BindOnce(
+      [](base::WeakPtr<SlayzoneShellUI> self,
+         slayzone::SlayzoneTerminalHost* host) {
+        base::SequencedTaskRunner::GetCurrentDefault()->PostTask(
+            FROM_HERE,
+            base::BindOnce(&SlayzoneShellUI::EraseTerminalHost,
+                           std::move(self), host));
+      },
+      weak_factory_.GetWeakPtr(), host_ptr));
+}
+
+void SlayzoneShellUI::BindInterface(
+    mojo::PendingReceiver<slayzone::windows::mojom::WindowsHost> receiver) {
+  // Route to the process-global singleton so every shell UI (main + aux)
+  // shares one window_id namespace + one observer fan-out. Pass the caller's
+  // WebContents so CloseCurrentWindow() can resolve the caller's top-level
+  // Widget.
+  slayzone::SlayzoneWindowsHost::GetInstance()->Bind(
+      std::move(receiver), web_ui()->GetWebContents());
+}
+
+void SlayzoneShellUI::BindInterface(
+    mojo::PendingReceiver<slayzone::json_rpc::mojom::JsonRpcHost> receiver) {
+  if (!json_rpc_host_) {
+    json_rpc_host_ = std::make_unique<slayzone::SlayzoneJsonRpcHost>();
+  }
+  json_rpc_host_->Bind(std::move(receiver));
+}
+
+void SlayzoneShellUI::EraseTerminalHost(slayzone::SlayzoneTerminalHost* host) {
+  terminal_hosts_.remove_if(
+      [host](const std::unique_ptr<slayzone::SlayzoneTerminalHost>& p) {
+        return p.get() == host;
+      });
+}
