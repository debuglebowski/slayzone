+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_UI_VIEWS_FRAME_SLAYZONE_SHELL_CONTAINER_H_
+#define CHROME_BROWSER_UI_VIEWS_FRAME_SLAYZONE_SHELL_CONTAINER_H_
+
+#include "base/memory/raw_ptr.h"
+#include "ui/base/metadata/metadata_header_macros.h"
+#include "ui/gfx/geometry/rect.h"
+#include "ui/views/view.h"
+
+namespace content {
+class BrowserContext;
+class WebContents;
+}
+
+namespace views {
+class WebView;
+}
+
+// cap-shell-1 — full-bleed host that renders chrome://slayzone-shell/ in a
+// single views::WebView. Replaces SlayzoneRegionContainer's 14-WebView grid
+// for the Path-B shell takeover.
+//
+// cap-shell-4 — adds one overlay views::WebView stacked above the shell. The
+// embedded-tab host (owned by SlayzoneShellUI) drives WebContents attach /
+// detach + bounds updates through SetEmbeddedTab{WebContents,Bounds,Visible}.
+// The overlay slot is a single shared WebView; the host swaps WebContents
+// when the active view_id changes. Z-order: shell_webview_ is added first
+// and fills the container; embedded_tab_slot_ is added second and renders on
+// top of the shell at the last SetEmbeddedTabBounds rect.
+class SlayzoneShellContainer : public views::View {
+  METADATA_HEADER(SlayzoneShellContainer, views::View)
+
+ public:
+  explicit SlayzoneShellContainer(content::BrowserContext* browser_context);
+  SlayzoneShellContainer(const SlayzoneShellContainer&) = delete;
+  SlayzoneShellContainer& operator=(const SlayzoneShellContainer&) = delete;
+  ~SlayzoneShellContainer() override;
+
+  // Returns the WebContents hosting chrome://slayzone-shell/, or nullptr if
+  // not yet created. cap-shell-2 uses this to route Mojo binder receivers
+  // from the shell's renderer process back to the per-region hosts.
+  content::WebContents* shell_web_contents();
+
+  // cap-shell-4 — embedded-tab overlay API. The host calls these from
+  // SlayzoneEmbeddedTabHost when the active view changes, moves, or toggles
+  // visibility. Passing nullptr to SetEmbeddedTabWebContents detaches the
+  // current WebContents without destroying it (the host owns its lifetime).
+  void SetEmbeddedTabWebContents(content::WebContents* contents);
+  void SetEmbeddedTabBounds(const gfx::Rect& bounds);
+  void SetEmbeddedTabVisible(bool visible);
+
+  // views::View:
+  void Layout(PassKey key) override;
+
+ private:
+  raw_ptr<views::WebView> shell_webview_ = nullptr;
+  raw_ptr<views::WebView> embedded_tab_slot_ = nullptr;
+  gfx::Rect embedded_tab_bounds_;
+  bool embedded_tab_visible_ = false;
+};
+
+#endif  // CHROME_BROWSER_UI_VIEWS_FRAME_SLAYZONE_SHELL_CONTAINER_H_
