+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/ui/views/frame/slayzone_shell_container.h"
+
+#include <memory>
+
+#include "chrome/common/webui_url_constants.h"
+#include "content/public/browser/browser_context.h"
+#include "content/public/browser/web_contents.h"
+#include "ui/base/metadata/metadata_impl_macros.h"
+#include "ui/views/controls/webview/webview.h"
+#include "url/gurl.h"
+
+SlayzoneShellContainer::SlayzoneShellContainer(
+    content::BrowserContext* browser_context) {
+  // Manual Layout(): the shell WebView fills the container, the embedded-tab
+  // slot is explicitly positioned on top. FillLayout would lay out both as
+  // fill; we need a two-child override instead.
+  auto shell_owned = std::make_unique<views::WebView>(browser_context);
+  shell_owned->LoadInitialURL(GURL(chrome::kChromeUISlayzoneShellURL));
+  shell_webview_ = AddChildView(std::move(shell_owned));
+
+  // cap-shell-4 — overlay slot lives above shell_webview_ in Z. Starts hidden
+  // until the host calls SetEmbeddedTab{WebContents,Bounds,Visible}.
+  auto overlay_owned = std::make_unique<views::WebView>(browser_context);
+  overlay_owned->SetVisible(false);
+  embedded_tab_slot_ = AddChildView(std::move(overlay_owned));
+}
+
+SlayzoneShellContainer::~SlayzoneShellContainer() {
+  // Detach the overlay WebContents so the host — which owns the WebContents
+  // via its Entry map — can destroy them without the view holding a stale
+  // pointer after teardown.
+  if (embedded_tab_slot_) {
+    embedded_tab_slot_->SetWebContents(nullptr);
+  }
+}
+
+content::WebContents* SlayzoneShellContainer::shell_web_contents() {
+  return shell_webview_ ? shell_webview_->GetWebContents() : nullptr;
+}
+
+void SlayzoneShellContainer::SetEmbeddedTabWebContents(
+    content::WebContents* contents) {
+  if (!embedded_tab_slot_) {
+    return;
+  }
+  embedded_tab_slot_->SetWebContents(contents);
+}
+
+void SlayzoneShellContainer::SetEmbeddedTabBounds(const gfx::Rect& bounds) {
+  if (bounds == embedded_tab_bounds_) {
+    return;
+  }
+  embedded_tab_bounds_ = bounds;
+  DeprecatedLayoutImmediately();
+}
+
+void SlayzoneShellContainer::SetEmbeddedTabVisible(bool visible) {
+  if (visible == embedded_tab_visible_) {
+    return;
+  }
+  embedded_tab_visible_ = visible;
+  if (embedded_tab_slot_) {
+    embedded_tab_slot_->SetVisible(visible);
+  }
+  DeprecatedLayoutImmediately();
+}
+
+void SlayzoneShellContainer::Layout(PassKey key) {
+  const gfx::Rect contents = GetContentsBounds();
+  if (shell_webview_) {
+    shell_webview_->SetBoundsRect(contents);
+  }
+  if (embedded_tab_slot_) {
+    // Clamp the requested rect to the container so rounding / pre-paint races
+    // in the rAF bounds loop don't send the WebView offscreen.
+    gfx::Rect clamped = embedded_tab_bounds_;
+    clamped.Intersect(contents);
+    embedded_tab_slot_->SetBoundsRect(clamped);
+  }
+}
+
+BEGIN_METADATA(SlayzoneShellContainer)
+END_METADATA
