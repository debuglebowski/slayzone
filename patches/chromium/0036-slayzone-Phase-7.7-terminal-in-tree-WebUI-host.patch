+#include "mojo/public/cpp/bindings/pending_receiver.h"
+
+namespace slayzone {
+class SlayzoneTerminalHost;
+}  // namespace slayzone
+
+// Phase 7.7 — `chrome://slayzone-terminal/` WebUI. Serves the Vite-built
+// xterm.js bundle from the outer repo (`packages/webui/terminal/dist`) and
+// binds a fresh `SlayzoneTerminalHost` per frame. The host is owned by the
+// UI controller (one pty per frame is the desired shape; two terminal
+// regions would mean two independent ptys).
+class SlayzoneTerminalUI : public content::WebUIController {
+ public:
+  explicit SlayzoneTerminalUI(content::WebUI* web_ui);
+  SlayzoneTerminalUI(const SlayzoneTerminalUI&) = delete;
+  SlayzoneTerminalUI& operator=(const SlayzoneTerminalUI&) = delete;
+  ~SlayzoneTerminalUI() override;
+
+  void BindInterface(
+      mojo::PendingReceiver<slayzone::terminal::mojom::TerminalHost> receiver);
+
+ private:
+  std::unique_ptr<slayzone::SlayzoneTerminalHost> host_;
+  WEB_UI_CONTROLLER_TYPE_DECL();
+};
+
+class SlayzoneTerminalUIConfig
+    : public content::DefaultWebUIConfig<SlayzoneTerminalUI> {
+ public:
+  SlayzoneTerminalUIConfig()
+      : DefaultWebUIConfig(content::kChromeUIScheme,
+                           chrome::kChromeUISlayzoneTerminalHost) {}
+};
+
+#endif  // CHROME_BROWSER_UI_WEBUI_SLAYZONE_SLAYZONE_TERMINAL_UI_H_
