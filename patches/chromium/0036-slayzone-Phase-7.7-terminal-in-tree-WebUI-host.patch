+#include "chrome/common/webui_url_constants.h"
+#include "content/public/browser/web_ui.h"
+#include "content/public/browser/web_ui_data_source.h"
+
+namespace {
+
+constexpr std::string_view kTerminalMissingBundleHtml =
+    R"HTML(<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <title>SlayZone · terminal</title>
+  <style>
+    :root { color-scheme: light dark; }
+    html, body { margin: 0; height: 100%; font: 11px/1.3 system-ui, sans-serif; }
+    body {
+      display: flex; align-items: center; padding: 0 10px;
+      background: #3a1a1a; color: #fca5a5;
+    }
+  </style>
+</head>
+<body>
+  <span>terminal: bundle missing — pass --slayzone-webui-bundle-dir=&lt;repo&gt;/packages/webui</span>
+</body>
+</html>)HTML";
+
+}  // namespace
+
+SlayzoneTerminalUI::SlayzoneTerminalUI(content::WebUI* web_ui)
+    : content::WebUIController(web_ui),
+      host_(std::make_unique<slayzone::SlayzoneTerminalHost>()) {
+  auto* source = content::WebUIDataSource::CreateAndAdd(
+      Profile::FromWebUI(web_ui), chrome::kChromeUISlayzoneTerminalHost);
+  slayzone::ConfigureBundleSource(source, "terminal",
+                                  kTerminalMissingBundleHtml);
+}
+
+SlayzoneTerminalUI::~SlayzoneTerminalUI() = default;
+
+WEB_UI_CONTROLLER_TYPE_IMPL(SlayzoneTerminalUI)
+
+void SlayzoneTerminalUI::BindInterface(
+    mojo::PendingReceiver<slayzone::terminal::mojom::TerminalHost> receiver) {
+  host_->Bind(std::move(receiver));
+}
