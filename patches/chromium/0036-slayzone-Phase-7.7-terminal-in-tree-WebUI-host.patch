+  // Phase 7.7 — register a handler for server-initiated JSON-RPC
+  // notifications whose `method` matches. Only one handler per method is
+  // retained (subsequent registrations replace). Pass a null callback to
+  // unregister. The sidecar's `server.broadcast(method, params)` fans out
+  // to every connected socket; this client side dispatches by method name.
+  using NotificationCallback =
+      base::RepeatingCallback<void(const base::Value& params)>;
+  void RegisterNotificationHandler(std::string_view method,
+                                   NotificationCallback callback);
+
  private:
   friend class base::NoDestructor<SidecarClient>;
 
diff --git a/chrome/browser/slayzone/slayzone_terminal_host.cc b/chrome/browser/slayzone/slayzone_terminal_host.cc
new file mode 100644
index 0000000000000..6d55a74d951e9
--- /dev/null
+++ b/chrome/browser/slayzone/slayzone_terminal_host.cc
@@ -0,0 +1,225 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/slayzone/slayzone_terminal_host.h"
+
+#include <string>
+#include <utility>
+
+#include "base/containers/flat_map.h"
+#include "base/functional/bind.h"
+#include "base/logging.h"
+#include "base/no_destructor.h"
+#include "base/values.h"
+#include "chrome/browser/slayzone/sidecar_client.h"
+
+namespace slayzone {
+
+namespace {
+
+// Routes `terminal.output` / `terminal.exit` broadcast notifications to the
+// per-frame SlayzoneTerminalHost that owns the matching pty id. One
+// subscription per method is shared across the whole process; each
+// SlayzoneTerminalHost adds itself to the router's weak-ptr map on Start()
+// and removes itself on destruction. A held weak_ptr that is invalidated
+// (frame teardown mid-flight) is skipped silently.
+class TerminalRouter {
+ public:
+  static TerminalRouter* Get() {
+    static base::NoDestructor<TerminalRouter> router;
+    return router.get();
+  }
+
+  TerminalRouter() = default;
+  TerminalRouter(const TerminalRouter&) = delete;
+  TerminalRouter& operator=(const TerminalRouter&) = delete;
+
+  void Register(const std::string& id,
+                base::WeakPtr<SlayzoneTerminalHost> host) {
+    EnsureSubscribed();
+    hosts_[id] = std::move(host);
+  }
+
+  void Unregister(const std::string& id) { hosts_.erase(id); }
+
+  void DispatchOutput(const base::Value& params) {
+    const base::DictValue* payload = ExtractPayload(params);
+    if (!payload) {
+      return;
+    }
+    const std::string* id = payload->FindString("id");
+    const std::string* data = payload->FindString("data");
+    if (!id || !data) {
+      return;
+    }
+    auto it = hosts_.find(*id);
+    if (it == hosts_.end() || !it->second) {
+      return;
+    }
+    it->second->OnOutput(*data);
+  }
+
+  void DispatchExit(const base::Value& params) {
+    const base::DictValue* payload = ExtractPayload(params);
+    if (!payload) {
+      return;
+    }
+    const std::string* id = payload->FindString("id");
+    if (!id) {
+      return;
+    }
+    const int code = payload->FindInt("code").value_or(0);
+    auto it = hosts_.find(*id);
+    if (it == hosts_.end() || !it->second) {
+      return;
+    }
+    it->second->OnExit(code);
+    hosts_.erase(it);
+  }
+
+ private:
+  void EnsureSubscribed() {
+    if (subscribed_) {
+      return;
+    }
+    subscribed_ = true;
+    SidecarClient::GetInstance()->RegisterNotificationHandler(
+        "terminal.output",
+        base::BindRepeating(&TerminalRouter::DispatchOutput,
+                            base::Unretained(this)));
+    SidecarClient::GetInstance()->RegisterNotificationHandler(
+        "terminal.exit",
+        base::BindRepeating(&TerminalRouter::DispatchExit,
+                            base::Unretained(this)));
+  }
+
+  // The sidecar's `server.broadcast(method, params)` ships params as an
+  // array whose first entry is the handler's payload dict (see
+  // RpcEventMessage in packages/shared/rpc-types/src/protocol.ts). Accept
+  // a bare dict too so future single-object broadcasts just work.
+  static const base::DictValue* ExtractPayload(const base::Value& params) {
+    if (params.is_list() && !params.GetList().empty()) {
+      const base::Value& first = params.GetList().front();
+      if (first.is_dict()) {
+        return &first.GetDict();
+      }
+    }
+    if (params.is_dict()) {
+      return &params.GetDict();
+    }
+    return nullptr;
+  }
+
+  bool subscribed_ = false;
+  base::flat_map<std::string, base::WeakPtr<SlayzoneTerminalHost>> hosts_;
+};
+
+}  // namespace
+
+SlayzoneTerminalHost::SlayzoneTerminalHost() = default;
+
+SlayzoneTerminalHost::~SlayzoneTerminalHost() {
+  if (!pty_id_.empty()) {
+    TerminalRouter::Get()->Unregister(pty_id_);
+    // Best-effort kill — fire-and-forget; sidecar handles dead ids silently.
+    base::DictValue params;
+    params.Set("id", pty_id_);
+    SidecarClient::GetInstance()->Call(
+        "terminal:kill", std::move(params),
+        base::BindOnce([](base::DictValue) {}));
+  }
+}
+
+void SlayzoneTerminalHost::Bind(
+    mojo::PendingReceiver<terminal::mojom::TerminalHost> receiver) {
+  receiver_.Bind(std::move(receiver));
+}
+
+void SlayzoneTerminalHost::Start(const std::string& cwd,
+                                  uint32_t cols,
+                                  uint32_t rows,
+                                  StartCallback callback) {
+  if (!pty_id_.empty()) {
+    // Already started — treat as idempotent success.
+    std::move(callback).Run(true);
+    return;
+  }
+  base::DictValue params;
+  params.Set("cwd", cwd);
+  params.Set("cols", static_cast<int>(cols));
+  params.Set("rows", static_cast<int>(rows));
+  SidecarClient::GetInstance()->Call(
+      "terminal:start", std::move(params),
+      base::BindOnce(
+          [](base::WeakPtr<SlayzoneTerminalHost> self, StartCallback cb,
+             base::DictValue response) {
+            if (!self) {
+              std::move(cb).Run(false);
+              return;
+            }
+            const base::Value* result = response.Find("result");
+            const base::DictValue* dict =
+                (result && result->is_dict()) ? &result->GetDict() : nullptr;
+            if (!dict) {
+              std::move(cb).Run(false);
+              return;
+            }
+            const std::string* id = dict->FindString("id");
+            if (!id || id->empty()) {
+              std::move(cb).Run(false);
+              return;
+            }
+            self->pty_id_ = *id;
+            TerminalRouter::Get()->Register(self->pty_id_,
+                                             self->weak_factory_.GetWeakPtr());
+            std::move(cb).Run(true);
+          },
+          weak_factory_.GetWeakPtr(), std::move(callback)));
+}
+
+void SlayzoneTerminalHost::Write(const std::string& data) {
+  if (pty_id_.empty()) {
+    return;
+  }
+  base::DictValue params;
+  params.Set("id", pty_id_);
+  params.Set("data", data);
+  SidecarClient::GetInstance()->Call(
+      "terminal:write", std::move(params),
+      base::BindOnce([](base::DictValue) {}));
+}
+
+void SlayzoneTerminalHost::Resize(uint32_t cols, uint32_t rows) {
+  if (pty_id_.empty()) {
+    return;
+  }
+  base::DictValue params;
+  params.Set("id", pty_id_);
+  params.Set("cols", static_cast<int>(cols));
+  params.Set("rows", static_cast<int>(rows));
+  SidecarClient::GetInstance()->Call(
+      "terminal:resize", std::move(params),
+      base::BindOnce([](base::DictValue) {}));
+}
+
+void SlayzoneTerminalHost::Subscribe(
+    mojo::PendingRemote<terminal::mojom::TerminalObserver> observer) {
+  observer_.reset();
+  observer_.Bind(std::move(observer));
+}
+
+void SlayzoneTerminalHost::OnOutput(const std::string& data) {
+  if (observer_) {
+    observer_->OnOutput(data);
+  }
+}
+
+void SlayzoneTerminalHost::OnExit(int code) {
+  if (observer_) {
+    observer_->OnExit(code);
+  }
+  pty_id_.clear();
+}
+
+}  // namespace slayzone
