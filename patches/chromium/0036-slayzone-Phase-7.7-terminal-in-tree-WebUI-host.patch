@@ -0,0 +1,66 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_SLAYZONE_SLAYZONE_TERMINAL_HOST_H_
+#define CHROME_BROWSER_SLAYZONE_SLAYZONE_TERMINAL_HOST_H_
+
+#include <string>
+
+#include "base/memory/weak_ptr.h"
+#include "base/values.h"
+#include "chrome/browser/slayzone/mojom/terminal.mojom.h"
+#include "mojo/public/cpp/bindings/pending_receiver.h"
+#include "mojo/public/cpp/bindings/pending_remote.h"
+#include "mojo/public/cpp/bindings/receiver.h"
+#include "mojo/public/cpp/bindings/remote.h"
+
+namespace slayzone {
+
+// Phase 7.7 — one-pty-per-frame terminal host. Every new
+// chrome://slayzone-terminal/ WebUI frame binds its own TerminalHost
+// receiver; the host owns a sidecar-assigned pty id and forwards writes /
+// resizes to `terminal:*` JSON-RPC methods. Output arrives as
+// `terminal.output` notifications, which the host fans out to the currently-
+// subscribed observer. Unlike the per-region singleton hosts (ToolsHost,
+// StatusbarHost, …), this host is instantiated per-frame so two terminal
+// regions don't share a pty.
+class SlayzoneTerminalHost : public slayzone::terminal::mojom::TerminalHost {
+ public:
+  SlayzoneTerminalHost();
+  SlayzoneTerminalHost(const SlayzoneTerminalHost&) = delete;
+  SlayzoneTerminalHost& operator=(const SlayzoneTerminalHost&) = delete;
+  ~SlayzoneTerminalHost() override;
+
+  void Bind(
+      mojo::PendingReceiver<slayzone::terminal::mojom::TerminalHost> receiver);
+
+  // slayzone::terminal::mojom::TerminalHost:
+  void Start(const std::string& cwd,
+             uint32_t cols,
+             uint32_t rows,
+             StartCallback callback) override;
+  void Write(const std::string& data) override;
+  void Resize(uint32_t cols, uint32_t rows) override;
+  void Subscribe(mojo::PendingRemote<slayzone::terminal::mojom::TerminalObserver>
+                     observer) override;
+
+  // Router callbacks — the TerminalRouter (in the .cc) dispatches matching
+  // `terminal.output` / `terminal.exit` notifications into these. Not part
+  // of the Mojo interface; public so the router can reach them via a weak
+  // ptr held in its registration table.
+  void OnOutput(const std::string& data);
+  void OnExit(int code);
+
+ private:
+  mojo::Receiver<slayzone::terminal::mojom::TerminalHost> receiver_{this};
+  mojo::Remote<slayzone::terminal::mojom::TerminalObserver> observer_;
+
+  // Sidecar-assigned pty id. Empty until Start() resolves.
+  std::string pty_id_;
+  base::WeakPtrFactory<SlayzoneTerminalHost> weak_factory_{this};
+};
+
+}  // namespace slayzone
+
+#endif  // CHROME_BROWSER_SLAYZONE_SLAYZONE_TERMINAL_HOST_H_
