+  // Continuation of CreateView once its profile is resolved.
+  void CreateViewOnProfile(
+      slayzone::embedded_tab::mojom::CreateViewParamsPtr params,
+      CreateViewCallback callback,
+      Profile* profile);
+
+  // Open the VISIBLE extension-management window (Web Store + native install
+  // prompts) on the pooled profile named by `profile_key` (empty = default).
+  // Installs land in that identity → apply to that identity's task panes.
+  // Triggered by the CreateView sentinel url "slayzone:open-extensions".
+  void OpenExtensionsWindow(const std::string& profile_key);
+  void OpenExtensionsWindowOnProfile(Profile* profile);
 
   Entry* FindEntry(const std::string& view_id);
 
@@ -162,6 +184,10 @@ class SlayzoneEmbeddedTabHost
   // OnBrowserRemoved when the user closes it.
   raw_ptr<Browser> extensions_browser_ = nullptr;
 
+  // SPIKE — keep-alives holding pooled secondary profiles alive while their
+  // windowless Browsers exist.
+  std::vector<std::unique_ptr<ScopedProfileKeepAlive>> pool_keepalives_;
+
   // view_id → Entry (non-owning ref to a TabStripModel tab + its observer).
   std::map<std::string, std::unique_ptr<Entry>> entries_;
 
