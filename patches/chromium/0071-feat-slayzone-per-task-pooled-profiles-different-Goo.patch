+
+void SlayzoneEmbeddedTabHost::OpenExtensionsWindowOnProfile(Profile* profile) {
   if (!profile) {
-    LOG(WARNING) << "[embedded_tab] OpenExtensionsWindow — no Profile";
+    LOG(WARNING) << "[embedded_tab] OpenExtensionsWindow — profile unresolved";
     return;
   }
+  if (extensions_browser_) {
+    if (extensions_browser_->profile() == profile) {
+      extensions_browser_->window()->Show();
+      extensions_browser_->window()->Activate();
+      return;  // already open on this identity
+    }
+    // A different identity was requested — close the old window first.
+    extensions_browser_->tab_strip_model()->CloseAllTabs();
+    extensions_browser_ = nullptr;
+  }
   // A NORMAL, VISIBLE Browser on the panes' profile. The marker makes the
   // window factory give it a plain BrowserView (real toolbar/omnibox, no shell
   // takeover, not hidden) — so chrome://extensions, the Web Store and native
@@ -293,6 +314,55 @@ void SlayzoneEmbeddedTabHost::OpenExtensionsWindow() {
             << extensions_browser_.get();
 }
 
+void SlayzoneEmbeddedTabHost::ResolveProfile(
+    const std::string& profile_key,
+    base::OnceCallback<void(Profile*)> cb) {
+  if (profile_key.empty()) {
+    // Default identity — the shell's own profile (synchronous).
+    std::move(cb).Run(Profile::FromBrowserContext(browser_context_));
+    return;
+  }
+  ProfileManager* pm = g_browser_process->profile_manager();
+  if (!pm) {
+    std::move(cb).Run(nullptr);
+    return;
+  }
+  const base::FilePath path =
+      pm->user_data_dir().AppendASCII("slayzone-" + profile_key);
+  if (Profile* existing = pm->GetProfileByPath(path)) {
+    EnsureKeepAlive(existing);
+    std::move(cb).Run(existing);
+    return;
+  }
+  LOG(INFO) << "[embedded_tab] creating pooled profile '" << profile_key
+            << "' at " << path.AsUTF8Unsafe();
+  pm->CreateProfileAsync(
+      path, base::BindOnce(
+                [](base::WeakPtr<SlayzoneEmbeddedTabHost> self,
+                   base::OnceCallback<void(Profile*)> cb, Profile* profile) {
+                  if (self && profile) {
+                    self->EnsureKeepAlive(profile);
+                  }
+                  std::move(cb).Run(profile);
+                },
+                weak_factory_.GetWeakPtr(), std::move(cb)));
+}
+
+void SlayzoneEmbeddedTabHost::EnsureKeepAlive(Profile* profile) {
+  if (!profile || profile == Profile::FromBrowserContext(browser_context_)) {
+    return;  // default profile needs no keep-alive from us
+  }
+  for (const auto& ka : pool_keepalives_) {
+    if (ka && ka->profile() == profile) {
+      return;  // already held
+    }
+  }
+  if (auto ka = ScopedProfileKeepAlive::TryAcquire(
+          profile, ProfileKeepAliveOrigin::kHeadlessCommand)) {
+    pool_keepalives_.push_back(std::move(ka));
+  }
+}
+
 void SlayzoneEmbeddedTabHost::CreateView(
     slayzone::embedded_tab::mojom::CreateViewParamsPtr params,
     CreateViewCallback callback) {
@@ -313,7 +383,28 @@ void SlayzoneEmbeddedTabHost::CreateView(
   // Sentinel: open the VISIBLE extension-management window instead of a pane.
   // Reuses the existing mojo pipe so no new mojom is needed for the trigger.
   if (params->url == "slayzone:open-extensions") {
-    OpenExtensionsWindow();
+    OpenExtensionsWindow(params->profile_key);
+    std::move(callback).Run(std::string());
+    return;
+  }
+
+  // Resolve the task's pooled profile (async on first use of a pool), then
+  // build the view on it.
+  const std::string profile_key = params->profile_key;
+  ResolveProfile(
+      profile_key,
+      base::BindOnce(&SlayzoneEmbeddedTabHost::CreateViewOnProfile,
+                     weak_factory_.GetWeakPtr(), std::move(params),
+                     std::move(callback)));
+}
+
+void SlayzoneEmbeddedTabHost::CreateViewOnProfile(
+    slayzone::embedded_tab::mojom::CreateViewParamsPtr params,
+    CreateViewCallback callback,
+    Profile* profile) {
+  if (!profile || !container_) {
+    LOG(WARNING) << "[embedded_tab] CreateViewOnProfile aborted — "
+                 << (!profile ? "profile unresolved" : "no container");
     std::move(callback).Run(std::string());
     return;
   }
@@ -323,10 +414,8 @@ void SlayzoneEmbeddedTabHost::CreateView(
   // creates a fresh one for the same tile. If we returned the SAME view_id, the
   // old anchor's in-flight teardown would destroy the tab the new anchor is now
   // using (a destroy-shared-view race → blank pane). Each CreateView gets its
-  // own tab; the orphaned one is torn down by the renderer's destroyView. The
-  // create-storm that idempotency was meant to cap is gone now that the shell
-  // takeover no longer recurses (see GetOrCreateTaskBrowser marker).
-  Browser* browser = GetOrCreateTaskBrowser(params->task_id);
+  // own tab; the orphaned one is torn down by the renderer's destroyView.
+  Browser* browser = GetOrCreateTaskBrowser(params->task_id, profile);
   if (!browser) {
     std::move(callback).Run(std::string());
     return;
@@ -359,7 +448,8 @@ void SlayzoneEmbeddedTabHost::CreateView(
   EvictIfOverCap();
 
   LOG(INFO) << "[embedded_tab] CreateView resolved view_id=" << view_id
-            << " loaded=" << url.possibly_invalid_spec();
+            << " loaded=" << url.possibly_invalid_spec()
+            << " profile=" << profile->GetPath().BaseName().AsUTF8Unsafe();
   std::move(callback).Run(view_id);
 }
 
