@@ -239,18 +249,29 @@ Browser* SlayzoneEmbeddedTabHost::GetOrCreateTaskBrowser(
   return browser;
 }
 
-void SlayzoneEmbeddedTabHost::OpenExtensionsWindow() {
-  if (extensions_browser_) {
-    // Already open — just surface it.
-    extensions_browser_->window()->Show();
-    extensions_browser_->window()->Activate();
-    return;
-  }
-  Profile* profile = Profile::FromBrowserContext(browser_context_);
+void SlayzoneEmbeddedTabHost::OpenExtensionsWindow(
+    const std::string& profile_key) {
+  ResolveProfile(
+      profile_key,
+      base::BindOnce(&SlayzoneEmbeddedTabHost::OpenExtensionsWindowOnProfile,
