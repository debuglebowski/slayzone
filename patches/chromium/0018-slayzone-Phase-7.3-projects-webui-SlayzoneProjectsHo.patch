diff --git a/chrome/browser/ui/webui/slayzone/slayzone_projects_ui.cc b/chrome/browser/ui/webui/slayzone/slayzone_projects_ui.cc
new file mode 100644
index 0000000000000..7305747899f40
--- /dev/null
+++ b/chrome/browser/ui/webui/slayzone/slayzone_projects_ui.cc
@@ -0,0 +1,148 @@
+// Copyright 2026 The Chromium Authors (SlayZone fork)
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/ui/webui/slayzone/slayzone_projects_ui.h"
+
+#include <string>
+#include <string_view>
+#include <utility>
+
+#include "base/command_line.h"
+#include "base/files/file_path.h"
+#include "base/files/file_util.h"
+#include "base/functional/bind.h"
+#include "base/memory/ref_counted_memory.h"
+#include "base/task/thread_pool.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/browser/slayzone/slayzone_projects_host.h"
+#include "chrome/browser/ui/views/frame/slayzone_browser_view.h"
+#include "chrome/common/webui_url_constants.h"
+#include "content/public/browser/web_contents.h"
+#include "content/public/browser/web_ui.h"
+#include "content/public/browser/web_ui_data_source.h"
+#include "services/network/public/mojom/content_security_policy.mojom.h"
+
+namespace {
+
+// CLI switch pointing at the outer-repo `packages/webui/` root. Set by
+// scripts/chromium/run.sh; when missing the projects UI renders an inline
+// error page so the failure mode is visible at a glance.
+constexpr char kSlayzoneWebUIBundleDirSwitch[] = "slayzone-webui-bundle-dir";
+
+// Inline fallback served when the bundle dir is missing or the file read
+// fails. Deliberately minimal — a non-empty body so the WebView shows
+// something, and a clear message pointing at the probable root cause.
+constexpr std::string_view kProjectsMissingBundleHtml =
+    R"HTML(<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <title>SlayZone · projects</title>
+  <style>
+    :root { color-scheme: light dark; }
+    html, body { margin: 0; height: 100%; font: 11px/1.3 system-ui, sans-serif; }
+    body {
+      display: flex; align-items: center; padding: 0 10px;
+      background: #3a1a1a; color: #fca5a5;
+      border-right: 1px solid #6b2020;
+    }
+  </style>
+</head>
+<body>
+  <span>projects: bundle missing — pass --slayzone-webui-bundle-dir=&lt;repo&gt;/packages/webui</span>
+</body>
+</html>)HTML";
+
+base::FilePath ResolveBundleRoot() {
+  const base::CommandLine* cli = base::CommandLine::ForCurrentProcess();
+  if (!cli->HasSwitch(kSlayzoneWebUIBundleDirSwitch)) {
+    return base::FilePath();
+  }
+  return cli->GetSwitchValuePath(kSlayzoneWebUIBundleDirSwitch);
+}
+
+// Blocking file read — hopped to a MayBlock worker below. Returns the file
+// bytes or the fallback HTML when the file is missing.
+scoped_refptr<base::RefCountedMemory> ReadBundleFileOnWorker(
+    base::FilePath full_path,
+    bool is_index) {
+  std::string contents;
+  if (base::ReadFileToString(full_path, &contents)) {
+    return base::MakeRefCounted<base::RefCountedString>(std::move(contents));
+  }
+  if (is_index) {
+    return base::MakeRefCounted<base::RefCountedString>(
+        std::string(kProjectsMissingBundleHtml));
+  }
+  return base::MakeRefCounted<base::RefCountedString>(std::string());
+}
+
+bool ShouldHandleAnyPath(const std::string& path) {
+  return true;
+}
+
+void HandleProjectsRequest(const std::string& path,
+                           content::WebUIDataSource::GotDataCallback callback) {
+  base::FilePath bundle_root = ResolveBundleRoot();
+  if (bundle_root.empty()) {
+    std::move(callback).Run(base::MakeRefCounted<base::RefCountedString>(
+        std::string(kProjectsMissingBundleHtml)));
+    return;
+  }
+
+  std::string rel = path;
+  if (!rel.empty() && rel.front() == '/') {
+    rel.erase(0, 1);
+  }
+  const bool is_index = rel.empty();
+  if (is_index) {
+    rel = "index.html";
+  }
+
+  const base::FilePath full = bundle_root.AppendASCII("projects")
+                                   .AppendASCII("dist")
+                                   .AppendASCII(rel);
+
+  base::ThreadPool::PostTaskAndReplyWithResult(
+      FROM_HERE, {base::MayBlock(), base::TaskPriority::USER_VISIBLE},
+      base::BindOnce(&ReadBundleFileOnWorker, full, is_index),
+      std::move(callback));
+}
+
+}  // namespace
+
+SlayzoneProjectsUI::SlayzoneProjectsUI(content::WebUI* web_ui)
+    : content::WebUIController(web_ui) {
+  auto* source = content::WebUIDataSource::CreateAndAdd(
+      Profile::FromWebUI(web_ui), chrome::kChromeUISlayzoneProjectsHost);
+  source->SetRequestFilter(base::BindRepeating(&ShouldHandleAnyPath),
+                           base::BindRepeating(&HandleProjectsRequest));
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::ScriptSrc,
+      "script-src 'self' chrome://resources;");
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::StyleSrc,
+      "style-src 'self' 'unsafe-inline';");
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::FontSrc,
+      "font-src 'self' data:;");
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::ImgSrc,
+      "img-src 'self' data:;");
+  source->DisableTrustedTypesCSP();
+}
+
+SlayzoneProjectsUI::~SlayzoneProjectsUI() = default;
+
+WEB_UI_CONTROLLER_TYPE_IMPL(SlayzoneProjectsUI)
+
+void SlayzoneProjectsUI::BindInterface(
+    mojo::PendingReceiver<slayzone::projects::mojom::ProjectsHost> receiver) {
+  SlayzoneBrowserView* view =
+      SlayzoneBrowserView::FromRegionWebContents(web_ui()->GetWebContents());
+  if (!view || !view->projects_host()) {
+    return;
+  }
+  view->projects_host()->Bind(std::move(receiver));
+}
