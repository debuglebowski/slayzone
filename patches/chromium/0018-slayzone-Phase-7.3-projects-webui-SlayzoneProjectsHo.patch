+  void Bind(
+      mojo::PendingReceiver<slayzone::projects::mojom::ProjectsHost>
+          receiver);
+
+  // slayzone::projects::mojom::ProjectsHost:
+  void GetSnapshot(GetSnapshotCallback callback) override;
+
+ private:
+  mojo::ReceiverSet<slayzone::projects::mojom::ProjectsHost> receivers_;
+};
+
+}  // namespace slayzone
