diff --git a/chrome/browser/slayzone/mojom/projects.mojom b/chrome/browser/slayzone/mojom/projects.mojom
new file mode 100644
index 0000000000000..807b8adf51bf5
--- /dev/null
+++ b/chrome/browser/slayzone/mojom/projects.mojom
@@ -0,0 +1,45 @@
+// Phase 7.3 projects region data contract.
+//
+// Scope note: this .mojom lives in packages/shared/mojo-bindings/ (Phase 4.3
+// territory) as a coordinated exception, following the 5.6 layout.mojom and
+// 6.1 tabs.mojom pattern. The in-tree copy at
+// chrome/browser/slayzone/mojom/projects.mojom is what Chromium's mojom()
+// target compiles to C++; Phase 4.3 regenerates TS bindings from this outer
+// file. The two must stay diff-identical below the module line.
+//
+// The projects region is the slim left rail — project icon list plus which
+// one is currently active. Minimal read-only surface following the Phase 7.1
+// recipe; selection is handled by firing a JSON-RPC (`projects:set-active`)
+// through the sidecar rather than a direct Mojo method so the sidecar stays
+// the single source of truth across every region that reads active project
+// id (7.4 tasklist, 7.5 sidebar, 7.6 taskheader).
+
+module slayzone.projects.mojom;
+
+// One project entry — enough to render an icon button. Full metadata comes
+// from task-domain RPCs when a region opens the project.
+struct ProjectEntry {
+  // Stable uuid — matches packages/domains/projects/shared Project.id.
+  string id;
+
+  // User-facing project name. Rendered as tooltip + accessible name.
+  string name;
+
+  // Optional hex color (e.g. "#ff5722"). Empty string when unset — renderer
+  // falls back to an auto-hued badge from `id`.
+  string color;
+};
+
+// Projects rail snapshot. `active_project_id` is empty when no project is
+// selected (fresh install, all projects deleted, etc.).
+struct ProjectsSnapshot {
+  array<ProjectEntry> projects;
+  string active_project_id;
+};
+
+// Browser-side projects data provider. One remote per region WebUI that
+// mounts. The browser forwards snapshot queries to the sidecar over the
+// existing Unix-socket JSON-RPC channel (projects:get-snapshot method).
+interface ProjectsHost {
+  GetSnapshot() => (ProjectsSnapshot snapshot);
+};
diff --git a/chrome/browser/slayzone/slayzone_projects_host.cc b/chrome/browser/slayzone/slayzone_projects_host.cc
new file mode 100644
index 0000000000000..200aa869457d2
--- /dev/null
+++ b/chrome/browser/slayzone/slayzone_projects_host.cc
@@ -0,0 +1,78 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/slayzone/slayzone_projects_host.h"
+
+#include <string>
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "base/values.h"
+#include "chrome/browser/slayzone/sidecar_client.h"
+
+namespace slayzone {
+
+namespace {
+
+// Translate the sidecar's JSON response into a Mojo snapshot. Missing fields
+// fall back to neutral defaults so the region can still render a frame even
+// when the sidecar is handshaking or mid-reconnect.
+projects::mojom::ProjectsSnapshotPtr FromDict(const base::DictValue& response) {
+  auto snapshot = projects::mojom::ProjectsSnapshot::New();
+  const base::Value* result = response.Find("result");
+  const base::DictValue* dict =
+      (result && result->is_dict()) ? &result->GetDict() : nullptr;
+  if (!dict) {
+    return snapshot;
+  }
+
+  if (const std::string* active = dict->FindString("activeProjectId")) {
+    snapshot->active_project_id = *active;
+  }
+
+  const base::Value::List* list = dict->FindList("projects");
+  if (list) {
+    for (const base::Value& entry : *list) {
+      if (!entry.is_dict()) {
+        continue;
+      }
+      const base::DictValue& e = entry.GetDict();
+      auto project = projects::mojom::ProjectEntry::New();
+      if (const std::string* id = e.FindString("id")) {
+        project->id = *id;
+      }
+      if (const std::string* name = e.FindString("name")) {
+        project->name = *name;
+      }
+      if (const std::string* color = e.FindString("color")) {
+        project->color = *color;
+      }
+      snapshot->projects.push_back(std::move(project));
+    }
+  }
+
+  return snapshot;
+}
+
+}  // namespace
+
+SlayzoneProjectsHost::SlayzoneProjectsHost() = default;
+SlayzoneProjectsHost::~SlayzoneProjectsHost() = default;
+
+void SlayzoneProjectsHost::Bind(
+    mojo::PendingReceiver<projects::mojom::ProjectsHost> receiver) {
+  receivers_.Add(this, std::move(receiver));
+}
+
+void SlayzoneProjectsHost::GetSnapshot(GetSnapshotCallback callback) {
+  SidecarClient::GetInstance()->Call(
+      "projects:get-snapshot", base::DictValue(),
+      base::BindOnce(
+          [](GetSnapshotCallback cb, base::DictValue response) {
+            std::move(cb).Run(FromDict(response));
+          },
+          std::move(callback)));
+}
+
+}  // namespace slayzone
