+#ifndef CHROME_BROWSER_UI_WEBUI_SLAYZONE_SLAYZONE_PROJECTS_UI_H_
+#define CHROME_BROWSER_UI_WEBUI_SLAYZONE_SLAYZONE_PROJECTS_UI_H_
+
+#include "chrome/browser/slayzone/mojom/projects.mojom.h"
+#include "chrome/common/webui_url_constants.h"
+#include "content/public/browser/web_ui_controller.h"
+#include "content/public/browser/webui_config.h"
+#include "content/public/common/url_constants.h"
+#include "mojo/public/cpp/bindings/pending_receiver.h"
+
+// Phase 7.3 — chrome://slayzone-projects/ WebUI controller.
+//
+// Serves the @slayzone/webui-projects Vite bundle from the directory named
+// by `--slayzone-webui-bundle-dir`. `BindInterface` hands out per-frame Mojo
+// receivers to the per-BrowserView `SlayzoneProjectsHost`, mirroring the
+// Phase 7.1 statusbar pattern verbatim.
+class SlayzoneProjectsUI : public content::WebUIController {
+ public:
+  explicit SlayzoneProjectsUI(content::WebUI* web_ui);
+  SlayzoneProjectsUI(const SlayzoneProjectsUI&) = delete;
+  SlayzoneProjectsUI& operator=(const SlayzoneProjectsUI&) = delete;
+  ~SlayzoneProjectsUI() override;
+
+  void BindInterface(
+      mojo::PendingReceiver<slayzone::projects::mojom::ProjectsHost>
+          receiver);
+
+ private:
+  WEB_UI_CONTROLLER_TYPE_DECL();
+};
+
+class SlayzoneProjectsUIConfig
+    : public content::DefaultWebUIConfig<SlayzoneProjectsUI> {
+ public:
+  SlayzoneProjectsUIConfig()
+      : DefaultWebUIConfig(content::kChromeUIScheme,
+                           chrome::kChromeUISlayzoneProjectsHost) {}
+};
+
+#endif  // CHROME_BROWSER_UI_WEBUI_SLAYZONE_SLAYZONE_PROJECTS_UI_H_
