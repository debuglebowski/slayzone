++SlayzoneSplitView::SlayzoneSplitView(Orientation orientation,
++                                     std::unique_ptr<views::View> first,
++                                     std::unique_ptr<views::View> second,
++                                     double initial_fraction)
++    : orientation_(orientation),
++      fraction_(std::clamp(initial_fraction, 0.0, 1.0)) {
++  first_ = AddChildView(std::move(first));
++  divider_ = AddChildView(std::make_unique<views::ResizeArea>(this));
++  second_ = AddChildView(std::move(second));
++  SetFocusBehavior(FocusBehavior::ACCESSIBLE_ONLY);
++}
++
++SlayzoneSplitView::~SlayzoneSplitView() = default;
++
++void SlayzoneSplitView::SetFraction(double fraction) {
++  fraction = std::clamp(fraction, 0.0, 1.0);
++  if (fraction == fraction_) {
++    return;
++  }
++  fraction_ = fraction;
++  InvalidateLayout();
++}
++
++int SlayzoneSplitView::MainAxisLength() const {
++  return orientation_ == Orientation::kHorizontal ? width() : height();
++}
++
++void SlayzoneSplitView::ApplySnap() {
++  for (double snap : {0.0, 0.5, 1.0}) {
++    if (std::abs(fraction_ - snap) < kSnapThreshold) {
++      fraction_ = snap;
++      return;
++    }
++  }
++}
++
++void SlayzoneSplitView::Layout(PassKey key) {
++  const gfx::Rect bounds = GetContentsBounds();
++  if (bounds.IsEmpty()) {
++    return;
++  }
++  const int main = MainAxisLength();
++  if (main <= kDividerThicknessDip) {
++    // Not enough space — hand everything to `first_`.
++    first_->SetBoundsRect(bounds);
++    divider_->SetBoundsRect(gfx::Rect());
++    second_->SetBoundsRect(gfx::Rect());
++    return;
++  }
++  const int usable = main - kDividerThicknessDip;
++  const int first_main = std::clamp<int>(
++      static_cast<int>(std::round(usable * fraction_)), 0, usable);
++
++  if (orientation_ == Orientation::kHorizontal) {
++    first_->SetBoundsRect(
++        gfx::Rect(bounds.x(), bounds.y(), first_main, bounds.height()));
++    divider_->SetBoundsRect(gfx::Rect(bounds.x() + first_main, bounds.y(),
++                                      kDividerThicknessDip, bounds.height()));
++    second_->SetBoundsRect(
++        gfx::Rect(bounds.x() + first_main + kDividerThicknessDip, bounds.y(),
++                  usable - first_main, bounds.height()));
++  } else {
++    first_->SetBoundsRect(
++        gfx::Rect(bounds.x(), bounds.y(), bounds.width(), first_main));
++    divider_->SetBoundsRect(gfx::Rect(bounds.x(), bounds.y() + first_main,
++                                      bounds.width(), kDividerThicknessDip));
++    second_->SetBoundsRect(
++        gfx::Rect(bounds.x(), bounds.y() + first_main + kDividerThicknessDip,
++                  bounds.width(), usable - first_main));
++  }
++}
++
++bool SlayzoneSplitView::OnKeyPressed(const ui::KeyEvent& event) {
++  if (!event.IsAltDown()) {
++    return false;
++  }
++  const bool is_horizontal = orientation_ == Orientation::kHorizontal;
++  const bool decrease = (is_horizontal && event.key_code() == ui::VKEY_LEFT) ||
++                        (!is_horizontal && event.key_code() == ui::VKEY_UP);
++  const bool increase =
++      (is_horizontal && event.key_code() == ui::VKEY_RIGHT) ||
++      (!is_horizontal && event.key_code() == ui::VKEY_DOWN);
++  if (!decrease && !increase) {
++    return false;
++  }
++  SetFraction(fraction_ + (decrease ? -kKeyboardStep : kKeyboardStep));
++  return true;
++}
++
++gfx::Size SlayzoneSplitView::CalculatePreferredSize(
++    const views::SizeBounds& available_size) const {
++  // Claim whatever we're given — the parent layout decides final bounds.
++  if (orientation_ == Orientation::kHorizontal) {
++    return gfx::Size(kDividerThicknessDip, 0);
++  }
++  return gfx::Size(0, kDividerThicknessDip);
++}
++
++void SlayzoneSplitView::OnResize(int resize_amount, bool done_resizing) {
++  const int main = MainAxisLength();
++  if (main <= kDividerThicknessDip) {
++    return;
++  }
++  if (!divider_->is_resizing() && !done_resizing) {
++    // Drag just starting — snapshot the current fraction.
++    fraction_at_drag_start_ = fraction_;
++  }
++  const double delta =
++      static_cast<double>(resize_amount) / (main - kDividerThicknessDip);
++  SetFraction(fraction_at_drag_start_ + delta);
++  if (done_resizing) {
++    ApplySnap();
++    InvalidateLayout();
++  }
++}
++
