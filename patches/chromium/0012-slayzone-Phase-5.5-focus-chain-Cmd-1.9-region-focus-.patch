+void SlayzoneBrowserView::RegisterRegionFocusAccelerators() {
+  // Cmd+1 … Cmd+9 focus region slots 0..8 from `kRegionIds` order.
+  // Cmd+0 is left alone — upstream binds it to "reset zoom".
+  for (int i = 0; i < 9; ++i) {
+    ui::Accelerator accel(static_cast<ui::KeyboardCode>(ui::VKEY_1 + i),
+                          ui::EF_COMMAND_DOWN);
+    AddAccelerator(accel);
+  }
+}
+
+bool SlayzoneBrowserView::AcceleratorPressed(
+    const ui::Accelerator& accelerator) {
+  if (accelerator.modifiers() == ui::EF_COMMAND_DOWN &&
+      accelerator.key_code() >= ui::VKEY_1 &&
+      accelerator.key_code() <= ui::VKEY_9 && region_container_) {
+    const int index = accelerator.key_code() - ui::VKEY_1;
+    if (index < static_cast<int>(SlayzoneRegionContainer::kRegionIds.size())) {
+      const std::string_view id =
+          SlayzoneRegionContainer::kRegionIds[index];
+      if (views::WebView* slot = region_container_->GetRegion(id)) {
+        slot->RequestFocus();
+        return true;
+      }
+    }
+  }
+  return BrowserView::AcceleratorPressed(accelerator);
+}
+
 void SlayzoneBrowserView::OnBoundsChanged(const gfx::Rect& previous_bounds) {
   BrowserView::OnBoundsChanged(previous_bounds);
   if (region_container_) {
