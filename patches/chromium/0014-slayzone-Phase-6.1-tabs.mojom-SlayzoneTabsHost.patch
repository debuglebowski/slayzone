diff --git a/chrome/browser/slayzone/mojom/tabs.mojom b/chrome/browser/slayzone/mojom/tabs.mojom
new file mode 100644
index 0000000000000..ad2aada804f14
--- /dev/null
+++ b/chrome/browser/slayzone/mojom/tabs.mojom
@@ -0,0 +1,32 @@
+// Phase 6.1 tabs API (C++ side). Mirrors
+// packages/shared/mojo-bindings/mojom/tabs.mojom — Phase 4.3 regenerates TS
+// bindings from the outer file; this tree-local copy is what Chromium's
+// mojom() target consumes. Keep in sync below the module line (diff is an
+// invariant).
+
+module slayzone.tabs.mojom;
+
+struct TabSnapshot {
+  int32 id;
+  string title;
+  string url;
+  bool is_loading;
+  bool can_go_back;
+  bool can_go_forward;
+};
+
+interface TabObserver {
+  OnTabList(array<TabSnapshot> tabs, int32 active_id);
+};
+
+interface TabsHost {
+  CreateTab(string url) => (int32 id);
+  CloseTab(int32 id);
+  SelectTab(int32 id);
+  LoadUrl(string url);
+  GoBack();
+  GoForward();
+  Reload();
+  Stop();
+  Subscribe(pending_remote<TabObserver> observer);
+};
diff --git a/chrome/browser/slayzone/slayzone_tabs_host.cc b/chrome/browser/slayzone/slayzone_tabs_host.cc
new file mode 100644
index 0000000000000..38e1238451df0
--- /dev/null
+++ b/chrome/browser/slayzone/slayzone_tabs_host.cc
@@ -0,0 +1,249 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/slayzone/slayzone_tabs_host.h"
+
+#include <string>
+#include <utility>
+#include <vector>
+
+#include "base/check.h"
+#include "base/strings/utf_string_conversions.h"
+#include "chrome/browser/ui/browser.h"
+#include "chrome/browser/ui/browser_tabstrip.h"
+#include "chrome/browser/ui/tabs/tab_strip_model.h"
+#include "chrome/common/webui_url_constants.h"
+#include "components/tabs/public/tab_interface.h"
+#include "components/url_formatter/url_fixer.h"
+#include "content/public/browser/navigation_controller.h"
+#include "content/public/browser/reload_type.h"
+#include "content/public/browser/web_contents.h"
+#include "ui/base/page_transition_types.h"
+#include "url/gurl.h"
+
+namespace {
+
+using TabHandle = tabs::SupportsTabHandles::Handle;
+
+slayzone::tabs::mojom::TabSnapshotPtr BuildSnapshot(
+    const tabs::TabInterface* tab) {
+  auto snapshot = slayzone::tabs::mojom::TabSnapshot::New();
+  snapshot->id = tab->GetHandle().raw_value();
+  content::WebContents* contents = tab->GetContents();
+  if (!contents) {
+    // Android may transiently hold tabs without contents. Desktop should not,
+    // but we return a minimal snapshot to avoid a mid-teardown crash.
+    snapshot->title = std::string();
+    snapshot->url = std::string();
+    snapshot->is_loading = false;
+    snapshot->can_go_back = false;
+    snapshot->can_go_forward = false;
+    return snapshot;
+  }
+  snapshot->title = base::UTF16ToUTF8(contents->GetTitle());
+  snapshot->url = contents->GetVisibleURL().spec();
+  snapshot->is_loading = contents->IsLoading();
+  content::NavigationController& controller = contents->GetController();
+  snapshot->can_go_back = controller.CanGoBack();
+  snapshot->can_go_forward = controller.CanGoForward();
+  return snapshot;
+}
+
+}  // namespace
+
+SlayzoneTabsHost::SlayzoneTabsHost(Browser* browser) : browser_(browser) {
+  CHECK(browser_);
+  // `base::ScopedObservation<TabStripModel, TabStripModelObserver>` is
+  // explicitly deleted upstream — TabStripModelObserver tracks its observed
+  // models natively and cleans up in its destructor. We just add + rely on
+  // the base destructor.
+  browser_->tab_strip_model()->AddObserver(this);
+}
+
+SlayzoneTabsHost::~SlayzoneTabsHost() = default;
+
+void SlayzoneTabsHost::Bind(
+    mojo::PendingReceiver<slayzone::tabs::mojom::TabsHost> receiver) {
+  receivers_.Add(this, std::move(receiver));
+}
+
+void SlayzoneTabsHost::CreateTab(const std::string& url,
+                                 CreateTabCallback callback) {
+  GURL gurl;
+  if (url.empty()) {
+    gurl = GURL(chrome::kChromeUINewTabURL);
+  } else {
+    gurl = url_formatter::FixupURL(url, std::string());
+  }
+  if (!gurl.is_valid()) {
+    std::move(callback).Run(TabHandle::NullValue);
+    return;
+  }
+  content::WebContents* contents = chrome::AddAndReturnTabAt(
+      browser_, gurl, /*index=*/-1, /*foreground=*/true);
+  if (!contents) {
+    std::move(callback).Run(TabHandle::NullValue);
+    return;
+  }
+  tabs::TabInterface* tab = tabs::TabInterface::MaybeGetFromContents(contents);
+  std::move(callback).Run(tab ? tab->GetHandle().raw_value()
+                              : TabHandle::NullValue);
+}
+
+void SlayzoneTabsHost::CloseTab(int32_t id) {
+  tabs::TabInterface* tab = TabFor(id);
+  if (!tab) {
+    return;
+  }
+  // Route through the tab's own Close() — it picks the right close-type and
+  // respects IsTabClosable.
+  tab->Close();
+}
+
+void SlayzoneTabsHost::SelectTab(int32_t id) {
+  tabs::TabInterface* tab = TabFor(id);
+  if (!tab) {
+    return;
+  }
+  TabStripModel* model = browser_->tab_strip_model();
+  const int index = model->GetIndexOfTab(tab);
+  if (index == TabStripModel::kNoTab) {
+    return;
+  }
+  model->ActivateTabAt(index);
+}
+
+void SlayzoneTabsHost::LoadUrl(const std::string& url) {
+  content::WebContents* active =
+      browser_->tab_strip_model()->GetActiveWebContents();
+  if (!active) {
+    return;
+  }
+  GURL gurl = url_formatter::FixupURL(url, std::string());
+  if (!gurl.is_valid()) {
+    return;
+  }
+  content::NavigationController::LoadURLParams params(gurl);
+  params.transition_type = ui::PAGE_TRANSITION_TYPED;
+  active->GetController().LoadURLWithParams(params);
+}
+
+void SlayzoneTabsHost::GoBack() {
+  content::WebContents* active =
+      browser_->tab_strip_model()->GetActiveWebContents();
+  if (active && active->GetController().CanGoBack()) {
+    active->GetController().GoBack();
+  }
+}
+
+void SlayzoneTabsHost::GoForward() {
+  content::WebContents* active =
+      browser_->tab_strip_model()->GetActiveWebContents();
+  if (active && active->GetController().CanGoForward()) {
+    active->GetController().GoForward();
+  }
+}
+
+void SlayzoneTabsHost::Reload() {
+  content::WebContents* active =
+      browser_->tab_strip_model()->GetActiveWebContents();
+  if (active) {
+    active->GetController().Reload(content::ReloadType::NORMAL,
+                                   /*check_for_repost=*/true);
+  }
+}
+
+void SlayzoneTabsHost::Stop() {
+  content::WebContents* active =
+      browser_->tab_strip_model()->GetActiveWebContents();
+  if (active) {
+    active->Stop();
+  }
+}
+
+void SlayzoneTabsHost::Subscribe(
+    mojo::PendingRemote<slayzone::tabs::mojom::TabObserver> observer) {
+  mojo::RemoteSetElementId id = observers_.Add(std::move(observer));
+  // Seed the new observer with the current snapshot so the UI renders
+  // immediately instead of waiting for the next tab event.
+  auto* remote = observers_.Get(id);
+  if (!remote) {
+    return;
+  }
+  TabStripModel* model = browser_->tab_strip_model();
+  std::vector<slayzone::tabs::mojom::TabSnapshotPtr> tabs;
+  tabs.reserve(model->count());
+  int32_t active_id = TabHandle::NullValue;
+  for (int i = 0; i < model->count(); ++i) {
+    tabs::TabInterface* tab = model->GetTabAtIndex(i);
+    if (!tab) {
+      continue;
+    }
+    auto snapshot = BuildSnapshot(tab);
+    if (i == model->active_index()) {
+      active_id = snapshot->id;
+    }
+    tabs.push_back(std::move(snapshot));
+  }
+  remote->OnTabList(std::move(tabs), active_id);
+}
+
+void SlayzoneTabsHost::OnTabStripModelChanged(
+    TabStripModel* tab_strip_model,
+    const TabStripModelChange& change,
+    const TabStripSelectionChange& selection) {
+  BroadcastSnapshots();
+}
+
+void SlayzoneTabsHost::OnTabChangedAt(tabs::TabInterface* tab,
+                                     int index,
+                                     TabChangeType change_type) {
+  BroadcastSnapshots();
+}
+
+tabs::TabInterface* SlayzoneTabsHost::TabFor(int32_t id) const {
+  if (id == TabHandle::NullValue) {
+    return nullptr;
+  }
+  tabs::TabInterface* tab = TabHandle(id).Get();
+  if (!tab) {
+    return nullptr;
+  }
+  // Reject cross-window handles: if the tab isn't in our own TabStripModel,
+  // don't touch it — another Browser owns it.
+  if (browser_->tab_strip_model()->GetIndexOfTab(tab) ==
+      TabStripModel::kNoTab) {
+    return nullptr;
+  }
+  return tab;
+}
+
+void SlayzoneTabsHost::BroadcastSnapshots() {
+  if (observers_.empty()) {
+    return;
+  }
+  TabStripModel* model = browser_->tab_strip_model();
+  std::vector<slayzone::tabs::mojom::TabSnapshotPtr> tabs;
+  tabs.reserve(model->count());
+  int32_t active_id = TabHandle::NullValue;
+  for (int i = 0; i < model->count(); ++i) {
+    tabs::TabInterface* tab = model->GetTabAtIndex(i);
+    if (!tab) {
+      continue;
+    }
+    auto snapshot = BuildSnapshot(tab);
+    if (i == model->active_index()) {
+      active_id = snapshot->id;
+    }
+    tabs.push_back(std::move(snapshot));
+  }
+  for (auto& observer : observers_) {
+    std::vector<slayzone::tabs::mojom::TabSnapshotPtr> cloned;
+    cloned.reserve(tabs.size());
+    for (const auto& snap : tabs) {
+      cloned.push_back(snap->Clone());
+    }
+    observer->OnTabList(std::move(cloned), active_id);
+  }
+}
