+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_SLAYZONE_SLAYZONE_TABS_HOST_H_
+#define CHROME_BROWSER_SLAYZONE_SLAYZONE_TABS_HOST_H_
+
+#include <cstdint>
+#include <string>
+
+#include "base/memory/raw_ptr.h"
+#include "chrome/browser/slayzone/mojom/tabs.mojom.h"
+#include "chrome/browser/ui/tabs/tab_change_type.h"
+#include "chrome/browser/ui/tabs/tab_strip_model_observer.h"
+#include "mojo/public/cpp/bindings/pending_receiver.h"
+#include "mojo/public/cpp/bindings/pending_remote.h"
+#include "mojo/public/cpp/bindings/receiver_set.h"
+#include "mojo/public/cpp/bindings/remote_set.h"
+
+class Browser;
+
+namespace tabs {
+class TabInterface;
+}  // namespace tabs
+
+// Phase 6.1 — browser-side implementation of
+// `slayzone::tabs::mojom::TabsHost`. One instance per `SlayzoneBrowserView`,
+// mediating every tab-level action (create/close/select + navigate-active)
+// between region WebUIs and the owning Browser's TabStripModel.
+//
+// Observers are pushed the full TabSnapshot list on every change — cheap for
+// the <50-tab working set and lets regions render purely from the latest
+// payload. Stable tab identity comes from `tabs::TabHandle::raw_value()`,
+// which survives WebContents discard/swap.
+//
+// Binder registration from chrome://slayzone-tabbar/ +
+// chrome://slayzone-browserchrome/ to the per-BrowserView host lands in
+// Phase 6.3 alongside the JS clients; 6.1 only builds the impl.
+class SlayzoneTabsHost : public slayzone::tabs::mojom::TabsHost,
+                         public TabStripModelObserver {
+ public:
+  explicit SlayzoneTabsHost(Browser* browser);
+  SlayzoneTabsHost(const SlayzoneTabsHost&) = delete;
+  SlayzoneTabsHost& operator=(const SlayzoneTabsHost&) = delete;
+  ~SlayzoneTabsHost() override;
+
+  void Bind(
+      mojo::PendingReceiver<slayzone::tabs::mojom::TabsHost> receiver);
+
+  // slayzone::tabs::mojom::TabsHost:
+  void CreateTab(const std::string& url, CreateTabCallback callback) override;
+  void CloseTab(int32_t id) override;
+  void SelectTab(int32_t id) override;
+  void LoadUrl(const std::string& url) override;
+  void GoBack() override;
+  void GoForward() override;
+  void Reload() override;
+  void Stop() override;
+  void Subscribe(mojo::PendingRemote<slayzone::tabs::mojom::TabObserver>
+                     observer) override;
+
+  // TabStripModelObserver:
+  void OnTabStripModelChanged(
+      TabStripModel* tab_strip_model,
+      const TabStripModelChange& change,
+      const TabStripSelectionChange& selection) override;
+  void OnTabChangedAt(tabs::TabInterface* tab,
+                      int index,
+                      TabChangeType change_type) override;
+
+ private:
+  // Look up the TabInterface for a handle `id`, or nullptr if unknown or if
+  // the tab has been destroyed. Also returns nullptr if the tab is not in
+  // this host's Browser (cross-window handles are rejected defensively).
+  tabs::TabInterface* TabFor(int32_t id) const;
+
+  // Push the current TabStripModel snapshot to every subscribed observer.
+  void BroadcastSnapshots();
+
+  const raw_ptr<Browser> browser_;
+  mojo::ReceiverSet<slayzone::tabs::mojom::TabsHost> receivers_;
+  mojo::RemoteSet<slayzone::tabs::mojom::TabObserver> observers_;
+};
+
+#endif  // CHROME_BROWSER_SLAYZONE_SLAYZONE_TABS_HOST_H_
