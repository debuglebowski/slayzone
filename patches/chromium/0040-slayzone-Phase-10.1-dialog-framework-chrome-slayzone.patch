@@ -0,0 +1,51 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_SLAYZONE_SLAYZONE_DIALOGS_HOST_H_
+#define CHROME_BROWSER_SLAYZONE_SLAYZONE_DIALOGS_HOST_H_
+
+#include <string>
+
+#include "chrome/browser/slayzone/mojom/dialog.mojom.h"
+#include "mojo/public/cpp/bindings/pending_receiver.h"
+#include "mojo/public/cpp/bindings/receiver_set.h"
+
+namespace slayzone {
+
+// Phase 10.1 — browser-side implementation of
+// `slayzone::dialog::mojom::DialogHost`. Lifetime owned by
+// `SlayzoneDialogsUI` (one per WebContents).
+//
+// Dialog JS reports the user's choice here; this class forwards to the
+// sidecar via JSON-RPC (`dialog:resolve` / `dialog:cancel`). The invoker
+// on the C++/native side registered the invocation with the sidecar before
+// opening the WebUI URL and is awaiting the matching completion.
+//
+// Invoker-side wiring (views::Widget modal + focus trap) is deferred to
+// Phase 10.6; the invocation registration channel is a standalone
+// JSON-RPC method on the sidecar and does not require the widget layer.
+class SlayzoneDialogsHost : public slayzone::dialog::mojom::DialogHost {
+ public:
+  SlayzoneDialogsHost();
+  SlayzoneDialogsHost(const SlayzoneDialogsHost&) = delete;
+  SlayzoneDialogsHost& operator=(const SlayzoneDialogsHost&) = delete;
+  ~SlayzoneDialogsHost() override;
+
+  void Bind(
+      mojo::PendingReceiver<slayzone::dialog::mojom::DialogHost> receiver);
+
+  // slayzone::dialog::mojom::DialogHost:
+  void Resolve(const std::string& invocation_id,
+               const std::string& result_json,
+               ResolveCallback callback) override;
+  void Cancel(const std::string& invocation_id,
+              CancelCallback callback) override;
+
+ private:
+  mojo::ReceiverSet<slayzone::dialog::mojom::DialogHost> receivers_;
+};
+
+}  // namespace slayzone
+
+#endif  // CHROME_BROWSER_SLAYZONE_SLAYZONE_DIALOGS_HOST_H_
