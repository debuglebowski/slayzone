+constexpr std::string_view kDialogsMissingBundleHtml =
+    R"HTML(<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <title>SlayZone · dialog</title>
+  <style>
+    :root { color-scheme: light dark; }
+    html, body { margin: 0; height: 100%; font: 11px/1.3 system-ui, sans-serif; }
+    body {
+      display: flex; align-items: center; justify-content: center;
+      background: #1a1a2e; color: #c7d2fe;
+      border: 1px solid #3a3a5e;
+    }
+  </style>
+</head>
+<body>
+  <span>dialog: bundle missing — pass --slayzone-webui-bundle-dir=&lt;repo&gt;/packages/webui</span>
+</body>
+</html>)HTML";
+
+}  // namespace
+
+SlayzoneDialogsUI::SlayzoneDialogsUI(content::WebUI* web_ui)
+    : content::WebUIController(web_ui),
+      host_(std::make_unique<slayzone::SlayzoneDialogsHost>()) {
+  auto* source = content::WebUIDataSource::CreateAndAdd(
+      Profile::FromWebUI(web_ui), chrome::kChromeUISlayzoneDialogsHost);
+  slayzone::ConfigureBundleSource(source, "dialogs", kDialogsMissingBundleHtml);
+}
+
+SlayzoneDialogsUI::~SlayzoneDialogsUI() = default;
+
+WEB_UI_CONTROLLER_TYPE_IMPL(SlayzoneDialogsUI)
+
+void SlayzoneDialogsUI::BindInterface(
+    mojo::PendingReceiver<slayzone::dialog::mojom::DialogHost> receiver) {
+  host_->Bind(std::move(receiver));
+}
