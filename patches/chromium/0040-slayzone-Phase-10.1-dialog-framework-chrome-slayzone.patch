diff --git a/chrome/browser/slayzone/slayzone_dialogs_host.cc b/chrome/browser/slayzone/slayzone_dialogs_host.cc
new file mode 100644
index 0000000000000..198b77dc07eb5
--- /dev/null
+++ b/chrome/browser/slayzone/slayzone_dialogs_host.cc
@@ -0,0 +1,73 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/slayzone/slayzone_dialogs_host.h"
+
+#include <string>
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "base/json/json_reader.h"
+#include "base/values.h"
+#include "chrome/browser/slayzone/sidecar_client.h"
+
+namespace slayzone {
+
+namespace {
+
+// Parse an opaque result payload into a base::Value that the sidecar can
+// forward through the JSON-RPC pipeline. Non-JSON payloads are forwarded
+// as strings (the sidecar will hand them to the invoker unchanged); the
+// invocation contract is opaque to C++ and agreed by invoker + JS.
+base::Value ParseResultPayload(const std::string& result_json) {
+  if (result_json.empty()) {
+    return base::Value();
+  }
+  std::optional<base::Value> parsed =
+      base::JSONReader::Read(result_json, base::JSON_PARSE_RFC);
+  if (parsed.has_value()) {
+    return std::move(parsed).value();
+  }
+  return base::Value(result_json);
+}
+
+}  // namespace
+
+SlayzoneDialogsHost::SlayzoneDialogsHost() = default;
+SlayzoneDialogsHost::~SlayzoneDialogsHost() = default;
+
+void SlayzoneDialogsHost::Bind(
+    mojo::PendingReceiver<dialog::mojom::DialogHost> receiver) {
+  receivers_.Add(this, std::move(receiver));
+}
+
+void SlayzoneDialogsHost::Resolve(const std::string& invocation_id,
+                                  const std::string& result_json,
+                                  ResolveCallback callback) {
+  base::ListValue params;
+  params.Append(invocation_id);
+  params.Append(ParseResultPayload(result_json));
+  base::DictValue request;
+  request.Set("params", std::move(params));
+  SidecarClient::GetInstance()->Call(
+      "dialog:resolve", std::move(request),
+      base::BindOnce(
+          [](ResolveCallback cb, base::DictValue) { std::move(cb).Run(); },
+          std::move(callback)));
+}
+
+void SlayzoneDialogsHost::Cancel(const std::string& invocation_id,
+                                 CancelCallback callback) {
+  base::ListValue params;
+  params.Append(invocation_id);
+  base::DictValue request;
+  request.Set("params", std::move(params));
+  SidecarClient::GetInstance()->Call(
+      "dialog:cancel", std::move(request),
+      base::BindOnce(
+          [](CancelCallback cb, base::DictValue) { std::move(cb).Run(); },
+          std::move(callback)));
+}
+
+}  // namespace slayzone
