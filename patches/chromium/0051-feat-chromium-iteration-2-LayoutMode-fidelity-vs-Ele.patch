+void SlayzoneRegionContainer::SetLayoutMode(LayoutMode mode) {
+  if (layout_mode_ == mode) {
+    return;
+  }
+  layout_mode_ = mode;
+
+  auto set_region_visible = [this](std::string_view id, bool visible) {
+    if (views::WebView* wv = GetRegion(id)) {
+      wv->SetVisible(visible);
+    }
+  };
+
+  // Regions hidden outside task-detail mode. Order matches
+  // Electron's home layout survey in docs/chromium/layout-modes.md.
+  constexpr std::array<std::string_view, 4> kTaskOnlyRegions = {
+      "sidebar", "taskheader", "browserchrome", "terminal",
+  };
+
+  switch (mode) {
+    case LayoutMode::kTaskDetail:
+    case LayoutMode::kOverlay:
+      // kOverlay leaves the grid intact — SlayzoneOverlayManager paints a
+      // full-bleed WebView above it, and closing the overlay restores the
+      // prior mode without a relayout round-trip. kTaskDetail unhides
+      // everything the kHome branch may have hidden.
+      for (std::string_view id : kTaskOnlyRegions) {
+        set_region_visible(id, true);
+      }
+      if (inline_tab_webview_) {
+        inline_tab_webview_->SetVisible(true);
+      }
+      if (mid_right_pane_) {
+        mid_right_pane_->SetVisible(true);
+      }
+      if (mid_split_) {
+        mid_split_->SetFraction(0.5);
+      }
+      break;
+    case LayoutMode::kHome:
+      // Electron home-tab layout: projects rail + tabbar + tasklist (kanban)
+      // full-bleed + tools rail + statusbar. No per-task chrome.
+      for (std::string_view id : kTaskOnlyRegions) {
+        set_region_visible(id, false);
+      }
+      if (inline_tab_webview_) {
+        inline_tab_webview_->SetVisible(false);
+      }
+      if (mid_right_pane_) {
+        mid_right_pane_->SetVisible(false);
+      }
+      if (mid_split_) {
+        // Tasklist owns the full main-axis length; divider collapses to the
+        // edge, right pane is hidden anyway.
+        mid_split_->SetFraction(1.0);
+      }
+      break;
+  }
+  InvalidateLayout();
+}
