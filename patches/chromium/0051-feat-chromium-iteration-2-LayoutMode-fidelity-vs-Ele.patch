   SyncInlineTabWebView();
 
   // Phase 8.5 — honor `--slayzone-home-panel=<id>` for dev smoke. Invalid
-  // ids are silently ignored; the grid stays up. Used by the verify
-  // harness + docs/chromium/phase-8-smoke.md.
+  // ids are silently ignored; the grid stays up.
   const base::CommandLine* cli = base::CommandLine::ForCurrentProcess();
   if (cli->HasSwitch(kSlayzoneHomePanelSwitch)) {
     SetHomePanel(cli->GetSwitchValueASCII(kSlayzoneHomePanelSwitch));
   }
+  // Iteration-2 — honor `--slayzone-layout-mode=home|task-detail|overlay`
+  // for the layout-fidelity validation harness. Falls through silently on
+  // unknown values so a typo doesn't brick the region grid.
+  if (cli->HasSwitch(kSlayzoneLayoutModeSwitch)) {
+    const std::string value = cli->GetSwitchValueASCII(kSlayzoneLayoutModeSwitch);
+    if (value == "home") {
+      SetLayoutMode(LayoutMode::kHome);
+    } else if (value == "overlay") {
+      SetLayoutMode(LayoutMode::kOverlay);
+    } else if (value == "task-detail" || value.empty()) {
+      SetLayoutMode(LayoutMode::kTaskDetail);
+    }
+  }
+}
+
+void SlayzoneBrowserView::SetLayoutMode(LayoutMode mode) {
+  const auto region_mode =
+      static_cast<SlayzoneRegionContainer::LayoutMode>(mode);
+  if (layout_mode_ == mode && region_container_ &&
+      region_container_->layout_mode() == region_mode) {
+    return;
+  }
+  layout_mode_ = mode;
+  if (region_container_) {
+    region_container_->SetLayoutMode(region_mode);
+  }
+  // kHome suppresses the inline tab (browser WebContents surface) since the
+  // kanban WebUI owns the main area. kTaskDetail + kOverlay resume sync.
+  if (mode == LayoutMode::kTaskDetail || mode == LayoutMode::kOverlay) {
+    SyncInlineTabWebView();
+  }
 }
 
