+void SlayzoneLayoutHost::SetLayoutMode(
+    slayzone::layout::mojom::LayoutMode mode,
+    SetLayoutModeCallback callback) {
+  if (view_) {
+    using MojoMode = slayzone::layout::mojom::LayoutMode;
+    SlayzoneBrowserView::LayoutMode target =
+        SlayzoneBrowserView::LayoutMode::kTaskDetail;
+    switch (mode) {
+      case MojoMode::kTaskDetail:
+        target = SlayzoneBrowserView::LayoutMode::kTaskDetail;
+        break;
+      case MojoMode::kHome:
+        target = SlayzoneBrowserView::LayoutMode::kHome;
