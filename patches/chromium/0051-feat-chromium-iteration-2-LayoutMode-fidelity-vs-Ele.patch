 constexpr char kSlayzoneHomePanelSwitch[] = "slayzone-home-panel";
 
+// Iteration-2 — dev smoke switch for layout-mode fidelity validation.
+// Accepted values: "task-detail" (default, same as absent), "home",
+// "overlay". Applied in AddedToWidget after the region grid is up. Used
+// by scripts/chromium/compare-with-electron.sh to boot the binary in a
+// specific mode per screenshot.
+constexpr char kSlayzoneLayoutModeSwitch[] = "slayzone-layout-mode";
+
 // Back-pointer attached to every region WebView's WebContents so Phase 6.3's
 // Mojo binders can route TabsHost receivers to the owning SlayzoneBrowserView
 // from just the WebContents.
