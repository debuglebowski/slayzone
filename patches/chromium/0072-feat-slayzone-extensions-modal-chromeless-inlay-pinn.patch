+#ifndef CHROME_BROWSER_UI_VIEWS_FRAME_SLAYZONE_INLAY_BROWSER_VIEW_H_
+#define CHROME_BROWSER_UI_VIEWS_FRAME_SLAYZONE_INLAY_BROWSER_VIEW_H_
+
+#include "chrome/browser/ui/views/frame/browser_view.h"
+
+class Browser;
+
+// BrowserView for the single VISIBLE extension-management window
+// (`slayzone::IsExtensionsBrowser`). It hosts the Web Store / chrome://extensions
+// as a normal ACTIVE tab — so install confirm dialogs, the post-install bubble,
+// and 1Password autofill all work exactly as in stock Chrome — but renders with
+// NO browser chrome (no tabstrip, toolbar, bookmark bar). Paired with the
+// frameless+rounded+child-window config in `BrowserNativeWidgetMac` (gated on the
+// same `IsExtensionsBrowser` marker), the window becomes a chromeless, borderless,
+// rounded rectangle parented to the SlayZone shell — the "body" of a real React
+// SlayZone modal whose scrim/card/header/close are drawn by the shell above it.
+//
+// Chrome is suppressed two ways (belt + suspenders): the `IsToolbarVisible` /
+// `IsBookmarkBarVisible` overrides keep the layout from reserving space, and the
+// `Layout` override forcibly collapses `top_container()` and gives
+// `contents_container()` the entire window — robust regardless of the upstream
+// `BrowserViewTabbedLayoutImpl` (whose tabstrip presence is not a clean override
+// point). The active tab's WebContents renders normally (the window IS visible),
+// so none of the windowless-pane traps (capturer pinning, RWHV ownership) apply.
+class SlayzoneInlayBrowserView : public BrowserView {
+ public:
+  explicit SlayzoneInlayBrowserView(Browser* browser);
+  SlayzoneInlayBrowserView(const SlayzoneInlayBrowserView&) = delete;
+  SlayzoneInlayBrowserView& operator=(const SlayzoneInlayBrowserView&) = delete;
+  ~SlayzoneInlayBrowserView() override;
+
+  // BrowserWindow (via BrowserView) — report all chrome hidden so the layout
+  // delegate reserves no space for it.
+  bool IsToolbarVisible() const override;
+  bool IsBookmarkBarVisible() const override;
+
+  // views::View — after upstream layout, collapse the chrome strip and give the
+  // web contents the full window. This is the authoritative chromeless guarantee.
+  void Layout(PassKey key) override;
+};
+
+#endif  // CHROME_BROWSER_UI_VIEWS_FRAME_SLAYZONE_INLAY_BROWSER_VIEW_H_
