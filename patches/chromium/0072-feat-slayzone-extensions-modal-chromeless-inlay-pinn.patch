+SlayzoneInlayBrowserView::SlayzoneInlayBrowserView(Browser* browser)
+    : BrowserView(browser) {}
+
+SlayzoneInlayBrowserView::~SlayzoneInlayBrowserView() = default;
+
+bool SlayzoneInlayBrowserView::IsToolbarVisible() const {
