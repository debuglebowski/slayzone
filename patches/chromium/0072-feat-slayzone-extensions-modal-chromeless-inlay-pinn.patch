+
+void SlayzoneInlayBrowserView::Layout(PassKey /*key*/) {
+  // PassKey is non-copyable; forward to the superclass via the views helper
+  // (constructs its own key), then adjust.
+  LayoutSuperclass<BrowserView>(this);
+
+  // The React modal (in the shell) draws the frame; this window is only the
+  // web "body". Hide the whole chrome strip and give the contents the entire
+  // client area, regardless of what BrowserViewTabbedLayoutImpl computed
+  // (tabstrip presence is not a clean per-browser override point).
+  //
+  // The tab strip region is a DIRECT child of BrowserView (added last so it
+  // "paints on top of everything"), a SIBLING of top_container — NOT inside it.
+  // So hiding top_container alone leaves the tab strip's "+" new-tab button
+  // floating over the page; it must be hidden on its own.
+  if (views::View* tabs = tab_strip_view()) {
+    tabs->SetVisible(false);
+  }
+  // SetVisible(false) — NOT just zero bounds: views don't clip children to
+  // their parent's bounds, so a zero-sized top_container still PAINTS its
+  // children (toolbar / bookmark bar). Hiding it stops its descendants painting.
+  if (views::View* top = top_container()) {
+    top->SetVisible(false);
+    top->SetBoundsRect(gfx::Rect());
+  }
+  if (views::View* contents = contents_container()) {
+    contents->SetBoundsRect(GetLocalBounds());
+  }
+}
