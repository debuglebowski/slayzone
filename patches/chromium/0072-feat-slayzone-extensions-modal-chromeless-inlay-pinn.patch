+gfx::Rect SlayzoneEmbeddedTabHost::BodyToScreen(const gfx::Rect& body) const {
+  // `body` is CSS px relative to the shell's web viewport; the container fills
+  // that viewport, so its screen origin maps CSS (0,0). CSS px ↔ DIP 1:1 — the
+  // same convention the embedded-tab slot bounds use.
+  if (!container_) {
+    return body;
+  }
+  const gfx::Point origin = container_->GetBoundsInScreen().origin();
+  return gfx::Rect(origin.x() + body.x(), origin.y() + body.y(), body.width(),
+                   body.height());
+}
+
+void SlayzoneEmbeddedTabHost::PositionExtensionsInlay(const gfx::Rect& body) {
+  if (!extensions_browser_) {
+    return;
+  }
+  if (BrowserView* bv =
+          BrowserView::GetBrowserViewForBrowser(extensions_browser_)) {
+    if (views::Widget* w = bv->GetWidget()) {
+      w->SetBounds(BodyToScreen(body));
+    }
+  }
+}
+
+void SlayzoneEmbeddedTabHost::SetExtensionsBounds(
+    slayzone::embedded_tab::mojom::EmbeddedTabBoundsPtr bounds) {
+  // Renderer reports the modal body rect on move/resize — keep the chromeless
+  // child window pinned under the React card.
+  PositionExtensionsInlay(ToRect(bounds));
+}
+
+void SlayzoneEmbeddedTabHost::CloseExtensions() {
+  if (extensions_browser_) {
+    extensions_browser_->window()->Close();  // OnBrowserRemoved clears the ptr
+  }
+}
