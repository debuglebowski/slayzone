+void SlayzoneEmbeddedTabHost::ListExtensions(const std::string& profile_key,
+                                             ListExtensionsCallback callback) {
+  ResolveProfile(
+      profile_key,
+      base::BindOnce(&SlayzoneEmbeddedTabHost::ListExtensionsOnProfile,
+                     weak_factory_.GetWeakPtr(), std::move(callback)));
+}
+
+void SlayzoneEmbeddedTabHost::ListExtensionsOnProfile(
+    ListExtensionsCallback callback,
+    Profile* profile) {
+  std::vector<slayzone::embedded_tab::mojom::ExtensionInfoPtr> out;
+  if (profile) {
+    extensions::ExtensionActionManager* action_manager =
+        extensions::ExtensionActionManager::Get(profile);
+    if (extensions::ExtensionRegistry* registry =
+            extensions::ExtensionRegistry::Get(profile)) {
+      for (const auto& ext : registry->enabled_extensions()) {
+        // User-facing extensions only — skip component/built-in + themes/apps.
+        if (extensions::Manifest::IsComponentLocation(ext->location()) ||
+            !ext->is_extension()) {
+          continue;
+        }
+        extensions::ExtensionAction* action =
+            action_manager ? action_manager->GetExtensionAction(*ext) : nullptr;
+        auto info = slayzone::embedded_tab::mojom::ExtensionInfo::New();
+        info->id = ext->id();
+        info->name = ext->name();
+        info->enabled = true;  // enabled_extensions() only
+        info->has_options =
+            extensions::OptionsPageInfo::HasOptionsPage(ext.get());
+        info->has_popup =
+            action &&
+            action->HasPopup(extensions::ExtensionAction::kDefaultTabId);
+        out.push_back(std::move(info));
+      }
+    }
+  }
+  std::move(callback).Run(std::move(out));
+}
+
+void SlayzoneEmbeddedTabHost::OpenExtensionOptions(
+    const std::string& extension_id) {
+  if (!extensions_browser_) {
+    return;  // the modal (inlay) isn't open
+  }
+  extensions::ExtensionRegistry* registry =
+      extensions::ExtensionRegistry::Get(extensions_browser_->profile());
+  if (!registry) {
+    return;
+  }
+  const extensions::Extension* ext =
+      registry->enabled_extensions().GetByID(extension_id);
+  if (!ext || !extensions::OptionsPageInfo::HasOptionsPage(ext)) {
+    return;
+  }
+  // Canonical options-page open (handles open-in-tab vs embedded
+  // chrome://extensions?options=… correctly). Lands as the inlay's active tab.
+  extensions::ExtensionTabUtil::OpenOptionsPage(ext, extensions_browser_);
+}
+
+void SlayzoneEmbeddedTabHost::OpenExtensionPopup(
+    const std::string& extension_id) {
+  if (!extensions_browser_) {
+    return;  // the modal (inlay) isn't open
+  }
+  Profile* profile = extensions_browser_->profile();
+  extensions::ExtensionRegistry* registry =
+      extensions::ExtensionRegistry::Get(profile);
+  if (!registry) {
+    return;
+  }
+  const extensions::Extension* ext =
+      registry->enabled_extensions().GetByID(extension_id);
+  if (!ext) {
+    return;
+  }
+  extensions::ExtensionAction* action =
+      extensions::ExtensionActionManager::Get(profile)->GetExtensionAction(
+          *ext);
+  if (!action ||
+      !action->HasPopup(extensions::ExtensionAction::kDefaultTabId)) {
+    return;
+  }
+  const GURL popup_url =
+      action->GetPopupUrl(extensions::ExtensionAction::kDefaultTabId);
+  if (!popup_url.is_valid()) {
+    return;
+  }
+  // The action popup (e.g. the 1Password vault) is just an extension page —
+  // load it as the inlay's active tab. Not a true anchored bubble, but it
+  // surfaces the extension's UI (and its in-app settings) in the modal body.
+  if (content::WebContents* wc =
+          extensions_browser_->tab_strip_model()->GetActiveWebContents()) {
+    wc->GetController().LoadURL(popup_url, content::Referrer(),
+                               ui::PAGE_TRANSITION_TYPED, std::string());
+  }
+}
+
 void SlayzoneEmbeddedTabHost::ResolveProfile(
     const std::string& profile_key,
     base::OnceCallback<void(Profile*)> cb) {
