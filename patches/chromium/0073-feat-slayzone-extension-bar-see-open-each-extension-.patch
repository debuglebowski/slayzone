+
+  // SlayZone extension bar. List the installed extensions for the modal's
+  // identity (profile_key; empty = default), and open a given extension's
+  // options/settings page in the currently-open inlay.
+  ListExtensions(string profile_key) => (array<ExtensionInfo> extensions);
+  OpenExtensionOptions(string extension_id);
+  // Open an extension's action popup (e.g. the 1Password vault) in the inlay.
+  OpenExtensionPopup(string extension_id);
 };
 
