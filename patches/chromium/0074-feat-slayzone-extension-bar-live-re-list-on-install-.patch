   Entry* FindEntry(const std::string& view_id);
 
   // Push `view_id` to the MRU end (back of lru_).
@@ -214,6 +232,12 @@ class SlayzoneEmbeddedTabHost
   // windowless Browsers exist.
   std::vector<std::unique_ptr<ScopedProfileKeepAlive>> pool_keepalives_;
 
+  // Observes the ExtensionRegistry of every profile the bar has listed, so
