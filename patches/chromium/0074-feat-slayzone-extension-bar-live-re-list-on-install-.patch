+      public extensions::ExtensionRegistryObserver {
  public:
   // `browser_context` must outlive this object. `container` may be null (e.g.
   // shell mounted with no active browser view) — every public method becomes
@@ -129,6 +133,17 @@ class SlayzoneEmbeddedTabHost
   // closed). Drop it from task_browsers_.
   void OnBrowserRemoved(Browser* browser) override;
 
+  // extensions::ExtensionRegistryObserver — the observed identity's enabled
+  // extension set changed (install / uninstall / enable / disable). Nudge the
+  // renderer to re-list the extension bar live.
+  void OnExtensionLoaded(content::BrowserContext* browser_context,
+                         const extensions::Extension* extension) override;
+  void OnExtensionUnloaded(
+      content::BrowserContext* browser_context,
+      const extensions::Extension* extension,
+      extensions::UnloadedExtensionReason reason) override;
