Subject: =?UTF-8?q?feat(slayzone):=20extension=20bar=20=E2=80=94=20live=20?=
 =?UTF-8?q?re-list=20on=20install/uninstall?=
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

The bar listed extensions once on open, so a freshly-installed extension didn't
appear until the modal was reopened. Observe the listed identity's
ExtensionRegistry and push a change event so the rail re-lists live.

- mojom: EmbeddedTabObserver gains OnExtensionsChanged() (no payload — the
  renderer re-lists for its current identity).
- Host implements extensions::ExtensionRegistryObserver via a
  ScopedMultiSourceObservation; ListExtensions starts observing that profile's
  registry (idempotent); OnExtensionLoaded / OnExtensionUnloaded → fire
  OnExtensionsChanged; OnShutdown drops the observation.
---
 .../browser/slayzone/mojom/embedded_tab.mojom |  5 +++
 .../slayzone/slayzone_embedded_tab_host.cc    | 31 +++++++++++++++++++
 .../slayzone/slayzone_embedded_tab_host.h     | 26 +++++++++++++++-
 3 files changed, 61 insertions(+), 1 deletion(-)

diff --git a/chrome/browser/slayzone/mojom/embedded_tab.mojom b/chrome/browser/slayzone/mojom/embedded_tab.mojom
index 234991c80a791..b12c0529a6aaa 100644
--- a/chrome/browser/slayzone/mojom/embedded_tab.mojom
+++ b/chrome/browser/slayzone/mojom/embedded_tab.mojom
@@ -125,4 +125,9 @@ interface EmbeddedTabObserver {
                 int32 error_code,
                 string error_description,
                 string url);
+
+  // The installed-extension set changed for a profile the host is observing
+  // (install / uninstall / enable / disable) — the extension bar should
+  // re-list. No payload: the renderer re-lists for its current identity.
+  OnExtensionsChanged();
 };
diff --git a/chrome/browser/slayzone/slayzone_embedded_tab_host.cc b/chrome/browser/slayzone/slayzone_embedded_tab_host.cc
index 31ab6fccd89e2..546c7327dab92 100644
--- a/chrome/browser/slayzone/slayzone_embedded_tab_host.cc
+++ b/chrome/browser/slayzone/slayzone_embedded_tab_host.cc
@@ -398,6 +398,11 @@ void SlayzoneEmbeddedTabHost::ListExtensionsOnProfile(
         extensions::ExtensionActionManager::Get(profile);
     if (extensions::ExtensionRegistry* registry =
             extensions::ExtensionRegistry::Get(profile)) {
+      // Observe this identity's registry so installs/uninstalls push a live
+      // re-list to the bar (idempotent — only adds once per registry).
+      if (!registry_observations_.IsObservingSource(registry)) {
+        registry_observations_.AddObservation(registry);
+      }
       for (const auto& ext : registry->enabled_extensions()) {
         // User-facing extensions only — skip component/built-in + themes/apps.
         if (extensions::Manifest::IsComponentLocation(ext->location()) ||
@@ -480,6 +485,32 @@ void SlayzoneEmbeddedTabHost::OpenExtensionPopup(
   }
 }
 
+void SlayzoneEmbeddedTabHost::OnExtensionLoaded(
+    content::BrowserContext* /*browser_context*/,
+    const extensions::Extension* /*extension*/) {
+  NotifyExtensionsChanged();
+}
+
+void SlayzoneEmbeddedTabHost::OnExtensionUnloaded(
+    content::BrowserContext* /*browser_context*/,
+    const extensions::Extension* /*extension*/,
+    extensions::UnloadedExtensionReason /*reason*/) {
+  NotifyExtensionsChanged();
+}
+
+void SlayzoneEmbeddedTabHost::OnShutdown(
+    extensions::ExtensionRegistry* registry) {
+  if (registry_observations_.IsObservingSource(registry)) {
+    registry_observations_.RemoveObservation(registry);
+  }
+}
+
+void SlayzoneEmbeddedTabHost::NotifyExtensionsChanged() {
+  if (observer_) {
+    observer_->OnExtensionsChanged();
+  }
+}
+
 void SlayzoneEmbeddedTabHost::ResolveProfile(
     const std::string& profile_key,
     base::OnceCallback<void(Profile*)> cb) {
