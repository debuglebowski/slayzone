+  if (content::WebContents* wc =
+          extensions_browser_->tab_strip_model()->GetActiveWebContents()) {
+    nag_hider_ = std::make_unique<NagHider>(wc);
+  }
+
   if (BrowserView* bv =
           BrowserView::GetBrowserViewForBrowser(extensions_browser_)) {
     if (views::Widget* w = bv->GetWidget()) {
@@ -917,6 +998,7 @@ void SlayzoneEmbeddedTabHost::RefreshActivePresentation(
