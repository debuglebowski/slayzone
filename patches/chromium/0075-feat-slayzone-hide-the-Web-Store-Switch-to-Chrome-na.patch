+// Injected into the Web Store tab to hide Google's "Switch to Chrome?" promo —
+// a cosmetic nag served only to non-Chrome browsers (gated by Google's
+// proprietary X-Client-Data signal, which a Chromium fork can't legitimately
+// satisfy). Matches by the promo's TEXT (not a brittle class), pierces shadow
+// roots, and re-hides via a throttled MutationObserver since the card mounts
+// after load. The `< 300` char guard ensures we hide the small promo card, not
+// a large ancestor that merely contains the text. Selector-free → durable, but
+// if Google changes the wording this needs refreshing.
+constexpr char kHideSwitchToChromeScript[] = R"JS(
+(function(){
+  var RE=/recommends using chrome|switch to chrome/i;
+  var last=0;
+  function run(){
+    try{
+      var stack=[document];
+      while(stack.length){
+        var root=stack.pop();
+        var all=root.querySelectorAll?root.querySelectorAll('*'):[];
+        for(var i=0;i<all.length;i++){
+          var el=all[i];
+          if(el.shadowRoot)stack.push(el.shadowRoot);
+          var t=el.textContent||'';
+          if(t.length<300&&RE.test(t)){
+            el.style.setProperty('display','none','important');
+          }
+        }
+      }
+    }catch(e){}
+  }
+  run();
+  try{
+    new MutationObserver(function(){
+      var now=Date.now();
+      if(now-last<400)return;
+      last=now;run();
+    }).observe(document.documentElement||document,{childList:true,subtree:true});
+  }catch(e){}
+})();
+)JS";
+
 }  // namespace
 
+// Observes the extensions inlay's Web Store tab and re-injects the
+// "Switch to Chrome?" promo hider on every main-frame load (the inlay reuses
+// one WebContents across Store↔Manage, so a single observer suffices).
+class SlayzoneEmbeddedTabHost::NagHider : public content::WebContentsObserver {
+ public:
+  explicit NagHider(content::WebContents* contents)
+      : content::WebContentsObserver(contents) {}
+
+  // Inject at navigation COMMIT (document-start), not load-complete — so the
+  // script's MutationObserver is watching before the page renders the nag,
+  // hiding it as it mounts instead of after it has already painted (no flash).
+  void DidFinishNavigation(content::NavigationHandle* handle) override {
+    if (!handle->IsInPrimaryMainFrame() || !handle->HasCommitted() ||
+        handle->IsSameDocument()) {
+      return;
+    }
+    if (handle->GetURL().host() != "chromewebstore.google.com") {
+      return;  // only the Web Store shows the nag
+    }
+    content::WebContents* contents = web_contents();
+    if (!contents) {
+      return;
+    }
+    if (content::RenderFrameHost* rfh = contents->GetPrimaryMainFrame()) {
+      rfh->ExecuteJavaScriptInIsolatedWorld(
+          base::UTF8ToUTF16(std::string_view(kHideSwitchToChromeScript)),
+          base::NullCallback(), ISOLATED_WORLD_ID_CHROME_INTERNAL);
+    }
+  }
+};
+
 // Each Entry NON-owningly references one tab's content::WebContents (owned by
 // its task Browser's TabStripModel) and forwards WebContentsObserver events to
 // the parent host's mojo observer. When the underlying tab is closed (LRU,
@@ -330,6 +404,13 @@ void SlayzoneEmbeddedTabHost::OpenExtensionsWindowOnProfile(
   chrome::AddAndReturnTabAt(extensions_browser_, target,
