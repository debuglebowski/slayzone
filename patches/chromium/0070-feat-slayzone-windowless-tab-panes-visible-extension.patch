@@ -0,0 +1,42 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_UI_VIEWS_FRAME_SLAYZONE_HIDDEN_BROWSER_VIEW_H_
+#define CHROME_BROWSER_UI_VIEWS_FRAME_SLAYZONE_HIDDEN_BROWSER_VIEW_H_
+
+#include "chrome/browser/ui/views/frame/browser_view.h"
+
+class Browser;
+
+// BrowserView for the embedded-tab host's windowless Browsers (those tagged via
+// `slayzone::IsEmbeddedTabBrowser`). Those Browsers exist ONLY as
+// extension-capable `TabStripModel` containers — their tabs are composited into
+// the SlayZone shell's own slot, so their OS window must NEVER surface.
+//
+// A plain `BrowserView` would still surface the window on the explicit-show
+// paths (`ScopedBrowserShower` during navigation, `ScopedTabbedBrowserDisplayer`
+// during extension install, `window.open`/`target=_blank`), and the user could
+// then close it — destroying the Browser and killing the live pane. We reuse all
+// of BrowserView's (battle-tested) machinery and only no-op the show / activate /
+// restore paths so the window stays headless. Tab rendering happens in the
+// shell's slot, never in this view.
+class SlayzoneHiddenBrowserView : public BrowserView {
+ public:
+  explicit SlayzoneHiddenBrowserView(Browser* browser);
+  SlayzoneHiddenBrowserView(const SlayzoneHiddenBrowserView&) = delete;
+  SlayzoneHiddenBrowserView& operator=(const SlayzoneHiddenBrowserView&) =
+      delete;
+  ~SlayzoneHiddenBrowserView() override;
+
+  // BrowserWindow (via BrowserView) — suppress everything that surfaces or
+  // focuses the OS window.
+  void Show() override {}
+  void ShowInactive() override {}
+  void Activate() override {}
+  void Minimize() override {}
+  void Maximize() override {}
+  void Restore() override {}
+};
+
+#endif  // CHROME_BROWSER_UI_VIEWS_FRAME_SLAYZONE_HIDDEN_BROWSER_VIEW_H_
