+// Sentinel stamped into `Browser::user_title` for the single VISIBLE extension
+// management window (chrome://extensions + Web Store + native install prompts).
+// Unlike the embedded-tab Browsers this one DOES show a normal Chrome window
+// (toolbar/omnibox) — extension install/management is inherently a browser-chrome
+// activity. It shares the panes' profile so installs apply there. The window
+// factory gives it a plain `BrowserView` (no shell takeover, not hidden).
+inline constexpr char kExtensionsBrowserMarker[] = "__slayzone_extensions__";
+
+// True iff `browser` is the extension-management window.
+bool IsExtensionsBrowser(const Browser* browser);
+
 }  // namespace slayzone
 
