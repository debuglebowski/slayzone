+void SlayzoneEmbeddedTabHost::OpenExtensionsWindow() {
+  if (extensions_browser_) {
+    // Already open — just surface it.
+    extensions_browser_->window()->Show();
+    extensions_browser_->window()->Activate();
+    return;
+  }
+  Profile* profile = Profile::FromBrowserContext(browser_context_);
+  if (!profile) {
+    LOG(WARNING) << "[embedded_tab] OpenExtensionsWindow — no Profile";
+    return;
+  }
+  // A NORMAL, VISIBLE Browser on the panes' profile. The marker makes the
+  // window factory give it a plain BrowserView (real toolbar/omnibox, no shell
+  // takeover, not hidden) — so chrome://extensions, the Web Store and native
+  // install prompts behave exactly as in stock Chrome, and installs land in the
+  // shared profile the task panes use.
+  // Brand the SlayZone profile's Chrome UI dark + the SlayZone accent (#7c7cf0)
+  // so the extensions window — the only visible Chrome-chrome surface — reads as
+  // ours rather than stock Chrome. Profile-wide is intentional here: this IS the
+  // SlayZone app's profile. Idempotent.
+  if (ThemeService* theme = ThemeServiceFactory::GetForProfile(profile)) {
+    theme->SetBrowserColorScheme(ThemeService::BrowserColorScheme::kDark);
+    theme->SetUserColor(SkColorSetRGB(0x7c, 0x7c, 0xf0));
+  }
+
+  // Normal (tabbed) Browser — the extension install/success UI explicitly
+  // finds/creates a TABBED visible window to anchor to (see
+  // extension_install_ui_desktop.cc), so a chromeless popup would mis-route the
+  // install. Size it to 80% of the work area, centered.
+  Browser::CreateParams cp(profile, /*user_gesture=*/true);
+  cp.user_title = kExtensionsBrowserMarker;
+  if (display::Screen::HasScreen()) {
+    const gfx::Rect work =
+        display::Screen::Get()->GetPrimaryDisplay().work_area();
+    const int w = work.width() * 4 / 5;
+    const int h = work.height() * 4 / 5;
+    cp.initial_bounds = gfx::Rect(work.x() + (work.width() - w) / 2,
+                                  work.y() + (work.height() - h) / 2, w, h);
+  }
+  extensions_browser_ = Browser::Create(cp);
+  if (!extensions_browser_) {
+    LOG(WARNING) << "[embedded_tab] OpenExtensionsWindow — Browser::Create failed";
+    return;
+  }
+  chrome::AddAndReturnTabAt(extensions_browser_,
+                            GURL("https://chromewebstore.google.com/"),
+                            /*index=*/-1, /*foreground=*/true);
+  extensions_browser_->window()->Show();
+  extensions_browser_->window()->Activate();
+  LOG(INFO) << "[embedded_tab] opened extensions window browser="
+            << extensions_browser_.get();
+}
+
