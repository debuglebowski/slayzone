+void SlayzoneEmbeddedTabHost::OnEntryContentsDestroyed(
+    const std::string& view_id) {
+  // Copy — `view_id` may alias the Entry's own member, which the erase below
+  // frees.
+  const std::string id = view_id;
+  auto it = entries_.find(id);
+  if (it == entries_.end()) {
+    return;
+  }
+  const bool was_active = (id == active_view_id_);
+  entries_.erase(it);
+  lru_.remove(id);
+  if (was_active) {
+    SetActiveViewId(std::string());
+  }
+}
+
+void SlayzoneEmbeddedTabHost::RefreshActivePresentation(
+    const std::string& view_id) {
+  if (view_id != active_view_id_ || !container_) {
+    return;
+  }
+  Entry* entry = FindEntry(view_id);
+  content::WebContents* contents = entry ? entry->contents() : nullptr;
+  if (!contents) {
+    return;
+  }
+  // Re-take the render keepalive for the (possibly swapped) RWHV + force shown.
+  active_capture_ = contents->IncrementCapturerCount(
+      gfx::Size(), /*stay_hidden=*/false, /*stay_awake=*/false,
+      /*is_activity=*/true);
+  contents->WasShown();
+  // Toggle the slot's WebContents so the views::WebView detaches the old
+  // render-view and re-attaches the current one.
+  container_->SetEmbeddedTabWebContents(nullptr);
+  container_->SetEmbeddedTabWebContents(contents);
+  RefreshContainer();
+}
+
+void SlayzoneEmbeddedTabHost::OnBrowserRemoved(Browser* browser) {
+  for (auto it = task_browsers_.begin(); it != task_browsers_.end();) {
+    if (it->second == browser) {
+      LOG(INFO) << "[embedded_tab] OnBrowserRemoved — our task Browser died task="
+                << it->first << " browser=" << browser;
+      it = task_browsers_.erase(it);
+    } else {
+      ++it;
+    }
+  }
+}
