+Browser* SlayzoneEmbeddedTabHost::GetOrCreateTaskBrowser(
+    const std::string& task_id) {
+  auto it = task_browsers_.find(task_id);
+  if (it != task_browsers_.end() && it->second) {
+    return it->second;
+  }
+  Profile* profile = Profile::FromBrowserContext(browser_context_);
+  if (!profile) {
+    LOG(WARNING) << "[embedded_tab] no Profile from browser_context_";
+    return nullptr;
+  }
+  // Windowless Browser: CreateParams builds the BrowserWindow but we NEVER call
+  // window()->Show(), so no OS window appears. It still self-registers in
+  // BrowserList/WindowControllerList, which makes its tabs real,
+  // extension-addressable tabs.
+  //
+  // The marker tags it as an embedded-tab Browser so the window factory hands
+  // it a plain BrowserView (NOT SlayzoneBrowserView) — without this it would
+  // install its own chrome://slayzone-shell takeover, open a browser pane, and
+  // recurse infinitely. Keep it out of session restore: it's an ephemeral tab
+  // container, not a user window.
+  Browser::CreateParams cp(profile, /*user_gesture=*/false);
+  cp.user_title = kEmbeddedTabBrowserMarker;
+  cp.omit_from_session_restore = true;
+  Browser* browser = Browser::Create(cp);
+  if (!browser) {
+    LOG(WARNING) << "[embedded_tab] Browser::Create failed for task=" << task_id;
+    return nullptr;
+  }
+  task_browsers_[task_id] = browser;
+  // Park an inert active tab in the (hidden) Browser. A BrowserView always owns
+  // its ACTIVE tab's RenderWidgetHostView — if a displayed tab were active, its
+  // pixels would be trapped in the hidden window and our slot would show
+  // nothing. With a throwaway active tab, every real content tab stays a
+  // BACKGROUND tab, whose RWHV our slot is free to composite.
+  chrome::AddAndReturnTabAt(browser, GURL("about:blank"), /*index=*/-1,
+                            /*foreground=*/true);
+  LOG(INFO) << "[embedded_tab] windowless Browser for task=" << task_id
+            << " browser=" << browser;
+  return browser;
+}
