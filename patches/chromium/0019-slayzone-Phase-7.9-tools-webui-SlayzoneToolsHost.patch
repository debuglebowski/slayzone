+#ifndef CHROME_BROWSER_UI_WEBUI_SLAYZONE_SLAYZONE_TOOLS_UI_H_
+#define CHROME_BROWSER_UI_WEBUI_SLAYZONE_SLAYZONE_TOOLS_UI_H_
+
+#include "chrome/browser/slayzone/mojom/tools.mojom.h"
+#include "chrome/common/webui_url_constants.h"
+#include "content/public/browser/web_ui_controller.h"
+#include "content/public/browser/webui_config.h"
+#include "content/public/common/url_constants.h"
+#include "mojo/public/cpp/bindings/pending_receiver.h"
+
+// Phase 7.9 — chrome://slayzone-tools/ WebUI controller.
+//
+// Serves the @slayzone/webui-tools Vite bundle from the directory named by
+// `--slayzone-webui-bundle-dir`. `BindInterface` hands out per-frame Mojo
+// receivers to the per-BrowserView `SlayzoneToolsHost`, mirroring the
+// Phase 7.1 statusbar pattern verbatim.
+class SlayzoneToolsUI : public content::WebUIController {
+ public:
+  explicit SlayzoneToolsUI(content::WebUI* web_ui);
+  SlayzoneToolsUI(const SlayzoneToolsUI&) = delete;
+  SlayzoneToolsUI& operator=(const SlayzoneToolsUI&) = delete;
+  ~SlayzoneToolsUI() override;
+
+  void BindInterface(
+      mojo::PendingReceiver<slayzone::tools::mojom::ToolsHost> receiver);
+
+ private:
+  WEB_UI_CONTROLLER_TYPE_DECL();
+};
+
+class SlayzoneToolsUIConfig
+    : public content::DefaultWebUIConfig<SlayzoneToolsUI> {
+ public:
+  SlayzoneToolsUIConfig()
+      : DefaultWebUIConfig(content::kChromeUIScheme,
+                           chrome::kChromeUISlayzoneToolsHost) {}
+};
+
+#endif  // CHROME_BROWSER_UI_WEBUI_SLAYZONE_SLAYZONE_TOOLS_UI_H_
