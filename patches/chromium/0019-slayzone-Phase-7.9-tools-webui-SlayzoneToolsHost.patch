diff --git a/chrome/browser/slayzone/mojom/tools.mojom b/chrome/browser/slayzone/mojom/tools.mojom
new file mode 100644
index 0000000000000..0b4e67b8a6faa
--- /dev/null
+++ b/chrome/browser/slayzone/mojom/tools.mojom
@@ -0,0 +1,40 @@
+// Phase 7.9 tools region data contract.
+//
+// Scope note: this .mojom lives in packages/shared/mojo-bindings/ (Phase 4.3
+// territory) as a coordinated exception, following the 5.6 layout.mojom and
+// 6.1 tabs.mojom pattern. The in-tree copy at
+// chrome/browser/slayzone/mojom/tools.mojom is what Chromium's mojom()
+// target compiles to C++; Phase 4.3 regenerates TS bindings from this outer
+// file. The two must stay diff-identical below the module line.
+//
+// The tools region is the right-side tool-toggle rail — agent panel,
+// notifications, usage, etc. Each toggle is a distinct UI surface exposed
+// elsewhere; this region only shows the "on/off" state + hands a toggle
+// request back to the sidecar, which mutates shared state that every other
+// region observes.
+
+module slayzone.tools.mojom;
+
+// One toggle pill. `id` is the stable identifier shared with the sidecar's
+// tool registry (`packages/sidecar/src/handlers/tools.ts`); `label` is the
+// user-facing name; `active` reflects the current on/off state.
+struct ToolToggle {
+  string id;
+  string label;
+  bool active;
+};
+
+// Full toggle list for the rail. Order matches the sidecar's declared
+// display order (stable across snapshots so React reconciliation is cheap).
+struct ToolsSnapshot {
+  array<ToolToggle> tools;
+};
+
+// Browser-side tools data provider. One remote per region WebUI that mounts.
+// `ToggleTool` forwards to the sidecar which flips the state and returns the
+// new snapshot; the JS side polls `GetSnapshot` on its own cadence so cross-
+// region toggles (e.g. another surface turning a tool on) are reflected.
+interface ToolsHost {
+  GetSnapshot() => (ToolsSnapshot snapshot);
+  ToggleTool(string id) => (ToolsSnapshot snapshot);
+};
diff --git a/chrome/browser/slayzone/slayzone_tools_host.cc b/chrome/browser/slayzone/slayzone_tools_host.cc
new file mode 100644
index 0000000000000..bfe5bfe462e84
--- /dev/null
+++ b/chrome/browser/slayzone/slayzone_tools_host.cc
@@ -0,0 +1,88 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/slayzone/slayzone_tools_host.h"
+
+#include <string>
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "base/values.h"
+#include "chrome/browser/slayzone/sidecar_client.h"
+
+namespace slayzone {
+
+namespace {
+
+// Translate the sidecar's JSON response into a Mojo snapshot. Missing fields
+// fall back to neutral defaults so the region can still render a frame even
+// when the sidecar is handshaking or mid-reconnect.
+tools::mojom::ToolsSnapshotPtr FromDict(const base::DictValue& response) {
+  auto snapshot = tools::mojom::ToolsSnapshot::New();
+  const base::Value* result = response.Find("result");
+  const base::DictValue* dict =
+      (result && result->is_dict()) ? &result->GetDict() : nullptr;
+  if (!dict) {
+    return snapshot;
+  }
+
+  const base::Value::List* list = dict->FindList("tools");
+  if (list) {
+    for (const base::Value& entry : *list) {
+      if (!entry.is_dict()) {
+        continue;
+      }
+      const base::DictValue& e = entry.GetDict();
+      auto tool = tools::mojom::ToolToggle::New();
+      if (const std::string* id = e.FindString("id")) {
+        tool->id = *id;
+      }
+      if (const std::string* label = e.FindString("label")) {
+        tool->label = *label;
+      }
+      tool->active = e.FindBool("active").value_or(false);
+      snapshot->tools.push_back(std::move(tool));
+    }
+  }
+
+  return snapshot;
+}
+
+}  // namespace
+
+SlayzoneToolsHost::SlayzoneToolsHost() = default;
+SlayzoneToolsHost::~SlayzoneToolsHost() = default;
+
+void SlayzoneToolsHost::Bind(
+    mojo::PendingReceiver<tools::mojom::ToolsHost> receiver) {
+  receivers_.Add(this, std::move(receiver));
+}
+
+void SlayzoneToolsHost::GetSnapshot(GetSnapshotCallback callback) {
+  SidecarClient::GetInstance()->Call(
+      "tools:get-snapshot", base::DictValue(),
+      base::BindOnce(
+          [](GetSnapshotCallback cb, base::DictValue response) {
+            std::move(cb).Run(FromDict(response));
+          },
+          std::move(callback)));
+}
+
+void SlayzoneToolsHost::ToggleTool(const std::string& id,
+                                   ToggleToolCallback callback) {
+  // JSON-RPC positional params: single string id.
+  base::Value::List params;
+  params.Append(id);
+  base::DictValue request;
+  request.Set("params", std::move(params));
+  SidecarClient::GetInstance()->Call(
+      "tools:toggle", std::move(request),
+      base::BindOnce(
+          [](ToggleToolCallback cb, base::DictValue response) {
+            std::move(cb).Run(FromDict(response));
+          },
+          std::move(callback)));
+}
+
+}  // namespace slayzone
