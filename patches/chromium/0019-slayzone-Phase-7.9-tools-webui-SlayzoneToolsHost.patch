+#ifndef CHROME_BROWSER_SLAYZONE_SLAYZONE_TOOLS_HOST_H_
+#define CHROME_BROWSER_SLAYZONE_SLAYZONE_TOOLS_HOST_H_
+
+#include <string>
+
+#include "chrome/browser/slayzone/mojom/tools.mojom.h"
+#include "mojo/public/cpp/bindings/pending_receiver.h"
+#include "mojo/public/cpp/bindings/receiver_set.h"
+
+namespace slayzone {
+
+// Phase 7.9 — browser-side implementation of
+// `slayzone::tools::mojom::ToolsHost`. One instance per
+// `SlayzoneBrowserView`. Both `GetSnapshot` and `ToggleTool` forward to the
+// process-wide `SidecarClient` via JSON-RPC methods `tools:get-snapshot`
+// and `tools:toggle`. The sidecar keeps the authoritative state in-process.
+class SlayzoneToolsHost
+    : public slayzone::tools::mojom::ToolsHost {
+ public:
+  SlayzoneToolsHost();
+  SlayzoneToolsHost(const SlayzoneToolsHost&) = delete;
+  SlayzoneToolsHost& operator=(const SlayzoneToolsHost&) = delete;
+  ~SlayzoneToolsHost() override;
+
+  void Bind(
+      mojo::PendingReceiver<slayzone::tools::mojom::ToolsHost> receiver);
+
+  // slayzone::tools::mojom::ToolsHost:
+  void GetSnapshot(GetSnapshotCallback callback) override;
+  void ToggleTool(const std::string& id, ToggleToolCallback callback) override;
+
+ private:
+  mojo::ReceiverSet<slayzone::tools::mojom::ToolsHost> receivers_;
+};
+
+}  // namespace slayzone
+
+#endif  // CHROME_BROWSER_SLAYZONE_SLAYZONE_TOOLS_HOST_H_
