--- /dev/null
+++ b/chrome/browser/slayzone/slayzone_json_rpc_host.cc
@@ -0,0 +1,106 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/slayzone/slayzone_json_rpc_host.h"
+
+#include <string>
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "base/json/json_reader.h"
+#include "base/json/json_writer.h"
+#include "base/values.h"
+#include "chrome/browser/slayzone/sidecar_client.h"
+
+namespace slayzone {
+
+namespace {
+
+json_rpc::mojom::JsonRpcResultPtr MakeError(const std::string& message) {
+  auto out = json_rpc::mojom::JsonRpcResult::New();
+  out->ok = false;
+  out->error = message;
+  return out;
+}
+
+json_rpc::mojom::JsonRpcResultPtr ResultFromResponse(
+    const base::DictValue& response) {
+  auto out = json_rpc::mojom::JsonRpcResult::New();
+
+  // sidecar error envelope: `{error: {message: ...}}`
+  if (const base::Value* err = response.Find("error");
+      err && err->is_dict()) {
+    if (const std::string* msg = err->GetDict().FindString("message")) {
+      out->error = *msg;
+    } else {
+      out->error = "sidecar error";
+    }
+    return out;
+  }
+
+  const base::Value* result = response.Find("result");
+  if (!result) {
+    // no-response fallback — treat as null result success so renderer can
+    // disambiguate missing handler (which surfaces as error above) from
+    // fire-and-forget notifications.
+    out->ok = true;
+    out->result_json = "null";
+    return out;
+  }
+
+  std::string serialized;
+  if (!base::JSONWriter::Write(*result, &serialized)) {
+    out->ok = false;
+    out->error = "failed to serialize sidecar result";
+    return out;
+  }
+  out->ok = true;
+  out->result_json = std::move(serialized);
+  return out;
+}
+
+}  // namespace
+
+SlayzoneJsonRpcHost::SlayzoneJsonRpcHost() = default;
+SlayzoneJsonRpcHost::~SlayzoneJsonRpcHost() = default;
+
+void SlayzoneJsonRpcHost::Bind(
+    mojo::PendingReceiver<json_rpc::mojom::JsonRpcHost> receiver) {
+  receivers_.Add(this, std::move(receiver));
+}
+
+void SlayzoneJsonRpcHost::Call(const std::string& method,
+                               const std::string& params_json,
+                               CallCallback callback) {
+  // Empty params = no-arg call. Pass empty dict.
+  base::DictValue params;
+  if (!params_json.empty()) {
+    std::optional<base::Value> parsed =
+        base::JSONReader::Read(params_json, base::JSON_PARSE_RFC);
+    if (!parsed.has_value()) {
+      std::move(callback).Run(MakeError("invalid params_json"));
+      return;
+    }
+    if (parsed->is_dict()) {
+      params = std::move(*parsed).TakeDict();
+    } else if (parsed->is_list()) {
+      // Sidecar dispatcher unwraps `{params: [...]}` to positional args.
+      params.Set("params", std::move(*parsed));
+    } else {
+      std::move(callback).Run(
+          MakeError("params_json must decode to object or array"));
+      return;
+    }
+  }
+
+  SidecarClient::GetInstance()->Call(
+      method, std::move(params),
+      base::BindOnce(
+          [](CallCallback cb, base::DictValue response) {
+            std::move(cb).Run(ResultFromResponse(response));
+          },
+          std::move(callback)));
+}
+
+}  // namespace slayzone
