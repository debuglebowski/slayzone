+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_SLAYZONE_SLAYZONE_JSON_RPC_HOST_H_
+#define CHROME_BROWSER_SLAYZONE_SLAYZONE_JSON_RPC_HOST_H_
+
+#include <string>
+
+#include "chrome/browser/slayzone/mojom/json_rpc.mojom.h"
+#include "mojo/public/cpp/bindings/pending_receiver.h"
+#include "mojo/public/cpp/bindings/receiver_set.h"
+
+namespace slayzone {
+
+// cap-shell-6 — generic JSON-RPC passthrough to the sidecar. Lets the
+// renderer's window-api-shim call arbitrary sidecar methods without a
+// dedicated typed mojom per domain. Parses the shim's JSON params string
+// into a base::Value dict, forwards to SidecarClient, re-serializes the
+// response's `result` field back into JSON for the shim to parse.
+class SlayzoneJsonRpcHost : public slayzone::json_rpc::mojom::JsonRpcHost {
+ public:
+  SlayzoneJsonRpcHost();
+  SlayzoneJsonRpcHost(const SlayzoneJsonRpcHost&) = delete;
+  SlayzoneJsonRpcHost& operator=(const SlayzoneJsonRpcHost&) = delete;
+  ~SlayzoneJsonRpcHost() override;
+
+  void Bind(
+      mojo::PendingReceiver<slayzone::json_rpc::mojom::JsonRpcHost> receiver);
+
+  // slayzone::json_rpc::mojom::JsonRpcHost:
+  void Call(const std::string& method,
+            const std::string& params_json,
+            CallCallback callback) override;
+
+ private:
+  mojo::ReceiverSet<slayzone::json_rpc::mojom::JsonRpcHost> receivers_;
+};
+
+}  // namespace slayzone
+
+#endif  // CHROME_BROWSER_SLAYZONE_SLAYZONE_JSON_RPC_HOST_H_
