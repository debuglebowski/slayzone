new file mode 100644
index 0000000000000..99e4e37c86bae
--- /dev/null
+++ b/chrome/browser/slayzone/slayzone_embedded_tab_host.h
@@ -0,0 +1,152 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_SLAYZONE_SLAYZONE_EMBEDDED_TAB_HOST_H_
+#define CHROME_BROWSER_SLAYZONE_SLAYZONE_EMBEDDED_TAB_HOST_H_
+
+#include <list>
+#include <map>
+#include <memory>
+#include <string>
+
+#include "base/memory/raw_ptr.h"
+#include "base/memory/weak_ptr.h"
+#include "chrome/browser/slayzone/mojom/embedded_tab.mojom.h"
+#include "content/public/browser/web_contents_observer.h"
+#include "mojo/public/cpp/bindings/pending_receiver.h"
+#include "mojo/public/cpp/bindings/pending_remote.h"
+#include "mojo/public/cpp/bindings/receiver.h"
+#include "mojo/public/cpp/bindings/remote.h"
+#include "ui/gfx/geometry/rect.h"
+
+class SlayzoneShellContainer;
+
+namespace content {
+class BrowserContext;
+class WebContents;
+}  // namespace content
+
+namespace slayzone {
+
+// cap-shell-4 — inline task browser.
+//
+// One SlayzoneEmbeddedTabHost per SlayzoneShellUI instance. The host owns N
+// per-view content::WebContents (keyed by host-generated view_id) and a single
+// shared views::WebView "slot" — the overlay surface in SlayzoneShellContainer
+// that renders whichever WebContents is currently active. Switching the
+// active view is SetWebContents(ptr) on the slot; no reparenting.
+//
+// Per-view WebContents cache with LRU at cap=10 — see embedded_tab.mojom for
+// rationale. The currently-active view is always at the MRU end and is never
+// evictable.
+//
+// Nav / state events flow the opposite direction: each Entry is a
+// WebContentsObserver and forwards TitleWasSet / PrimaryPageChanged /
+// DidStart-DidStopLoading into the single EmbeddedTabObserver remote the
+// renderer registered via Subscribe.
+class SlayzoneEmbeddedTabHost
+    : public slayzone::embedded_tab::mojom::EmbeddedTabHost {
+ public:
+  // `browser_context` must outlive this object. `container` may be null (e.g.
+  // shell mounted with no active browser view) — every public method becomes
+  // a no-op in that case so the renderer pipe stays alive.
+  SlayzoneEmbeddedTabHost(content::BrowserContext* browser_context,
+                          SlayzoneShellContainer* container);
+  SlayzoneEmbeddedTabHost(const SlayzoneEmbeddedTabHost&) = delete;
+  SlayzoneEmbeddedTabHost& operator=(const SlayzoneEmbeddedTabHost&) = delete;
+  ~SlayzoneEmbeddedTabHost() override;
+
+  void Bind(mojo::PendingReceiver<
+            slayzone::embedded_tab::mojom::EmbeddedTabHost> receiver);
+
+  // slayzone::embedded_tab::mojom::EmbeddedTabHost:
+  void CreateView(slayzone::embedded_tab::mojom::CreateViewParamsPtr params,
+                  CreateViewCallback callback) override;
+  void DestroyView(const std::string& view_id) override;
+  void DestroyAllForTask(const std::string& task_id) override;
+  void SetBounds(
+      const std::string& view_id,
+      slayzone::embedded_tab::mojom::EmbeddedTabBoundsPtr bounds) override;
+  void SetVisible(const std::string& view_id, bool visible) override;
+  void Navigate(const std::string& view_id,
+                const std::string& url) override;
+  void GoBack(const std::string& view_id) override;
+  void GoForward(const std::string& view_id) override;
+  void Reload(const std::string& view_id, bool ignore_cache) override;
+  void Stop(const std::string& view_id) override;
+  void Focus(const std::string& view_id) override;
+  void ToggleDevtools(const std::string& view_id) override;
+  void Subscribe(mojo::PendingRemote<
+                 slayzone::embedded_tab::mojom::EmbeddedTabObserver>
+                     observer) override;
+
+  // Entry-side callbacks. Declared public so the private Entry inner class in
+  // the .cc can reach them without friending. Signatures mirror the mojom
+  // observer interface 1:1 — see embedded_tab.mojom for rationale.
+  void FireDidNavigate(const std::string& view_id,
+                       const std::string& url,
+                       bool can_go_back,
+                       bool can_go_forward);
+  void FirePageTitleUpdated(const std::string& view_id,
+                             const std::string& title);
+  void FireDidStartLoading(const std::string& view_id);
+  void FireDidStopLoading(const std::string& view_id);
+  void FireDomReady(const std::string& view_id);
+  void FireDidFailLoad(const std::string& view_id,
+                       int32_t error_code,
+                       const std::string& error_description,
+                       const std::string& url);
+
+ private:
+  class Entry;
+
+  // LRU cap — see feedback in the binding contract. 10 open tabs at ~30-50MB
+  // each caps at ~500MB worst-case; larger caps need telemetry before we
+  // justify them.
+  static constexpr size_t kLruCap = 10;
+
+  Entry* FindEntry(const std::string& view_id);
+
+  // Push `view_id` to the MRU end (back of lru_).
+  void TouchLru(const std::string& view_id);
+
+  // Evict the least-recently-used entry if we're over kLruCap. The active
+  // view (always at the back of lru_) is never evictable.
+  void EvictIfOverCap();
+
+  // Swap the active view. Passing "" detaches.
+  void SetActiveViewId(const std::string& view_id);
+
+  // Push the current active view's visibility / bounds into the container.
+  void RefreshContainer();
+
+  raw_ptr<content::BrowserContext> browser_context_;
+  raw_ptr<SlayzoneShellContainer> container_;
+
+  std::map<std::string, std::unique_ptr<Entry>> entries_;
+
+  // LRU order: front = least recent, back = most recent (active).
+  std::list<std::string> lru_;
+
+  // Currently-active view id. Empty when no view is active.
+  std::string active_view_id_;
+
+  // Last bounds / visibility requested for the active view. Kept so
+  // RefreshContainer can push the latest state after a view swap.
+  gfx::Rect active_bounds_;
+  bool active_visible_ = false;
+
+  // Monotonic view id counter — the shim keys everything on this string.
+  uint64_t next_id_ = 1;
+
+  mojo::Receiver<slayzone::embedded_tab::mojom::EmbeddedTabHost> receiver_{
+      this};
+  mojo::Remote<slayzone::embedded_tab::mojom::EmbeddedTabObserver> observer_;
+
+  base::WeakPtrFactory<SlayzoneEmbeddedTabHost> weak_factory_{this};
+};
+
+}  // namespace slayzone
+
+#endif  // CHROME_BROWSER_SLAYZONE_SLAYZONE_EMBEDDED_TAB_HOST_H_
diff --git a/chrome/browser/slayzone/slayzone_json_rpc_host.cc b/chrome/browser/slayzone/slayzone_json_rpc_host.cc
new file mode 100644
