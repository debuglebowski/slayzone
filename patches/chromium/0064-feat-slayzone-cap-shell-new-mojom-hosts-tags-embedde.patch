new file mode 100644
index 0000000000000..37340c4849e4e
--- /dev/null
+++ b/chrome/browser/slayzone/slayzone_windows_host.cc
@@ -0,0 +1,431 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/slayzone/slayzone_windows_host.h"
+
+#include <memory>
+#include <string>
+#include <utility>
+
+#include "base/logging.h"
+#include "base/memory/ptr_util.h"
+#include "base/no_destructor.h"
+#include "base/strings/strcat.h"
+#include "base/task/sequenced_task_runner.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/common/webui_url_constants.h"
+#include "content/public/browser/web_contents.h"
+#include "ui/base/mojom/ui_base_types.mojom-shared.h"
+#include "ui/gfx/geometry/rect.h"
+#include "ui/views/controls/webview/webview.h"
+#include "ui/views/widget/widget.h"
+#include "ui/views/widget/widget_delegate.h"
+#include "ui/views/widget/widget_observer.h"
+#include "url/gurl.h"
+
+namespace slayzone {
+
+namespace {
+
+// Defaults picked to mirror the Electron build. Widths in DIP.
+constexpr int kDefaultSplashWidth = 800;
+constexpr int kDefaultSplashHeight = 600;
+constexpr int kDefaultFloatingAgentWidth = 360;
+constexpr int kDefaultFloatingAgentHeight = 480;
+constexpr int kDefaultLeaderboardWidth = 900;
+constexpr int kDefaultLeaderboardHeight = 700;
+constexpr int kDefaultGenericWidth = 600;
+constexpr int kDefaultGenericHeight = 400;
+
+gfx::Rect ResolveInitialBounds(
+    slayzone::windows::mojom::AuxWindowType type,
+    const slayzone::windows::mojom::WindowBounds& bounds) {
+  int w = bounds.width;
+  int h = bounds.height;
+  if (w <= 0 || h <= 0) {
+    switch (type) {
+      case slayzone::windows::mojom::AuxWindowType::kSplash:
+        w = kDefaultSplashWidth;
+        h = kDefaultSplashHeight;
+        break;
+      case slayzone::windows::mojom::AuxWindowType::kFloatingAgent:
+        w = kDefaultFloatingAgentWidth;
+        h = kDefaultFloatingAgentHeight;
+        break;
+      case slayzone::windows::mojom::AuxWindowType::kLeaderboard:
+        w = kDefaultLeaderboardWidth;
+        h = kDefaultLeaderboardHeight;
+        break;
+      case slayzone::windows::mojom::AuxWindowType::kGeneric:
+      default:
+        w = kDefaultGenericWidth;
+        h = kDefaultGenericHeight;
+        break;
+    }
+  }
+  return gfx::Rect(bounds.x, bounds.y, w, h);
+}
+
+GURL BuildAuxUrl(const std::string& url_fragment) {
+  std::string base = chrome::kChromeUISlayzoneShellURL;
+  if (url_fragment.empty()) {
+    return GURL(base);
+  }
+  if (url_fragment.front() == '#' || url_fragment.front() == '/' ||
+      url_fragment.front() == '?') {
+    return GURL(base::StrCat({base, url_fragment}));
+  }
+  return GURL(base::StrCat({base, "#", url_fragment}));
+}
+
+}  // namespace
+
+// AuxWindow: one per open aux window. Lifetime matches the views::Widget —
+// when the OS closes the window (user X button, app teardown) the Widget
+// fires OnWidgetDestroying on us; we notify the host which erases our entry,
+// destroying this object as the map entry unwinds.
+class SlayzoneWindowsHost::AuxWindow : public views::WidgetObserver {
+ public:
+  AuxWindow(SlayzoneWindowsHost* host,
+            Profile* profile,
+            std::string window_id,
+            slayzone::windows::mojom::AuxWindowType type,
+            const GURL& url,
+            const gfx::Rect& initial_bounds,
+            bool frameless,
+            bool skip_taskbar,
+            bool activate_on_show)
+      : host_(host), window_id_(std::move(window_id)) {
+    LOG(INFO) << "[AuxWindow] ctor id=" << window_id_
+              << " type=" << static_cast<int>(type)
+              << " bounds=" << initial_bounds.ToString()
+              << " frameless=" << frameless
+              << " activate=" << activate_on_show;
+    // Built-in default WidgetDelegate is used — we skip a custom one to
+    // avoid WidgetDelegate::OwnedByWidgetPassKey's locked-down friend list.
+    // Frame removal + resizability come through InitParams directly.
+    views::Widget::InitParams params(
+        views::Widget::InitParams::NATIVE_WIDGET_OWNS_WIDGET,
+        views::Widget::InitParams::TYPE_WINDOW);
+    params.bounds = initial_bounds;
+    params.remove_standard_frame = frameless;
+    params.name = "SlayzoneAuxWindow-" + window_id_;
+    if (type == slayzone::windows::mojom::AuxWindowType::kFloatingAgent) {
+      params.z_order = ui::ZOrderLevel::kFloatingWindow;
+    }
+    // skip_taskbar is platform-specific; views::Widget::InitParams doesn't
+    // expose a cross-platform skip-taskbar knob — defer to a native-widget
+    // platform-specific follow-up if a real use case lands.
+    (void)skip_taskbar;
+
+    widget_ = new views::Widget();
+    widget_->Init(std::move(params));
+    LOG(INFO) << "[AuxWindow] Widget::Init done id=" << window_id_
+              << " widget=" << widget_.get();
+    widget_obs_.Observe(widget_.get());
+
+    auto webview_owned = std::make_unique<views::WebView>(profile);
+    web_view_ = widget_->SetContentsView(std::move(webview_owned));
+    web_view_->LoadInitialURL(url);
+    LOG(INFO) << "[AuxWindow] WebView attached id=" << window_id_
+              << " url=" << url.spec();
+
+    if (activate_on_show) {
+      widget_->Show();
+    } else {
+      widget_->ShowInactive();
+    }
+    LOG(INFO) << "[AuxWindow] Shown id=" << window_id_
+              << " visible=" << widget_->IsVisible()
+              << " active=" << widget_->IsActive();
+  }
+
+  AuxWindow(const AuxWindow&) = delete;
+  AuxWindow& operator=(const AuxWindow&) = delete;
+
+  ~AuxWindow() override {
+    widget_obs_.Reset();
+    if (widget_ && !widget_closing_) {
+      // Host-initiated teardown (Close() / erase). NATIVE_WIDGET_OWNS_WIDGET
+      // means widget_->Close() posts a task that destroys the Widget.
+      widget_->Close();
+      widget_ = nullptr;
+    }
+  }
+
+  void Close() {
+    if (widget_ && !widget_closing_) {
+      widget_closing_ = true;
+      widget_->Close();
+    }
+  }
+
+  void Focus() {
+    if (widget_) {
+      widget_->Activate();
+    }
+  }
+
+  void SetBounds(const gfx::Rect& bounds) {
+    if (widget_) {
+      widget_->SetBounds(bounds);
+    }
+  }
+
+  void SetVisible(bool visible) {
+    if (!widget_) {
+      return;
+    }
+    if (visible) {
+      widget_->Show();
+    } else {
+      widget_->Hide();
+    }
+  }
+
+  views::Widget* widget() { return widget_; }
+  const std::string& window_id() const { return window_id_; }
+
+  // views::WidgetObserver:
+  void OnWidgetDestroying(views::Widget* widget) override {
+    widget_obs_.Reset();
+    widget_ = nullptr;
+    // Tell the host; host erases us from the map which destroys `this`.
+    // Stack-safe because OnAuxWindowClosed copies the id out before erase.
+    const std::string id_copy = window_id_;
+    SlayzoneWindowsHost* host_copy = host_;
+    host_copy->OnAuxWindowClosed(id_copy);
+  }
+
+  void OnWidgetActivationChanged(views::Widget* widget, bool active) override {
+    host_->OnAuxWindowFocused(window_id_, active);
+  }
+
+  void OnWidgetBoundsChanged(views::Widget* widget,
+                              const gfx::Rect& new_bounds) override {
+    host_->OnAuxWindowBoundsChanged(window_id_, new_bounds);
+  }
+
+ private:
+  raw_ptr<SlayzoneWindowsHost> host_;
+  const std::string window_id_;
+  raw_ptr<views::Widget> widget_ = nullptr;
+  raw_ptr<views::WebView> web_view_ = nullptr;
+  bool widget_closing_ = false;
+  base::ScopedObservation<views::Widget, views::WidgetObserver> widget_obs_{
+      this};
+};
+
+// static
+SlayzoneWindowsHost* SlayzoneWindowsHost::GetInstance() {
+  static base::NoDestructor<SlayzoneWindowsHost> instance;
+  return instance.get();
+}
+
+SlayzoneWindowsHost::SlayzoneWindowsHost() = default;
+SlayzoneWindowsHost::~SlayzoneWindowsHost() = default;
+
+void SlayzoneWindowsHost::Bind(
+    mojo::PendingReceiver<slayzone::windows::mojom::WindowsHost> receiver,
+    content::WebContents* caller_wc) {
+  LOG(INFO) << "[WindowsHost] Bind — caller_wc=" << caller_wc
+            << " windows_size=" << windows_.size()
+            << " observers=" << observers_.size();
+  base::WeakPtr<content::WebContents> ctx;
+  if (caller_wc) {
+    ctx = caller_wc->GetWeakPtr();
+  }
+  receivers_.Add(this, std::move(receiver), std::move(ctx));
+}
+
+void SlayzoneWindowsHost::Open(
+    slayzone::windows::mojom::OpenParamsPtr params,
+    OpenCallback callback) {
+  LOG(INFO) << "[WindowsHost] Open enter "
+            << (params ? params->window_id : "<null-params>")
+            << " type=" << (params ? static_cast<int>(params->type) : -1)
+            << " url_fragment="
+            << (params ? params->url_fragment : "<null>");
+  if (!params) {
+    LOG(WARNING) << "[WindowsHost] Open — null params";
+    std::move(callback).Run(false, "null params");
+    return;
+  }
+  if (params->window_id.empty()) {
+    LOG(WARNING) << "[WindowsHost] Open — empty window_id";
+    std::move(callback).Run(false, "window_id required");
+    return;
+  }
+  if (windows_.find(params->window_id) != windows_.end()) {
+    LOG(WARNING) << "[WindowsHost] Open — window_id already open: "
+                 << params->window_id;
+    std::move(callback).Run(false, "window_id already open");
+    return;
+  }
+
+  // Capture profile from the caller's WebContents on first Open.
+  if (!profile_) {
+    if (content::WebContents* wc = CurrentContextWebContents()) {
+      profile_ = Profile::FromBrowserContext(wc->GetBrowserContext());
+    }
+  }
+  if (!profile_) {
+    LOG(WARNING) << "[WindowsHost] Open — no profile available; caller_wc null";
+    std::move(callback).Run(false, "no profile available");
+    return;
+  }
+
+  const GURL url = BuildAuxUrl(params->url_fragment);
+  if (!url.is_valid()) {
+    LOG(WARNING) << "[WindowsHost] Open — invalid url: " << url.spec();
+    std::move(callback).Run(false, "invalid url_fragment");
+    return;
+  }
+
+  const gfx::Rect bounds = ResolveInitialBounds(params->type, *params->bounds);
+  LOG(INFO) << "[WindowsHost] Open spawning Widget id=" << params->window_id
+            << " url=" << url.spec() << " bounds=" << bounds.ToString();
+
+  auto aux = std::make_unique<AuxWindow>(
+      this, profile_.get(), params->window_id, params->type, url, bounds,
+      params->frameless, params->skip_taskbar, params->activate_on_show);
+
+  const std::string id = params->window_id;
+  windows_[id] = std::move(aux);
+
+  // Fan OnOpened to every subscribed observer.
+  for (auto& obs : observers_) {
+    obs->OnOpened(id);
+  }
+
+  LOG(INFO) << "[WindowsHost] Open ok id=" << id
+            << " observers=" << observers_.size();
+  std::move(callback).Run(true, std::string());
+}
+
+void SlayzoneWindowsHost::Close(const std::string& window_id) {
+  LOG(INFO) << "[WindowsHost] Close id=" << window_id;
+  auto it = windows_.find(window_id);
+  if (it == windows_.end()) {
+    LOG(WARNING) << "[WindowsHost] Close — unknown id: " << window_id;
+    return;
+  }
+  // AuxWindow::Close() → widget->Close() → OnWidgetDestroying →
+  // OnAuxWindowClosed which erases from `windows_`. That erase deletes the
+  // AuxWindow. Posting avoids destroying the receiver from inside its own
+  // call — matches the cap-shell-3 terminal-host disconnect pattern.
+  it->second->Close();
+}
+
+void SlayzoneWindowsHost::Focus(const std::string& window_id) {
+  LOG(INFO) << "[WindowsHost] Focus id=" << window_id;
+  AuxWindow* aux = FindAuxWindow(window_id);
+  if (aux) {
+    aux->Focus();
+  } else {
+    LOG(WARNING) << "[WindowsHost] Focus — unknown id: " << window_id;
+  }
+}
+
+void SlayzoneWindowsHost::SetBounds(
+    const std::string& window_id,
+    slayzone::windows::mojom::WindowBoundsPtr bounds) {
+  if (!bounds) {
+    return;
+  }
+  AuxWindow* aux = FindAuxWindow(window_id);
+  if (aux) {
+    aux->SetBounds(gfx::Rect(bounds->x, bounds->y, bounds->width,
+                              bounds->height));
+  }
+}
+
+void SlayzoneWindowsHost::SetVisible(const std::string& window_id,
+                                      bool visible) {
+  AuxWindow* aux = FindAuxWindow(window_id);
+  if (aux) {
+    aux->SetVisible(visible);
+  }
+}
+
+void SlayzoneWindowsHost::CloseCurrentWindow() {
+  content::WebContents* wc = CurrentContextWebContents();
+  LOG(INFO) << "[WindowsHost] CloseCurrentWindow caller_wc=" << wc;
+  if (!wc) {
+    LOG(WARNING) << "[WindowsHost] CloseCurrentWindow — no caller WebContents";
+    return;
+  }
+  gfx::NativeView native_view = wc->GetNativeView();
+  views::Widget* top_level =
+      views::Widget::GetTopLevelWidgetForNativeView(native_view);
+  if (top_level) {
+    top_level->Close();
+  } else {
+    LOG(WARNING) << "[WindowsHost] CloseCurrentWindow — no top-level Widget";
+  }
+}
+
+void SlayzoneWindowsHost::SendMessage(const std::string& window_id,
+                                      const std::string& json) {
+  for (auto& obs : observers_) {
+    obs->OnMessage(window_id, json);
+  }
+}
+
+void SlayzoneWindowsHost::Subscribe(
+    mojo::PendingRemote<slayzone::windows::mojom::WindowsObserver> observer) {
+  observers_.Add(std::move(observer));
+}
+
+void SlayzoneWindowsHost::OnAuxWindowClosed(const std::string& window_id) {
+  // Fan OnClosed before erasing — observers may want to log the close.
+  for (auto& obs : observers_) {
+    obs->OnClosed(window_id);
+  }
+  // Defer erase to the next task so we don't destroy the AuxWindow from
+  // inside its own WidgetObserver callback.
+  base::SequencedTaskRunner::GetCurrentDefault()->PostTask(
+      FROM_HERE, base::BindOnce(
+                     [](base::WeakPtr<SlayzoneWindowsHost> self,
+                        const std::string& id) {
+                       if (self) {
+                         self->windows_.erase(id);
+                       }
+                     },
+                     weak_factory_.GetWeakPtr(), window_id));
+}
+
+void SlayzoneWindowsHost::OnAuxWindowFocused(const std::string& window_id,
+                                              bool focused) {
+  for (auto& obs : observers_) {
+    obs->OnFocused(window_id, focused);
+  }
+}
+
+void SlayzoneWindowsHost::OnAuxWindowBoundsChanged(
+    const std::string& window_id,
+    const gfx::Rect& bounds) {
+  auto rect = slayzone::windows::mojom::WindowBounds::New();
+  rect->x = bounds.x();
+  rect->y = bounds.y();
+  rect->width = bounds.width();
+  rect->height = bounds.height();
+  for (auto& obs : observers_) {
+    obs->OnBoundsChanged(window_id, rect.Clone());
+  }
+}
+
+content::WebContents* SlayzoneWindowsHost::CurrentContextWebContents() {
+  const base::WeakPtr<content::WebContents>& ctx =
+      receivers_.current_context();
+  return ctx.get();
+}
+
+SlayzoneWindowsHost::AuxWindow* SlayzoneWindowsHost::FindAuxWindow(
+    const std::string& window_id) {
+  auto it = windows_.find(window_id);
+  return it == windows_.end() ? nullptr : it->second.get();
+}
+
+}  // namespace slayzone
