+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_SLAYZONE_SLAYZONE_NATIVE_DIALOG_HOST_H_
+#define CHROME_BROWSER_SLAYZONE_SLAYZONE_NATIVE_DIALOG_HOST_H_
+
+#include <vector>
+
+#include "base/memory/raw_ptr.h"
+#include "base/memory/scoped_refptr.h"
+#include "base/memory/weak_ptr.h"
+#include "chrome/browser/slayzone/mojom/dialog.mojom.h"
+#include "mojo/public/cpp/bindings/pending_receiver.h"
+#include "mojo/public/cpp/bindings/receiver_set.h"
+#include "ui/shell_dialogs/select_file_dialog.h"
+
+namespace content {
+class WebContents;
+}
+
+namespace slayzone {
+
+// cap-shell-dialog — browser-side fan-out for the native OS open-folder /
+// open-file picker. One per SlayzoneShellUI instance; dialogs are serial
+// (Electron's `dialog.showOpenDialog` contract blocks until dismissed), so
+// a single SelectFileDialog + single pending callback is enough. A second
+// call before the first resolves returns `canceled=true` on the new one.
+//
+// Lifetime of a single invocation:
+//   1. JS calls NativeDialogHost.ShowOpenDialog → Mojo hop → ShowOpenDialog.
+//   2. We allocate `select_file_dialog_` (scoped_refptr) via the factory,
+//      stash the Mojo response callback, and fire `SelectFile`.
+//   3. macOS shows NSOpenPanel. User picks or cancels → Listener callback
+//      runs on the UI thread → we run `pending_callback_` with the result
+//      and drop the refptr.
+class SlayzoneNativeDialogHost
+    : public slayzone::dialog::mojom::NativeDialogHost,
+      public ui::SelectFileDialog::Listener {
+ public:
+  explicit SlayzoneNativeDialogHost(content::WebContents* web_contents);
+  SlayzoneNativeDialogHost(const SlayzoneNativeDialogHost&) = delete;
+  SlayzoneNativeDialogHost& operator=(const SlayzoneNativeDialogHost&) = delete;
+  ~SlayzoneNativeDialogHost() override;
+
+  void Bind(mojo::PendingReceiver<slayzone::dialog::mojom::NativeDialogHost>
+                receiver);
+
+  // slayzone::dialog::mojom::NativeDialogHost:
+  void ShowOpenDialog(slayzone::dialog::mojom::ShowOpenDialogOptionsPtr options,
+                      ShowOpenDialogCallback callback) override;
+
+  // ui::SelectFileDialog::Listener:
+  void FileSelected(const ui::SelectedFileInfo& file, int index) override;
+  void MultiFilesSelected(
+      const std::vector<ui::SelectedFileInfo>& files) override;
+  void FileSelectionCanceled() override;
+
+ private:
+  // The WebContents is owned by the SlayzoneShellUI controller, which also
+  // owns this host. The controller tears us down before the WebContents
+  // goes away, so a raw pointer is safe.
+  const raw_ptr<content::WebContents> web_contents_;
+
+  mojo::ReceiverSet<slayzone::dialog::mojom::NativeDialogHost> receivers_;
+
+  scoped_refptr<ui::SelectFileDialog> select_file_dialog_;
+  ShowOpenDialogCallback pending_callback_;
+
+  base::WeakPtrFactory<SlayzoneNativeDialogHost> weak_factory_{this};
+};
+
+}  // namespace slayzone
+
+#endif  // CHROME_BROWSER_SLAYZONE_SLAYZONE_NATIVE_DIALOG_HOST_H_
diff --git a/chrome/browser/slayzone/slayzone_tags_host.cc b/chrome/browser/slayzone/slayzone_tags_host.cc
new file mode 100644
index 0000000000000..53775ee3a4a67
--- /dev/null
+++ b/chrome/browser/slayzone/slayzone_tags_host.cc
@@ -0,0 +1,223 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/slayzone/slayzone_tags_host.h"
+
+#include <string>
+#include <utility>
+#include <vector>
+
+#include "base/functional/bind.h"
+#include "base/values.h"
+#include "chrome/browser/slayzone/sidecar_client.h"
+
+namespace slayzone {
+
+namespace {
+
+// Pull a `Tag` out of a JSON dict row (`{ id, name, color }`). Missing fields
+// fall back to empty strings — the renderer tolerates empty label/color.
+tags::mojom::TagPtr TagFromDict(const base::DictValue& row) {
+  auto t = tags::mojom::Tag::New();
+  if (const std::string* id = row.FindString("id")) {
+    t->id = *id;
+  }
+  if (const std::string* name = row.FindString("name")) {
+    t->name = *name;
+  }
+  if (const std::string* color = row.FindString("color")) {
+    t->color = *color;
+  }
+  return t;
+}
+
+// Sidecar `tags:list` and `tags:for-task` return a bare array under
+// `result`. Convert to array<Tag>.
+std::vector<tags::mojom::TagPtr> TagsFromListResponse(
+    const base::DictValue& response) {
+  std::vector<tags::mojom::TagPtr> out;
+  const base::Value* result = response.Find("result");
+  if (!result || !result->is_list()) {
+    return out;
+  }
+  for (const base::Value& entry : result->GetList()) {
+    if (!entry.is_dict()) {
+      continue;
+    }
+    out.push_back(TagFromDict(entry.GetDict()));
+  }
+  return out;
+}
+
+// Sidecar write-shape handlers return `{ ok, error, tag }`.
+tags::mojom::TagWriteResultPtr WriteResultFromResponse(
+    const base::DictValue& response) {
+  auto out = tags::mojom::TagWriteResult::New();
+  out->tag = tags::mojom::Tag::New();
+
+  const base::Value* result = response.Find("result");
+  const base::DictValue* dict =
+      (result && result->is_dict()) ? &result->GetDict() : nullptr;
+  if (!dict) {
+    if (const base::Value* err = response.Find("error");
+        err && err->is_dict()) {
+      if (const std::string* msg = err->GetDict().FindString("message")) {
+        out->error = *msg;
+      } else {
+        out->error = "sidecar error";
+      }
+    } else {
+      out->error = "no response";
+    }
+    return out;
+  }
+
+  out->ok = dict->FindBool("ok").value_or(false);
+  if (const std::string* err = dict->FindString("error")) {
+    out->error = *err;
+  }
+  if (const base::Value* tag = dict->Find("tag"); tag && tag->is_dict()) {
+    out->tag = TagFromDict(tag->GetDict());
+  }
+  return out;
+}
+
+// `tags:attach` / `tags:detach` return `{ ok, error }`.
+tags::mojom::TagAttachResultPtr AttachResultFromResponse(
+    const base::DictValue& response) {
+  auto out = tags::mojom::TagAttachResult::New();
+
+  const base::Value* result = response.Find("result");
+  const base::DictValue* dict =
+      (result && result->is_dict()) ? &result->GetDict() : nullptr;
+  if (!dict) {
+    if (const base::Value* err = response.Find("error");
+        err && err->is_dict()) {
+      if (const std::string* msg = err->GetDict().FindString("message")) {
+        out->error = *msg;
+      } else {
+        out->error = "sidecar error";
+      }
+    } else {
+      out->error = "no response";
+    }
+    return out;
+  }
+
+  out->ok = dict->FindBool("ok").value_or(false);
+  if (const std::string* err = dict->FindString("error")) {
+    out->error = *err;
+  }
+  return out;
+}
+
+}  // namespace
+
+SlayzoneTagsHost::SlayzoneTagsHost() = default;
+SlayzoneTagsHost::~SlayzoneTagsHost() = default;
+
+void SlayzoneTagsHost::Bind(
+    mojo::PendingReceiver<tags::mojom::TagsHost> receiver) {
+  receivers_.Add(this, std::move(receiver));
+}
+
+void SlayzoneTagsHost::GetTags(GetTagsCallback callback) {
+  SidecarClient::GetInstance()->Call(
+      "tags:list", base::DictValue(),
+      base::BindOnce(
+          [](GetTagsCallback cb, base::DictValue response) {
+            std::move(cb).Run(TagsFromListResponse(response));
+          },
+          std::move(callback)));
+}
+
+void SlayzoneTagsHost::GetTagsForTask(const std::string& task_id,
+                                      GetTagsForTaskCallback callback) {
+  base::DictValue params;
+  params.Set("taskId", task_id);
+  SidecarClient::GetInstance()->Call(
+      "tags:for-task", std::move(params),
+      base::BindOnce(
+          [](GetTagsForTaskCallback cb, base::DictValue response) {
+            std::move(cb).Run(TagsFromListResponse(response));
+          },
+          std::move(callback)));
+}
+
+void SlayzoneTagsHost::CreateTag(const std::string& name,
+                                  const std::string& color,
+                                  CreateTagCallback callback) {
+  base::DictValue params;
+  params.Set("name", name);
+  params.Set("color", color);
+  SidecarClient::GetInstance()->Call(
+      "tags:create", std::move(params),
+      base::BindOnce(
+          [](CreateTagCallback cb, base::DictValue response) {
+            std::move(cb).Run(WriteResultFromResponse(response));
+          },
+          std::move(callback)));
+}
+
+void SlayzoneTagsHost::UpdateTag(const std::string& id,
+                                  const std::string& name,
+                                  const std::string& color,
+                                  UpdateTagCallback callback) {
+  base::DictValue params;
+  params.Set("id", id);
+  params.Set("name", name);
+  params.Set("color", color);
+  SidecarClient::GetInstance()->Call(
+      "tags:update", std::move(params),
+      base::BindOnce(
+          [](UpdateTagCallback cb, base::DictValue response) {
+            std::move(cb).Run(WriteResultFromResponse(response));
+          },
+          std::move(callback)));
+}
+
+void SlayzoneTagsHost::DeleteTag(const std::string& id,
+                                  DeleteTagCallback callback) {
+  base::DictValue params;
+  params.Set("id", id);
+  SidecarClient::GetInstance()->Call(
+      "tags:delete", std::move(params),
+      base::BindOnce(
+          [](DeleteTagCallback cb, base::DictValue response) {
+            std::move(cb).Run(WriteResultFromResponse(response));
+          },
+          std::move(callback)));
+}
+
+void SlayzoneTagsHost::AttachTag(const std::string& task_id,
+                                  const std::string& tag_id,
+                                  AttachTagCallback callback) {
+  base::DictValue params;
+  params.Set("taskId", task_id);
+  params.Set("tagId", tag_id);
+  SidecarClient::GetInstance()->Call(
+      "tags:attach", std::move(params),
+      base::BindOnce(
+          [](AttachTagCallback cb, base::DictValue response) {
+            std::move(cb).Run(AttachResultFromResponse(response));
+          },
+          std::move(callback)));
+}
+
+void SlayzoneTagsHost::DetachTag(const std::string& task_id,
+                                  const std::string& tag_id,
+                                  DetachTagCallback callback) {
+  base::DictValue params;
+  params.Set("taskId", task_id);
+  params.Set("tagId", tag_id);
+  SidecarClient::GetInstance()->Call(
+      "tags:detach", std::move(params),
+      base::BindOnce(
+          [](DetachTagCallback cb, base::DictValue response) {
+            std::move(cb).Run(AttachResultFromResponse(response));
+          },
+          std::move(callback)));
+}
+
+}  // namespace slayzone
