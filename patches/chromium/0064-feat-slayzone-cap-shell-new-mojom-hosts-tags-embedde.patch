+namespace slayzone {
+
+// cap-shell-5 — aux-window multiplexer.
+//
+// Process-global singleton; every SlayzoneShellUI's BindInterface routes to
+// the same instance so window_ids are globally unique across the app (a
+// collapsed floating-agent icon spawned from the main shell can later be
+// Close()'d by a sibling shell's renderer using the same id). Matches the
+// Electron model where a single main process owned every BrowserWindow.
+//
+// Each Open() spawns one top-level views::Widget that hosts a views::WebView
+// pointed at chrome://slayzone-shell/<url_fragment>. The shell bundle's
+// main.tsx reads the hash + search params to mount the aux React root
+// (FloatingAgentPanel / Splash / LeaderboardPage). Z-order / frame / taskbar
+// behavior is driven by AuxWindowType + the OpenParams flags.
+//
+// Observer broadcast: one RemoteSet<WindowsObserver> receives every lifecycle
+// + message event. Any renderer that Subscribe()s gets the full stream; the
+// renderer filters by window_id client-side. This lets a detached floating
+// agent and the main shell coordinate via SendMessage without a bespoke pipe
+// per feature.
+class SlayzoneWindowsHost : public slayzone::windows::mojom::WindowsHost {
+ public:
+  // Singleton accessor. The instance is created lazily on first call and
+  // never destroyed (base::NoDestructor). Profile is captured on first
+  // Open() — single-profile assumption, matches the Electron build.
+  static SlayzoneWindowsHost* GetInstance();
+
+  SlayzoneWindowsHost(const SlayzoneWindowsHost&) = delete;
+  SlayzoneWindowsHost& operator=(const SlayzoneWindowsHost&) = delete;
+
+  // Accept a new receiver. `caller_wc` is the WebContents that made the bind
+  // request — used by CloseCurrentWindow() to resolve the caller's top-level
+  // views::Widget. May be null in teardown races; CloseCurrentWindow
+  // becomes a no-op in that case.
+  void Bind(
+      mojo::PendingReceiver<slayzone::windows::mojom::WindowsHost> receiver,
+      content::WebContents* caller_wc);
+
+  // slayzone::windows::mojom::WindowsHost:
+  void Open(slayzone::windows::mojom::OpenParamsPtr params,
+            OpenCallback callback) override;
+  void Close(const std::string& window_id) override;
+  void Focus(const std::string& window_id) override;
+  void SetBounds(const std::string& window_id,
+                 slayzone::windows::mojom::WindowBoundsPtr bounds) override;
+  void SetVisible(const std::string& window_id, bool visible) override;
+  void CloseCurrentWindow() override;
+  void SendMessage(const std::string& window_id,
+                   const std::string& json) override;
+  void Subscribe(mojo::PendingRemote<slayzone::windows::mojom::WindowsObserver>
+                     observer) override;
+
+  // AuxWindow-side callbacks. Public so the AuxWindow inner class in the .cc
+  // can forward widget-observer events without friending.
+  void OnAuxWindowClosed(const std::string& window_id);
+  void OnAuxWindowFocused(const std::string& window_id, bool focused);
+  void OnAuxWindowBoundsChanged(const std::string& window_id,
+                                 const gfx::Rect& bounds);
+
+ private:
+  friend class base::NoDestructor<SlayzoneWindowsHost>;
+  class AuxWindow;
+
+  SlayzoneWindowsHost();
+  ~SlayzoneWindowsHost() override;
+
+  // Context-per-receiver: the caller's WebContents, used only by
+  // CloseCurrentWindow to find the caller's top-level Widget. Stored via
+  // mojo::ReceiverSet context so disconnect automatically clears it.
+  content::WebContents* CurrentContextWebContents();
+
+  AuxWindow* FindAuxWindow(const std::string& window_id);
+
+  // The first Open() captures this; subsequent Opens re-use it. Chromium's
+  // views::WebView(profile) constructor creates its own WebContents in the
+  // given profile's StoragePartition so aux windows share cookies / IndexedDB
+  // with the main shell WebUI.
+  raw_ptr<Profile> profile_ = nullptr;
+
+  std::map<std::string, std::unique_ptr<AuxWindow>> windows_;
+
+  mojo::ReceiverSet<slayzone::windows::mojom::WindowsHost,
+                     base::WeakPtr<content::WebContents>>
+      receivers_;
+  mojo::RemoteSet<slayzone::windows::mojom::WindowsObserver> observers_;
+
+  base::WeakPtrFactory<SlayzoneWindowsHost> weak_factory_{this};
+};
+
+}  // namespace slayzone
+
+#endif  // CHROME_BROWSER_SLAYZONE_SLAYZONE_WINDOWS_HOST_H_
