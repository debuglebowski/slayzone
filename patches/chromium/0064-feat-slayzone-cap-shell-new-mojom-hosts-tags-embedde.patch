+// cap-06 tags domain data contract (in-tree mirror).
+// Source of truth: packages/shared/mojo-bindings/mojom/tags.mojom.
+// Keep diff-identical below the module line.
+
+module slayzone.tags.mojom;
+
+struct Tag {
+  string id;
+  string name;
+  string color;
+};
+
+struct TagWriteResult {
+  bool ok;
+  string error;
+  Tag tag;
+};
+
+struct TagAttachResult {
+  bool ok;
+  string error;
+};
+
+interface TagsHost {
+  GetTags() => (array<Tag> tags);
+  GetTagsForTask(string task_id) => (array<Tag> tags);
+  CreateTag(string name, string color) => (TagWriteResult result);
+  UpdateTag(string id, string name, string color) => (TagWriteResult result);
+  DeleteTag(string id) => (TagWriteResult result);
+  AttachTag(string task_id, string tag_id) => (TagAttachResult result);
+  DetachTag(string task_id, string tag_id) => (TagAttachResult result);
+};
diff --git a/chrome/browser/slayzone/mojom/windows.mojom b/chrome/browser/slayzone/mojom/windows.mojom
new file mode 100644
index 0000000000000..59203f324054e
--- /dev/null
+++ b/chrome/browser/slayzone/mojom/windows.mojom
@@ -0,0 +1,143 @@
+// cap-shell-5 aux-window contract.
+//
+// Scope note: lives in packages/shared/mojo-bindings/ as the outer
+// source-of-truth; the in-tree copy at
+// chrome/browser/slayzone/mojom/windows.mojom is what Chromium's mojom()
+// target compiles to C++. scripts/generate.ts regenerates TS bindings from
+// this file. The two must stay diff-identical below the module line.
+//
+// Background: the Electron build spawned BrowserWindows directly from the
+// main process for splash, floating-agent, and (future) leaderboard popout.
+// Chromium has no main process — so each aux window is a standalone
+// views::Widget owned by SlayzoneWindowsHost, each hosting a views::WebView
+// that navigates back to chrome://slayzone-shell/ with a hash that tells the
+// renderer-side main.tsx dispatcher which aux React root to mount.
+//
+// Renderer keys every call on a caller-supplied window_id string. The host
+// rejects duplicate ids (you must Close() first). OnOpened / OnClosed /
+// OnFocused / OnBoundsChanged fire on the single shared observer pipe that
+// every renderer in every window can Subscribe() to — so a collapsed icon
+// in window A can react to bounds changes in window B if needed.
+//
+// SendMessage(window_id, json) is the cross-window bus: the host forwards
+// via OnMessage(window_id, json) to every subscribed observer, letting the
+// shim re-implement Electron's main-process state-machine patterns
+// (floating-agent session redirect, etc.) client-side in the renderer that
+// owns that state.
+
+module slayzone.windows.mojom;
+
+// Closed set of aux-window types the host knows how to spawn. Each maps to a
+// specific views::Widget InitParams shape + default bounds. Kept closed so
+// typos from the renderer surface as an enum-decode failure rather than a
+// misconfigured window on screen.
+enum AuxWindowType {
+  // Modeless centered top-level, no taskbar, frameless. Used for the boot
+  // splash screen — lifetime usually a few seconds until the main shell
+  // bundle signals data-ready.
+  kSplash = 0,
+
+  // Always-on-top frameless panel; z_order = kFloatingWindow so it floats
+  // above the main SlayZone window but below OS overlays (notifications,
+  // Mission Control). Used for the detached agent widget.
+  kFloatingAgent = 1,
+
+  // Regular top-level window — user-resizable, appears in taskbar. Used for
+  // the leaderboard popout (not wired in the current Electron build but the
+  // primitive exists so renderer-side popouts land here instead of the
+  // inline overlay path).
+  kLeaderboard = 2,
+
+  // Escape hatch — caller-supplied bounds, normal window type, no special
+  // z-order. Lets future callers spawn one-off aux windows without a new
+  // enum landing per use case.
+  kGeneric = 3,
+};
+
+struct WindowBounds {
+  int32 x;
+  int32 y;
+  int32 width;
+  int32 height;
+};
+
+struct OpenParams {
+  AuxWindowType type;
+
+  // Renderer-supplied stable id. Host rejects Open() if the id already
+  // refers to a live window. Close() frees the id for reuse.
+  string window_id;
+
+  // Appended to chrome://slayzone-shell/ after the hash. The shell bundle's
+  // main.tsx reads window.location.hash + search params to pick the aux
+  // React root (FloatingAgentPanel / Splash / LeaderboardPage).
+  string url_fragment;
+
+  // Initial bounds in screen coordinates. The host clamps nothing — bounds
+  // outside the primary display will render off-screen. width/height of 0
+  // uses a type-specific default.
+  WindowBounds bounds;
+
+  // Frameless flag. Mirrors Electron's `frame: false`. Orthogonal to the
+  // type — a leaderboard could be frameless, a floating-agent framed, if a
+  // caller wants it.
+  bool frameless;
+
+  // Skip OS taskbar. Default for Splash / FloatingAgent in the Electron
+  // build; leaderboard keeps taskbar visibility.
+  bool skip_taskbar;
+
+  // Whether to Show() (focus-stealing) vs ShowInactive() (keeps current
+  // focus) on initial open. The Electron floating agent used showInactive
+  // to avoid triggering its own reattach via did-become-active.
+  bool activate_on_show;
+};
+
+interface WindowsHost {
+  // Spawn a new aux window. Returns ok=false with a diagnostic `error` if:
+  //   - window_id already refers to a live window
+  //   - the host's SlayzoneShellUI is torn down (teardown race)
+  //   - url_fragment fails GURL parse
+  // The renderer's main.tsx mounts the aux React root on navigation commit;
+  // wait for OnOpened before assuming the aux window can receive SendMessage
+  // traffic.
+  Open(OpenParams params) => (bool ok, string error);
+
+  // Close the named window. No-op on unknown id.
+  Close(string window_id);
+
+  // Bring the window to the front + activate it. No-op on unknown id.
+  Focus(string window_id);
+
+  // Reposition / resize in screen coordinates. No-op on unknown id.
+  SetBounds(string window_id, WindowBounds bounds);
+
+  // Show / hide without destroy. Re-showing preserves the last SetBounds
+  // rect (Chromium restores position). No-op on unknown id.
+  SetVisible(string window_id, bool visible);
+
+  // Close the *caller's* top-level window. Lets the main shell's
+  // `window.api.window.close()` still work without needing a caller id.
+  // No-op if the caller is not hosted in a top-level Chromium window (e.g.
+  // embedded dialog WebContents).
+  CloseCurrentWindow();
+
+  // Broadcast an opaque JSON blob to every subscribed observer, tagged with
+  // window_id. The renderer is responsible for routing to the correct
+  // handler. Used by the floating-agent shim to send state updates between
+  // the main window and the detached agent without re-binding a dedicated
+  // observer pipe per feature.
+  SendMessage(string window_id, string json);
+
+  // Install / replace the single observer remote for this WindowsHost
+  // instance. One observer per shell UI; all events dispatch to it.
+  Subscribe(pending_remote<WindowsObserver> observer);
+};
+
+interface WindowsObserver {
+  OnOpened(string window_id);
+  OnClosed(string window_id);
+  OnFocused(string window_id, bool focused);
+  OnBoundsChanged(string window_id, WindowBounds bounds);
+  OnMessage(string window_id, string json);
+};
diff --git a/chrome/browser/slayzone/slayzone_embedded_tab_host.cc b/chrome/browser/slayzone/slayzone_embedded_tab_host.cc
new file mode 100644
index 0000000000000..7d5cbfa3281b3
--- /dev/null
+++ b/chrome/browser/slayzone/slayzone_embedded_tab_host.cc
@@ -0,0 +1,449 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/slayzone/slayzone_embedded_tab_host.h"
+
+#include <algorithm>
+#include <utility>
+
+#include "base/logging.h"
+#include "base/strings/string_number_conversions.h"
+#include "base/strings/utf_string_conversions.h"
+#include "chrome/browser/devtools/devtools_window.h"
+#include "chrome/browser/ui/views/frame/slayzone_shell_container.h"
+#include "content/public/browser/browser_context.h"
+#include "content/public/browser/navigation_controller.h"
+#include "content/public/browser/navigation_entry.h"
+#include "content/public/browser/page.h"
+#include "content/public/browser/web_contents.h"
+#include "content/public/browser/web_contents_observer.h"
+#include "content/public/common/referrer.h"
+#include "net/base/net_errors.h"
+#include "ui/base/page_transition_types.h"
+#include "url/gurl.h"
+
+namespace slayzone {
+
+namespace {
+
+// Convert the mojom-side bounds struct into the views-side gfx::Rect. The
+// bounds struct is kept Chromium-import-free in the outer mojom (see
+// embedded_tab.mojom) so conversion happens at the C++ edge.
+gfx::Rect ToRect(
+    const slayzone::embedded_tab::mojom::EmbeddedTabBoundsPtr& bounds) {
+  if (!bounds) {
+    return gfx::Rect();
+  }
+  return gfx::Rect(bounds->x, bounds->y,
+                   std::max(0, bounds->width), std::max(0, bounds->height));
+}
+
+}  // namespace
+
+// Each Entry owns one content::WebContents + forwards WebContentsObserver
+// events to the parent host's mojo observer. Entries live inside entries_ —
+// erasing the unique_ptr destroys the WebContents and unregisters the
+// observer in one step.
+class SlayzoneEmbeddedTabHost::Entry : public content::WebContentsObserver {
+ public:
+  Entry(SlayzoneEmbeddedTabHost* host,
+        const std::string& view_id,
+        const std::string& task_id,
+        std::unique_ptr<content::WebContents> contents)
+      : host_(host),
+        view_id_(view_id),
+        task_id_(task_id),
+        contents_(std::move(contents)) {
+    Observe(contents_.get());
+  }
+
+  ~Entry() override = default;
+
+  content::WebContents* contents() { return contents_.get(); }
+  const std::string& view_id() const { return view_id_; }
+  const std::string& task_id() const { return task_id_; }
+
+  // content::WebContentsObserver:
+  void TitleWasSet(content::NavigationEntry* entry) override {
+    if (!entry) {
+      return;
+    }
+    host_->FirePageTitleUpdated(view_id_,
+                                 base::UTF16ToUTF8(entry->GetTitle()));
+  }
+
+  void PrimaryPageChanged(content::Page& /*page*/) override {
+    if (!contents_) {
+      return;
+    }
+    auto& controller = contents_->GetController();
+    host_->FireDidNavigate(view_id_,
+                            contents_->GetLastCommittedURL().possibly_invalid_spec(),
+                            controller.CanGoBack(),
+                            controller.CanGoForward());
+  }
+
+  void DidStartLoading() override {
+    host_->FireDidStartLoading(view_id_);
+  }
+
+  void DidStopLoading() override {
+    host_->FireDidStopLoading(view_id_);
+  }
+
+  void DOMContentLoaded(content::RenderFrameHost* render_frame_host) override {
+    // Only care about the outermost main frame — subframe / fenced-frame DOM
+    // events aren't what the renderer gates hasLoadedRealPage on.
+    if (render_frame_host && render_frame_host->GetParent() == nullptr) {
+      host_->FireDomReady(view_id_);
+    }
+  }
+
+  void DidFailLoad(content::RenderFrameHost* render_frame_host,
+                   const GURL& validated_url,
+                   int error_code) override {
+    if (render_frame_host && render_frame_host->GetParent() != nullptr) {
+      return;
+    }
+    host_->FireDidFailLoad(view_id_, error_code,
+                            net::ErrorToShortString(error_code),
+                            validated_url.possibly_invalid_spec());
+  }
+
+ private:
+  raw_ptr<SlayzoneEmbeddedTabHost> host_;
+  std::string view_id_;
+  std::string task_id_;
+  std::unique_ptr<content::WebContents> contents_;
+};
+
+SlayzoneEmbeddedTabHost::SlayzoneEmbeddedTabHost(
+    content::BrowserContext* browser_context,
+    SlayzoneShellContainer* container)
+    : browser_context_(browser_context), container_(container) {}
+
+SlayzoneEmbeddedTabHost::~SlayzoneEmbeddedTabHost() {
+  // Detach from the container before entries_ unwinds so the WebView slot
+  // doesn't hold a pointer to a WebContents we're about to destroy.
+  if (container_) {
+    container_->SetEmbeddedTabWebContents(nullptr);
+    container_->SetEmbeddedTabVisible(false);
+  }
+}
+
+void SlayzoneEmbeddedTabHost::Bind(
+    mojo::PendingReceiver<slayzone::embedded_tab::mojom::EmbeddedTabHost>
+        receiver) {
+  receiver_.reset();
+  receiver_.Bind(std::move(receiver));
+}
+
+void SlayzoneEmbeddedTabHost::CreateView(
+    slayzone::embedded_tab::mojom::CreateViewParamsPtr params,
+    CreateViewCallback callback) {
+  LOG(INFO) << "[embedded_tab] CreateView task=" << params->task_id
+            << " tab=" << params->tab_id << " url='" << params->url
+            << "' bounds=" << (params->bounds ? params->bounds->width : 0)
+            << "x" << (params->bounds ? params->bounds->height : 0)
+            << " visible=" << params->visible
+            << " container=" << (container_ ? "yes" : "NULL")
+            << " browser_context=" << (browser_context_ ? "yes" : "NULL");
+  if (!browser_context_ || !container_) {
+    LOG(WARNING) << "[embedded_tab] CreateView aborted — missing "
+                 << (!browser_context_ ? "browser_context" : "container");
+    std::move(callback).Run(std::string());
+    return;
+  }
+
+  content::WebContents::CreateParams create_params(browser_context_);
+  std::unique_ptr<content::WebContents> contents =
+      content::WebContents::Create(create_params);
+  if (!contents) {
+    std::move(callback).Run(std::string());
+    return;
+  }
+
+  GURL url(params->url.empty() ? std::string("about:blank") : params->url);
+  if (!url.is_valid()) {
+    url = GURL("about:blank");
+  }
+  content::NavigationController::LoadURLParams load_params(url);
+  load_params.transition_type = ui::PAGE_TRANSITION_AUTO_TOPLEVEL;
+  contents->GetController().LoadURLWithParams(load_params);
+
+  const std::string view_id = "etab-" + base::NumberToString(next_id_++);
+  auto entry = std::make_unique<Entry>(this, view_id, params->task_id,
+                                        std::move(contents));
+  entries_.emplace(view_id, std::move(entry));
+  lru_.push_back(view_id);
+
+  active_bounds_ = ToRect(params->bounds);
+  active_visible_ = params->visible;
+  SetActiveViewId(view_id);
+  EvictIfOverCap();
+
+  LOG(INFO) << "[embedded_tab] CreateView resolved view_id=" << view_id
+            << " loaded=" << url.possibly_invalid_spec();
+  std::move(callback).Run(view_id);
+}
+
+void SlayzoneEmbeddedTabHost::DestroyView(const std::string& view_id) {
+  auto it = entries_.find(view_id);
+  if (it == entries_.end()) {
+    return;
+  }
+  const bool was_active = (view_id == active_view_id_);
+  entries_.erase(it);
+  lru_.remove(view_id);
+  if (was_active) {
+    SetActiveViewId(std::string());
+  }
+}
+
+void SlayzoneEmbeddedTabHost::DestroyAllForTask(const std::string& task_id) {
+  // Collect first so we don't mutate while iterating.
+  std::vector<std::string> to_destroy;
+  for (auto& [view_id, entry] : entries_) {
+    if (entry->task_id() == task_id) {
+      to_destroy.push_back(view_id);
+    }
+  }
+  for (const std::string& view_id : to_destroy) {
+    DestroyView(view_id);
+  }
+}
+
+void SlayzoneEmbeddedTabHost::SetBounds(
+    const std::string& view_id,
+    slayzone::embedded_tab::mojom::EmbeddedTabBoundsPtr bounds) {
+  Entry* entry = FindEntry(view_id);
+  if (!entry) {
+    return;
+  }
+  const gfx::Rect rect = ToRect(bounds);
+  // Only the active view's bounds influence the overlay. The renderer stops
+  // the rAF loop when a view hides, so non-active SetBounds would be a bug —
+  // treat it as an implicit switch-to-active request.
+  if (view_id != active_view_id_) {
+    active_bounds_ = rect;
+    active_visible_ = true;
+    SetActiveViewId(view_id);
+    return;
+  }
+  active_bounds_ = rect;
+  RefreshContainer();
+}
+
+void SlayzoneEmbeddedTabHost::SetVisible(const std::string& view_id,
+                                          bool visible) {
+  Entry* entry = FindEntry(view_id);
+  if (!entry) {
+    return;
+  }
+  if (view_id != active_view_id_) {
+    // Renderer asked us to show a non-active view: swap to it.
+    if (visible) {
+      active_visible_ = true;
+      SetActiveViewId(view_id);
+    }
+    return;
+  }
+  active_visible_ = visible;
+  RefreshContainer();
+}
+
+void SlayzoneEmbeddedTabHost::Navigate(const std::string& view_id,
+                                        const std::string& url) {
+  LOG(INFO) << "[embedded_tab] Navigate view_id=" << view_id << " url='"
+            << url << "' entries=" << entries_.size()
+            << " active=" << active_view_id_;
+  Entry* entry = FindEntry(view_id);
+  if (!entry) {
+    LOG(WARNING) << "[embedded_tab] Navigate dropped — unknown view_id="
+                 << view_id;
+    return;
+  }
+  GURL gurl(url);
+  if (!gurl.is_valid()) {
+    LOG(WARNING) << "[embedded_tab] Navigate dropped — invalid url='" << url
+                 << "'";
+    return;
+  }
+  content::NavigationController::LoadURLParams params(gurl);
+  params.transition_type = ui::PAGE_TRANSITION_TYPED;
+  entry->contents()->GetController().LoadURLWithParams(params);
+  TouchLru(view_id);
+}
+
+void SlayzoneEmbeddedTabHost::GoBack(const std::string& view_id) {
+  Entry* entry = FindEntry(view_id);
+  if (!entry) {
+    return;
+  }
+  auto& controller = entry->contents()->GetController();
+  if (controller.CanGoBack()) {
+    controller.GoBack();
+    TouchLru(view_id);
+  }
+}
+
+void SlayzoneEmbeddedTabHost::GoForward(const std::string& view_id) {
+  Entry* entry = FindEntry(view_id);
+  if (!entry) {
+    return;
+  }
+  auto& controller = entry->contents()->GetController();
+  if (controller.CanGoForward()) {
+    controller.GoForward();
+    TouchLru(view_id);
+  }
+}
+
+void SlayzoneEmbeddedTabHost::Reload(const std::string& view_id,
+                                      bool ignore_cache) {
+  Entry* entry = FindEntry(view_id);
+  if (!entry) {
+    return;
+  }
+  entry->contents()->GetController().Reload(
+      ignore_cache ? content::ReloadType::BYPASSING_CACHE
+                   : content::ReloadType::NORMAL,
+      /*check_for_repost=*/true);
+  TouchLru(view_id);
+}
+
+void SlayzoneEmbeddedTabHost::Stop(const std::string& view_id) {
+  Entry* entry = FindEntry(view_id);
+  if (!entry) {
+    return;
+  }
+  entry->contents()->Stop();
+}
+
+void SlayzoneEmbeddedTabHost::Focus(const std::string& view_id) {
+  Entry* entry = FindEntry(view_id);
+  if (!entry) {
+    return;
+  }
+  entry->contents()->Focus();
+  TouchLru(view_id);
+}
+
+void SlayzoneEmbeddedTabHost::ToggleDevtools(const std::string& view_id) {
+  Entry* entry = FindEntry(view_id);
+  if (!entry) {
+    return;
+  }
+  DevToolsWindow::OpenDevToolsWindow(entry->contents(),
+                                      DevToolsToggleAction::Toggle(),
+                                      DevToolsOpenedByAction::kUnknown);
+}
+
+void SlayzoneEmbeddedTabHost::Subscribe(
+    mojo::PendingRemote<slayzone::embedded_tab::mojom::EmbeddedTabObserver>
+        observer) {
+  observer_.reset();
+  observer_.Bind(std::move(observer));
+}
+
+void SlayzoneEmbeddedTabHost::FireDidNavigate(const std::string& view_id,
+                                                const std::string& url,
+                                                bool can_go_back,
+                                                bool can_go_forward) {
+  if (observer_) {
+    observer_->OnDidNavigate(view_id, url, can_go_back, can_go_forward);
+  }
+}
+
+void SlayzoneEmbeddedTabHost::FirePageTitleUpdated(const std::string& view_id,
+                                                     const std::string& title) {
+  if (observer_) {
+    observer_->OnPageTitleUpdated(view_id, title);
+  }
+}
+
+void SlayzoneEmbeddedTabHost::FireDidStartLoading(const std::string& view_id) {
+  if (observer_) {
+    observer_->OnDidStartLoading(view_id);
+  }
+}
+
+void SlayzoneEmbeddedTabHost::FireDidStopLoading(const std::string& view_id) {
+  if (observer_) {
+    observer_->OnDidStopLoading(view_id);
+  }
+}
+
+void SlayzoneEmbeddedTabHost::FireDomReady(const std::string& view_id) {
+  if (observer_) {
+    observer_->OnDomReady(view_id);
+  }
+}
+
+void SlayzoneEmbeddedTabHost::FireDidFailLoad(
+    const std::string& view_id,
+    int32_t error_code,
+    const std::string& error_description,
+    const std::string& url) {
+  if (observer_) {
+    observer_->OnDidFailLoad(view_id, error_code, error_description, url);
+  }
+}
+
+SlayzoneEmbeddedTabHost::Entry* SlayzoneEmbeddedTabHost::FindEntry(
+    const std::string& view_id) {
+  auto it = entries_.find(view_id);
+  return it == entries_.end() ? nullptr : it->second.get();
+}
+
+void SlayzoneEmbeddedTabHost::TouchLru(const std::string& view_id) {
+  lru_.remove(view_id);
+  lru_.push_back(view_id);
+}
+
+void SlayzoneEmbeddedTabHost::EvictIfOverCap() {
+  while (entries_.size() > kLruCap && lru_.size() > 1) {
+    // Front = least recent, skip past active if for some reason it's there.
+    std::string victim = lru_.front();
+    if (victim == active_view_id_) {
+      // Shouldn't happen — active is kept at the back — but guard anyway.
+      auto it = std::next(lru_.begin());
+      if (it == lru_.end()) {
+        break;
+      }
+      victim = *it;
+      lru_.erase(it);
+    } else {
+      lru_.pop_front();
+    }
+    entries_.erase(victim);
+  }
+}
+
+void SlayzoneEmbeddedTabHost::SetActiveViewId(const std::string& view_id) {
+  if (view_id == active_view_id_) {
+    RefreshContainer();
+    return;
+  }
+  active_view_id_ = view_id;
+  if (!active_view_id_.empty()) {
+    TouchLru(active_view_id_);
+  }
+  if (container_) {
+    Entry* entry = FindEntry(active_view_id_);
+    container_->SetEmbeddedTabWebContents(entry ? entry->contents() : nullptr);
+  }
+  RefreshContainer();
+}
+
+void SlayzoneEmbeddedTabHost::RefreshContainer() {
+  if (!container_) {
+    return;
+  }
+  const bool has_active = !active_view_id_.empty();
+  container_->SetEmbeddedTabBounds(active_bounds_);
+  container_->SetEmbeddedTabVisible(has_active && active_visible_);
+}
+
+}  // namespace slayzone
