@@ -0,0 +1,150 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/slayzone/slayzone_native_dialog_host.h"
+
+#include <algorithm>
+#include <string>
+#include <string_view>
+#include <utility>
+#include <vector>
+
+#include "base/files/file_path.h"
+#include "base/strings/utf_string_conversions.h"
+#include "chrome/browser/ui/select_file_policy/chrome_select_file_policy.h"
+#include "content/public/browser/web_contents.h"
+#include "ui/shell_dialogs/select_file_dialog.h"
+#include "ui/shell_dialogs/selected_file_info.h"
+
+namespace slayzone {
+
+namespace {
+
+bool ContainsProperty(const std::vector<std::string>& properties,
+                      std::string_view needle) {
+  return std::find(properties.begin(), properties.end(), needle) !=
+         properties.end();
+}
+
+ui::SelectFileDialog::Type ChooseDialogType(
+    const std::vector<std::string>& properties) {
+  if (ContainsProperty(properties, "openDirectory")) {
+    return ui::SelectFileDialog::SELECT_FOLDER;
+  }
+  if (ContainsProperty(properties, "multiSelections")) {
+    return ui::SelectFileDialog::SELECT_OPEN_MULTI_FILE;
+  }
+  return ui::SelectFileDialog::SELECT_OPEN_FILE;
+}
+
+}  // namespace
+
+SlayzoneNativeDialogHost::SlayzoneNativeDialogHost(
+    content::WebContents* web_contents)
+    : web_contents_(web_contents) {}
+
+SlayzoneNativeDialogHost::~SlayzoneNativeDialogHost() {
+  // Drop the dangling SelectFileDialog listener pointer so a late callback
+  // after teardown is a no-op. (The refptr release below will cancel on
+  // most platforms, but we also want the listener cleared explicitly.)
+  if (select_file_dialog_) {
+    select_file_dialog_->ListenerDestroyed();
+    select_file_dialog_.reset();
+  }
+  // If a call was still in flight, the response must fire so the renderer's
+  // pending promise doesn't hang on teardown.
+  if (pending_callback_) {
+    auto result = slayzone::dialog::mojom::ShowOpenDialogResult::New();
+    result->canceled = true;
+    std::move(pending_callback_).Run(std::move(result));
+  }
+}
+
+void SlayzoneNativeDialogHost::Bind(
+    mojo::PendingReceiver<slayzone::dialog::mojom::NativeDialogHost> receiver) {
+  receivers_.Add(this, std::move(receiver));
+}
+
+void SlayzoneNativeDialogHost::ShowOpenDialog(
+    slayzone::dialog::mojom::ShowOpenDialogOptionsPtr options,
+    ShowOpenDialogCallback callback) {
+  // Serial-only: if a picker is already up, short-circuit the new call with
+  // canceled=true. Electron's contract permits serial invocation; matching
+  // that is simpler than queueing and is what every other Chromium
+  // SelectFileDialog user does.
+  if (pending_callback_ || select_file_dialog_) {
+    auto result = slayzone::dialog::mojom::ShowOpenDialogResult::New();
+    result->canceled = true;
+    std::move(callback).Run(std::move(result));
+    return;
+  }
+
+  if (!web_contents_) {
+    auto result = slayzone::dialog::mojom::ShowOpenDialogResult::New();
+    result->canceled = true;
+    std::move(callback).Run(std::move(result));
+    return;
+  }
+
+  pending_callback_ = std::move(callback);
+
+  select_file_dialog_ = ui::SelectFileDialog::Create(
+      this, std::make_unique<ChromeSelectFilePolicy>(web_contents_));
+
+  const ui::SelectFileDialog::Type type = ChooseDialogType(options->properties);
+
+  const base::FilePath default_path =
+      options->default_path.empty()
+          ? base::FilePath()
+          : base::FilePath::FromUTF8Unsafe(options->default_path);
+
+  const std::u16string title = options->title.empty()
+                                   ? std::u16string()
+                                   : base::UTF8ToUTF16(options->title);
+
+  ui::SelectFileDialog::FileTypeInfo file_type_info;
+  file_type_info.allowed_paths =
+      ui::SelectFileDialog::FileTypeInfo::NATIVE_PATH;
+
+  select_file_dialog_->SelectFile(
+      type, title, default_path, &file_type_info, /*file_type_index=*/0,
+      /*default_extension=*/base::FilePath::StringType(),
+      web_contents_->GetTopLevelNativeWindow(),
+      /*params=*/nullptr);
+}
+
+void SlayzoneNativeDialogHost::FileSelected(const ui::SelectedFileInfo& file,
+                                            int /*index*/) {
+  auto result = slayzone::dialog::mojom::ShowOpenDialogResult::New();
+  result->canceled = false;
+  result->file_paths.push_back(file.path().AsUTF8Unsafe());
+  select_file_dialog_.reset();
+  if (pending_callback_) {
+    std::move(pending_callback_).Run(std::move(result));
+  }
+}
+
+void SlayzoneNativeDialogHost::MultiFilesSelected(
+    const std::vector<ui::SelectedFileInfo>& files) {
+  auto result = slayzone::dialog::mojom::ShowOpenDialogResult::New();
+  result->canceled = false;
+  for (const auto& f : files) {
+    result->file_paths.push_back(f.path().AsUTF8Unsafe());
+  }
+  select_file_dialog_.reset();
+  if (pending_callback_) {
+    std::move(pending_callback_).Run(std::move(result));
+  }
+}
+
+void SlayzoneNativeDialogHost::FileSelectionCanceled() {
+  auto result = slayzone::dialog::mojom::ShowOpenDialogResult::New();
+  result->canceled = true;
+  select_file_dialog_.reset();
+  if (pending_callback_) {
+    std::move(pending_callback_).Run(std::move(result));
+  }
+}
+
+}  // namespace slayzone
