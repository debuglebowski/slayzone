+void SlayzoneBrowserView::RegisterOverlayAccelerators() {
+  // cap-03 — Cmd+K opens the search overlay; ESC closes the active overlay
+  // (and restores prior mode via SlayzoneLayoutHost::ShowOverlay("")). ESC
+  // is left registered even when no overlay is active — `AcceleratorPressed`
+  // falls through to the base handler in that case so upstream shortcut
+  // behavior (e.g. clear find bar) still works.
+  AddAccelerator(ui::Accelerator(ui::VKEY_K, ui::EF_COMMAND_DOWN));
+  AddAccelerator(ui::Accelerator(ui::VKEY_ESCAPE, ui::EF_NONE));
+}
+
 bool SlayzoneBrowserView::AcceleratorPressed(
     const ui::Accelerator& accelerator) {
   if (accelerator.modifiers() == ui::EF_COMMAND_DOWN &&
@@ -220,6 +237,21 @@ bool SlayzoneBrowserView::AcceleratorPressed(
       }
     }
   }
+  // cap-03 — Cmd+K opens the search overlay regardless of prior state.
+  if (layout_host_ && accelerator.modifiers() == ui::EF_COMMAND_DOWN &&
+      accelerator.key_code() == ui::VKEY_K) {
+    layout_host_->ShowOverlay("search", base::DoNothing());
+    return true;
+  }
+  // cap-03 — ESC closes the active overlay and restores prior mode. Fall
+  // through to the base handler when no overlay is active so upstream
+  // handlers (find bar, full screen, etc.) still see the key.
+  if (accelerator.key_code() == ui::VKEY_ESCAPE &&
+      accelerator.modifiers() == ui::EF_NONE && layout_host_ &&
+      layout_mode_ == LayoutMode::kOverlay) {
+    layout_host_->ShowOverlay(std::string(), base::DoNothing());
+    return true;
+  }
   return BrowserView::AcceleratorPressed(accelerator);
 }
 
@@ -238,7 +270,45 @@ void SlayzoneBrowserView::OnTabStripModelChanged(
   if (selection.active_tab_changed() ||
       change.type() != TabStripModelChange::kSelectionOnly) {
     SyncInlineTabWebView();
+    // cap-03 — the active tab's URL drives LayoutMode. When an overlay is
+    // up we don't evict it on a tab switch; instead we update `prior_mode_`
+    // so ESC restores to the newly-selected tab's mode. The CLI flag path
+    // still applies at AddedToWidget and wins over the initial tab (orders
+    // the harness's explicit choice above the URL-derived fallback).
+    SyncLayoutModeToActiveTab();
+  }
+}
+
+void SlayzoneBrowserView::SyncLayoutModeToActiveTab() {
+  content::WebContents* active =
+      browser()->tab_strip_model()->GetActiveWebContents();
+  if (!active) {
+    return;
+  }
+  const slayzone::tabs::mojom::TabType tab_type =
+      SlayzoneTabsHost::ClassifyUrl(active->GetVisibleURL());
+  LayoutMode target = LayoutMode::kTaskDetail;
+  switch (tab_type) {
+    case slayzone::tabs::mojom::TabType::kHome:
+      target = LayoutMode::kHome;
+      break;
+    case slayzone::tabs::mojom::TabType::kOverlay:
+      target = LayoutMode::kOverlay;
+      break;
+    case slayzone::tabs::mojom::TabType::kTaskDetail:
+    case slayzone::tabs::mojom::TabType::kAux:
+      target = LayoutMode::kTaskDetail;
+      break;
+  }
+  if (layout_mode_ == LayoutMode::kOverlay &&
+      target != LayoutMode::kOverlay) {
+    // Overlay is on top — keep it, but update prior_mode_ so the ESC/close
+    // path lands on the newly-selected tab's mode rather than the tab that
+    // was active when the overlay opened.
+    prior_mode_ = target;
+    return;
   }
+  SetLayoutMode(target);
 }
 
