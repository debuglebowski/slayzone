diff --git a/chrome/browser/slayzone/slayzone_overlay_manager.cc b/chrome/browser/slayzone/slayzone_overlay_manager.cc
new file mode 100644
index 0000000000000..0540fcb5a6832
--- /dev/null
+++ b/chrome/browser/slayzone/slayzone_overlay_manager.cc
@@ -0,0 +1,90 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/slayzone/slayzone_overlay_manager.h"
+
+#include <algorithm>
+#include <memory>
+#include <string>
+#include <utility>
+
+#include "base/strings/strcat.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/browser/ui/browser.h"
+#include "chrome/browser/ui/views/frame/slayzone_browser_view.h"
+#include "ui/views/controls/webview/webview.h"
+#include "ui/views/view.h"
+#include "url/gurl.h"
+
+namespace slayzone {
+
+SlayzoneOverlayManager::SlayzoneOverlayManager(SlayzoneBrowserView* view)
+    : view_(view) {
+  bounds_observer_.Observe(view_);
+}
+
+SlayzoneOverlayManager::~SlayzoneOverlayManager() = default;
+
+bool SlayzoneOverlayManager::SetOverlay(std::string_view overlay_id) {
+  // Empty id = close overlay. Hide the WebView if present; leave the
+  // underlying region grid / home panel alone so whatever was visible
+  // before simply re-emerges.
+  if (overlay_id.empty()) {
+    if (overlay_webview_) {
+      overlay_webview_->SetVisible(false);
+    }
+    active_overlay_.clear();
+    return true;
+  }
+
+  const bool known = std::any_of(
+      kOverlayIds.begin(), kOverlayIds.end(),
+      [overlay_id](std::string_view known_id) {
+        return known_id == overlay_id;
+      });
+  if (!known) {
+    return false;
+  }
+
+  EnsureWebView();
+
+  const std::string url =
+      base::StrCat({"chrome://slayzone-", overlay_id, "/"});
+  overlay_webview_->LoadInitialURL(GURL(url));
+  overlay_webview_->SetBoundsRect(view_->GetContentsBounds());
+  // Keep overlay at the top of the z-order so it paints over the region
+  // grid + any home-panel WebView that may be active underneath.
+  view_->ReorderChildView(overlay_webview_, -1);
+  overlay_webview_->SetVisible(true);
+  active_overlay_ = std::string(overlay_id);
+  return true;
+}
+
+void SlayzoneOverlayManager::OnViewBoundsChanged(views::View* observed_view) {
+  if (observed_view != view_.get() || !overlay_webview_) {
+    return;
+  }
+  overlay_webview_->SetBoundsRect(view_->GetContentsBounds());
+}
+
+void SlayzoneOverlayManager::OnViewIsDeleting(views::View* observed_view) {
+  if (observed_view == view_.get()) {
+    bounds_observer_.Reset();
+    overlay_webview_ = nullptr;
+    view_ = nullptr;
+  }
+}
+
+void SlayzoneOverlayManager::EnsureWebView() {
+  if (overlay_webview_ || !view_) {
+    return;
+  }
+  auto webview_owned =
+      std::make_unique<views::WebView>(view_->browser()->profile());
+  overlay_webview_ = view_->AddChildView(std::move(webview_owned));
+  overlay_webview_->SetBoundsRect(view_->GetContentsBounds());
+  overlay_webview_->SetVisible(false);
+}
+
+}  // namespace slayzone
