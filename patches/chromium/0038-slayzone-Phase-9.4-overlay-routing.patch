new file mode 100644
index 0000000000000..9f9fb77eb35bd
--- /dev/null
+++ b/chrome/browser/slayzone/slayzone_overlay_manager.h
@@ -0,0 +1,80 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_SLAYZONE_SLAYZONE_OVERLAY_MANAGER_H_
+#define CHROME_BROWSER_SLAYZONE_SLAYZONE_OVERLAY_MANAGER_H_
+
+#include <array>
+#include <string>
+#include <string_view>
+
+#include "base/memory/raw_ptr.h"
+#include "base/scoped_observation.h"
+#include "ui/views/view_observer.h"
+
+class SlayzoneBrowserView;
+
+namespace views {
+class View;
+class WebView;
+}  // namespace views
+
+namespace slayzone {
+
+// Phase 9.4 — lazily manages a single full-window overlay WebView that
+// covers SlayzoneBrowserView's content area. Owned by SlayzoneLayoutHost
+// and constructed eagerly in its ctor (cheap; the underlying WebView is
+// lazy — not created until the first `SetOverlay(known_id)` call).
+//
+// Architectural note: this class intentionally parents its WebView as a
+// child of `SlayzoneBrowserView` via the public `views::View::AddChildView`
+// API and tracks resize via a `views::ViewObserver` on the BrowserView.
+// There are NO edits to `slayzone_browser_view.{h,cc}` — the Phase 7 R3
+// terminal-slot work is still in flight in that file per orchestrator
+// directive, and Phase 9.4 must ship without coordinating bounds tracking
+// into `OnBoundsChanged`. ESC-to-close + dev --slayzone-overlay=<id> CLI
+// switch are deferred to a follow-up that can touch BrowserView.
+class SlayzoneOverlayManager : public views::ViewObserver {
+ public:
+  // Allowlist — overlay IDs accepted by `SetOverlay`. Typos reject rather
+  // than silently loading a bogus chrome://slayzone-<id>/.
+  static constexpr std::array<std::string_view, 3> kOverlayIds = {
+      "leaderboard",
+      "usage",
+      "context",
+  };
+
+  explicit SlayzoneOverlayManager(SlayzoneBrowserView* view);
+  SlayzoneOverlayManager(const SlayzoneOverlayManager&) = delete;
+  SlayzoneOverlayManager& operator=(const SlayzoneOverlayManager&) = delete;
+  ~SlayzoneOverlayManager() override;
+
+  // Swap into the given overlay. An empty `overlay_id` closes the active
+  // overlay (overlay WebView is hidden; the region grid / home panel
+  // underneath remains visible exactly as before). `overlay_id` must be in
+  // `kOverlayIds`; unknown ids return `false` with no state change.
+  bool SetOverlay(std::string_view overlay_id);
+
+  // Currently active overlay id, empty if none.
+  const std::string& active_overlay() const { return active_overlay_; }
+
+  // views::ViewObserver:
+  void OnViewBoundsChanged(views::View* observed_view) override;
+  void OnViewIsDeleting(views::View* observed_view) override;
+
+ private:
+  // Ensures `overlay_webview_` is created + parented + bounds-tracked.
+  // No-op when already present.
+  void EnsureWebView();
+
+  raw_ptr<SlayzoneBrowserView> view_;
+  raw_ptr<views::WebView> overlay_webview_ = nullptr;
+  std::string active_overlay_;
+  base::ScopedObservation<views::View, views::ViewObserver> bounds_observer_{
+      this};
+};
+
+}  // namespace slayzone
+
+#endif  // CHROME_BROWSER_SLAYZONE_SLAYZONE_OVERLAY_MANAGER_H_
