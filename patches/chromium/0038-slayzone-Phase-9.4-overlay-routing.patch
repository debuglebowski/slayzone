+void SlayzoneLayoutHost::ShowOverlay(const std::string& overlay_id,
+                                     ShowOverlayCallback callback) {
+  // Empty overlay_id = close overlay; allowed ids live on
+  // SlayzoneOverlayManager::kOverlayIds. Returning false here leaves the UI
+  // in its current mode so the caller can render an inline error.
+  if (!overlay_manager_) {
+    std::move(callback).Run(false);
+    return;
+  }
+  std::move(callback).Run(overlay_manager_->SetOverlay(overlay_id));
+}
