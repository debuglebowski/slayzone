diff --git a/chrome/browser/ui/views/frame/slayzone_browser_view.h b/chrome/browser/ui/views/frame/slayzone_browser_view.h
new file mode 100644
index 0000000000000..9e4de9367fdd3
--- /dev/null
+++ b/chrome/browser/ui/views/frame/slayzone_browser_view.h
@@ -0,0 +1,29 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_UI_VIEWS_FRAME_SLAYZONE_BROWSER_VIEW_H_
+#define CHROME_BROWSER_UI_VIEWS_FRAME_SLAYZONE_BROWSER_VIEW_H_
+
+#include "chrome/browser/ui/views/frame/browser_view.h"
+#include "ui/base/metadata/metadata_header_macros.h"
+
+class Browser;
+
+// Phase 5 native layout shell. Hosts the SlayZone region grid in place of the
+// upstream tabbed browser chrome. Gated on `slayzone::kSlayzoneLayoutShell`
+// via `browser_window_factory.cc`.
+//
+// Phase 5.1 ships an empty scaffold (no visible change). Phase 5.2 adds the
+// region container + placeholder WebUIs.
+class SlayzoneBrowserView : public BrowserView {
+  METADATA_HEADER(SlayzoneBrowserView, BrowserView)
+
+ public:
+  explicit SlayzoneBrowserView(Browser* browser);
+  SlayzoneBrowserView(const SlayzoneBrowserView&) = delete;
+  SlayzoneBrowserView& operator=(const SlayzoneBrowserView&) = delete;
+  ~SlayzoneBrowserView() override;
+};
+
+#endif  // CHROME_BROWSER_UI_VIEWS_FRAME_SLAYZONE_BROWSER_VIEW_H_
