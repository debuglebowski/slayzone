@@ -50,7 +52,11 @@ BrowserWindow::CreateBrowserWindow(Browser* browser,
 #if BUILDFLAG(IS_CHROMEOS)
   view = new BrowserViewAsh(browser);
 #else
-  view = new BrowserView(browser);
+  if (slayzone::IsLayoutShellEnabled() && browser->is_type_normal()) {
+    view = new SlayzoneBrowserView(browser);
+  } else {
+    view = new BrowserView(browser);
+  }
 #endif
   auto browser_widget = std::make_unique<BrowserWidget>(view);
   view->set_browser_widget(std::move(browser_widget));
