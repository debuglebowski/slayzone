 chrome/browser/slayzone/layout_features.cc    | 17 +++++++++++
 chrome/browser/slayzone/layout_features.h     | 21 ++++++++++++++
 chrome/browser/ui/BUILD.gn                    |  2 ++
 .../ui/views/frame/browser_window_factory.cc  |  8 ++++-
 .../ui/views/frame/slayzone_browser_view.cc   | 15 ++++++++++
 .../ui/views/frame/slayzone_browser_view.h    | 29 +++++++++++++++++++
 7 files changed, 93 insertions(+), 1 deletion(-)
