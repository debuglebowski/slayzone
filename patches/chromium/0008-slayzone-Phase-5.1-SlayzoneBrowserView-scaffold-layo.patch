diff --git a/chrome/browser/slayzone/layout_features.h b/chrome/browser/slayzone/layout_features.h
new file mode 100644
index 0000000000000..527a9dcbcbeba
--- /dev/null
+++ b/chrome/browser/slayzone/layout_features.h
@@ -0,0 +1,21 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_SLAYZONE_LAYOUT_FEATURES_H_
+#define CHROME_BROWSER_SLAYZONE_LAYOUT_FEATURES_H_
+
+#include "base/feature_list.h"
+
+namespace slayzone {
+
+// Gates the Phase 5 native layout shell (`SlayzoneBrowserView` subclass +
+// region grid). Default-on; flip off to fall back to upstream `BrowserView`
+// for A/B and bisect.
+BASE_DECLARE_FEATURE(kSlayzoneLayoutShell);
+
+bool IsLayoutShellEnabled();
+
+}  // namespace slayzone
+
+#endif  // CHROME_BROWSER_SLAYZONE_LAYOUT_FEATURES_H_
