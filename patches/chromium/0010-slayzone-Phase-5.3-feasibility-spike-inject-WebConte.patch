@@ -6,6 +6,7 @@
 #define CHROME_BROWSER_UI_VIEWS_FRAME_SLAYZONE_BROWSER_VIEW_H_
 
 #include "base/memory/raw_ptr.h"
+#include "base/memory/weak_ptr.h"
 #include "chrome/browser/ui/views/frame/browser_view.h"
 #include "ui/base/metadata/metadata_header_macros.h"
 #include "ui/gfx/geometry/rect.h"
@@ -17,11 +18,10 @@ class SlayzoneRegionContainer;
 // upstream tabbed browser chrome. Gated on `slayzone::kSlayzoneLayoutShell`
 // via `browser_window_factory.cc`.
 //
-// Phase 5.2 installs the 10-slot placeholder grid. Upstream toolbar/tabstrip/
-// infobar/side-panel children are collapsed to zero via `SetVisible(false)`;
-// `BrowserViewLayout` skips invisible children. The region container is
-// positioned in `OnBoundsChanged` because it is not one of the views
-// `BrowserViewLayout` knows about.
+// Phase 5.2 installs the 10-slot placeholder grid as a later sibling of the
+// upstream BrowserView children, overlaying the tabstrip/toolbar/contents in
+// paint order. Phase 5.3 wires the feasibility spike that injects a live
+// WebContents into the terminal slot via command-line flag.
 class SlayzoneBrowserView : public BrowserView {
   METADATA_HEADER(SlayzoneBrowserView, BrowserView)
 
@@ -40,7 +40,14 @@ class SlayzoneBrowserView : public BrowserView {
   void OnBoundsChanged(const gfx::Rect& previous_bounds) override;
 
  private:
+  // Phase 5.3 feasibility spike. If the `--slayzone-spike-url` switch is
+  // present, navigate the active tab's WebContents to the spike URL and drop
+  // it into the terminal region slot. Deferred to a PostTask because the
+  // active tab is not guaranteed to exist at AddedToWidget time.
+  void MaybeSpikeTerminalSlot();
+
   raw_ptr<SlayzoneRegionContainer> region_container_ = nullptr;
+  base::WeakPtrFactory<SlayzoneBrowserView> weak_factory_{this};
 };
 
 #endif  // CHROME_BROWSER_UI_VIEWS_FRAME_SLAYZONE_BROWSER_VIEW_H_
