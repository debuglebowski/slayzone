+#ifndef CHROME_BROWSER_UI_WEBUI_SLAYZONE_SLAYZONE_WEBUI_REGISTRY_H_
+#define CHROME_BROWSER_UI_WEBUI_SLAYZONE_SLAYZONE_WEBUI_REGISTRY_H_
+
+namespace content {
+class WebUIConfigMap;
+}
+
+namespace slayzone {
+
+// Single entry point that registers every chrome://slayzone-*/ WebUI with the
+// browser's WebUIConfigMap. Called from RegisterChromeWebUIConfigs() once per
+// browser process. Every Phase 5+ region lands a WebUIConfig here; this keeps
+// the Chromium diff surface to a single call in chrome_web_ui_configs.cc.
+void RegisterSlayzoneWebUIConfigs(content::WebUIConfigMap& map);
+
+}  // namespace slayzone
