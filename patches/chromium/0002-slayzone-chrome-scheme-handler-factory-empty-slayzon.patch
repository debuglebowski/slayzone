+// found in the LICENSE file.
+
+#include "chrome/browser/ui/webui/slayzone/slayzone_webui_registry.h"
+
+#include <memory>
+#include <string>
+#include <string_view>
+
+#include "base/functional/bind.h"
+#include "base/memory/ref_counted_memory.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/common/webui_url_constants.h"
+#include "content/public/browser/web_ui.h"
+#include "content/public/browser/web_ui_controller.h"
+#include "content/public/browser/web_ui_data_source.h"
+#include "content/public/browser/webui_config.h"
+#include "content/public/browser/webui_config_map.h"
+#include "content/public/common/url_constants.h"
+
+namespace slayzone {
+namespace {
+
+// Empty shell WebUI. Phase 2.5 points chrome://newtab/ at this host; later
+// phases replace the inline body with the real Shell region (Phase 7.1).
+// Served via SetRequestFilter so Phase 2 stays decoupled from the grit pipe;
+// Phase 4/7 switches this to generated resources alongside every region.
+constexpr std::string_view kShellHtml = R"HTML(<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <title>SlayZone</title>
+  <style>:root { color-scheme: light dark; } body { margin: 0; }</style>
+</head>
+<body></body>
+</html>)HTML";
+
+bool ShouldHandleShellRequest(const std::string& path) {
+  return path.empty();
+}
+
+void HandleShellRequest(const std::string& path,
+                        content::WebUIDataSource::GotDataCallback callback) {
+  std::move(callback).Run(base::MakeRefCounted<base::RefCountedString>(
+      std::string(kShellHtml)));
+}
+
+class ShellUI : public content::WebUIController {
+ public:
+  explicit ShellUI(content::WebUI* web_ui) : content::WebUIController(web_ui) {
+    auto* source = content::WebUIDataSource::CreateAndAdd(
+        Profile::FromWebUI(web_ui), chrome::kChromeUISlayzoneShellHost);
+    source->SetRequestFilter(base::BindRepeating(&ShouldHandleShellRequest),
+                             base::BindRepeating(&HandleShellRequest));
+  }
+
+  ShellUI(const ShellUI&) = delete;
+  ShellUI& operator=(const ShellUI&) = delete;
+  ~ShellUI() override = default;
+};
+
+class ShellUIConfig : public content::DefaultWebUIConfig<ShellUI> {
+ public:
+  ShellUIConfig()
+      : DefaultWebUIConfig(content::kChromeUIScheme,
+                           chrome::kChromeUISlayzoneShellHost) {}
+};
+
+}  // namespace
+
+void RegisterSlayzoneWebUIConfigs(content::WebUIConfigMap& map) {
+  map.AddWebUIConfig(std::make_unique<ShellUIConfig>());
+}
+
+}  // namespace slayzone
