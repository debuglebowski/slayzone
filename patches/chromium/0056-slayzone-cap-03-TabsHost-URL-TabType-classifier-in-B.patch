+// cap-03 — static URL → TabType classifier, shared with
+// SlayzoneBrowserView so its TabStripModel observer can derive the same
+// mapping without a Mojo round-trip.
+slayzone::tabs::mojom::TabType SlayzoneTabsHost::ClassifyUrl(const GURL& url) {
+  if (url.is_empty() || url.spec() == "about:blank") {
+    return slayzone::tabs::mojom::TabType::kHome;
+  }
+  if (url.SchemeIs("chrome")) {
+    const std::string host = url.host();
+    if (host == "newtab") {
+      return slayzone::tabs::mojom::TabType::kHome;
+    }
+    if (host == "slayzone-leaderboard" || host == "slayzone-usage" ||
+        host == "slayzone-context" || host == "slayzone-dialogs") {
+      return slayzone::tabs::mojom::TabType::kOverlay;
+    }
+    if (host.rfind("slayzone-", 0) == 0) {
+      return slayzone::tabs::mojom::TabType::kAux;
+    }
+  }
+  return slayzone::tabs::mojom::TabType::kTaskDetail;
+}
