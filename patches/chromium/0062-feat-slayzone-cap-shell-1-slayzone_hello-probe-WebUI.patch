+// Copyright 2026 The Chromium Authors (SlayZone fork)
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_UI_WEBUI_SLAYZONE_HELLO_HELLO_UI_H_
+#define CHROME_BROWSER_UI_WEBUI_SLAYZONE_HELLO_HELLO_UI_H_
+
+#include "chrome/common/webui_url_constants.h"
+#include "content/public/browser/web_ui_controller.h"
+#include "content/public/browser/webui_config.h"
+#include "content/public/common/url_constants.h"
+
+// Phase 1 smoke-test WebUI: chrome://hello/.
+// Serves a static HTML page with one button + a JS counter. Its sole purpose
+// is to prove the full build → sign → launch → custom scheme → JS chain works
+// before the real SlayZone WebUI regions land in later phases. Phase 2.2
+// replaces this one-off registration with a generic scheme handler factory.
+
+class HelloUI;
+
+class HelloUIConfig : public content::DefaultWebUIConfig<HelloUI> {
+ public:
+  HelloUIConfig()
+      : DefaultWebUIConfig(content::kChromeUIScheme,
+                           chrome::kChromeUIHelloHost) {}
+};
+
+class HelloUI : public content::WebUIController {
+ public:
+  explicit HelloUI(content::WebUI* web_ui);
+
+  HelloUI(const HelloUI&) = delete;
+  HelloUI& operator=(const HelloUI&) = delete;
+
+  ~HelloUI() override;
+};
+
+#endif  // CHROME_BROWSER_UI_WEBUI_SLAYZONE_HELLO_HELLO_UI_H_
