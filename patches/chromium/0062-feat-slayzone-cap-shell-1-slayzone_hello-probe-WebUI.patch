+// Copyright 2026 The Chromium Authors (SlayZone fork)
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/ui/webui/slayzone_hello/hello_ui.h"
+
+#include <string>
+#include <string_view>
+
+#include "base/functional/bind.h"
+#include "base/memory/ref_counted_memory.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/common/webui_url_constants.h"
+#include "content/public/browser/web_ui.h"
+#include "content/public/browser/web_ui_data_source.h"
+#include "services/network/public/mojom/content_security_policy.mojom.h"
+
+namespace {
+
+// Inline resources. Kept in the .cc so the smoke-test has zero coupling to
+// the grit resource pipeline — Phase 2.2 migrates this to generated resources
+// alongside every other chrome:// WebUI.
+constexpr std::string_view kHelloHtml = R"HTML(<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <title>chrome://hello/</title>
+  <style>
+    :root { color-scheme: light dark; }
+    body {
+      font: 14px system-ui, -apple-system, sans-serif;
+      max-width: 480px;
+      margin: 48px auto;
+      padding: 0 24px;
+    }
+    h1 { font-size: 20px; margin: 0 0 16px; }
+    p  { margin: 0 0 24px;
+         color: color-mix(in srgb, currentColor 70%, transparent); }
+    button {
+      font: inherit;
+      padding: 8px 16px;
+      border: 1px solid color-mix(in srgb, currentColor 30%, transparent);
+      border-radius: 6px;
+      background: transparent;
+      color: inherit;
+      cursor: pointer;
+    }
+    button:hover {
+      background: color-mix(in srgb, currentColor 10%, transparent);
+    }
+    #counter { margin-left: 12px; font-variant-numeric: tabular-nums; }
+  </style>
+</head>
+<body>
+  <h1>chrome://hello/</h1>
+  <p>SlayZone Chromium fork &mdash; Phase 1 smoke test.</p>
+  <button id="tick">Tick</button>
+  <span id="counter" aria-live="polite">0</span>
+  <script src="hello.js"></script>
+</body>
+</html>)HTML";
+
+constexpr std::string_view kHelloJs = R"JS((() => {
+  const btn = document.getElementById('tick');
+  const out = document.getElementById('counter');
+  let n = 0;
+  btn.addEventListener('click', () => {
+    n += 1;
+    out.textContent = String(n);
+  });
+})();
+)JS";
+
+bool ShouldHandleHelloRequest(const std::string& path) {
+  return path.empty() || path == "hello.js";
+}
+
+void HandleHelloRequest(const std::string& path,
+                        content::WebUIDataSource::GotDataCallback callback) {
+  std::string_view body = path == "hello.js" ? kHelloJs : kHelloHtml;
+  std::move(callback).Run(
+      base::MakeRefCounted<base::RefCountedString>(std::string(body)));
+}
+
+}  // namespace
+
+HelloUI::HelloUI(content::WebUI* web_ui) : content::WebUIController(web_ui) {
+  auto* source = content::WebUIDataSource::CreateAndAdd(
+      Profile::FromWebUI(web_ui), chrome::kChromeUIHelloHost);
+
+  // Allow the inline-ish hello.js script tag. Default Chromium WebUI CSP
+  // blocks non-resource scripts; we serve hello.js via SetRequestFilter
+  // below, but script-src still needs `self` permitted explicitly.
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::ScriptSrc,
+      "script-src chrome://resources 'self';");
+
+  source->SetRequestFilter(base::BindRepeating(&ShouldHandleHelloRequest),
+                           base::BindRepeating(&HandleHelloRequest));
+}
+
+HelloUI::~HelloUI() = default;
