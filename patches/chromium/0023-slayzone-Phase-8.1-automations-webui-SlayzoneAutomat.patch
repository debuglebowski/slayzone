+namespace {
+
+constexpr std::string_view kAutomationsMissingBundleHtml =
+    R"HTML(<!doctype html>
+<html lang="en">
+<head>
+  <meta charset="utf-8">
+  <title>SlayZone · automations</title>
+  <style>
+    :root { color-scheme: light dark; }
+    html, body { margin: 0; height: 100%; font: 11px/1.3 system-ui, sans-serif; }
+    body {
+      display: flex; align-items: center; padding: 0 10px;
+      background: #3a1a1a; color: #fca5a5;
+      border-left: 1px solid #6b2020;
+    }
+  </style>
+</head>
+<body>
+  <span>automations: bundle missing — pass --slayzone-webui-bundle-dir=&lt;repo&gt;/packages/webui</span>
+</body>
+</html>)HTML";
+
+}  // namespace
+
+SlayzoneAutomationsUI::SlayzoneAutomationsUI(content::WebUI* web_ui)
+    : content::WebUIController(web_ui) {
+  auto* source = content::WebUIDataSource::CreateAndAdd(
+      Profile::FromWebUI(web_ui), chrome::kChromeUISlayzoneAutomationsHost);
+  slayzone::ConfigureBundleSource(source, "automations",
+                                  kAutomationsMissingBundleHtml);
+}
+
+SlayzoneAutomationsUI::~SlayzoneAutomationsUI() = default;
+
+WEB_UI_CONTROLLER_TYPE_IMPL(SlayzoneAutomationsUI)
+
+void SlayzoneAutomationsUI::BindInterface(
+    mojo::PendingReceiver<slayzone::automations::mojom::AutomationsHost>
+        receiver) {
+  SlayzoneBrowserView* view =
+      SlayzoneBrowserView::FromRegionWebContents(web_ui()->GetWebContents());
+  if (!view || !view->automations_host()) {
+    return;
+  }
+  view->automations_host()->Bind(std::move(receiver));
+}
