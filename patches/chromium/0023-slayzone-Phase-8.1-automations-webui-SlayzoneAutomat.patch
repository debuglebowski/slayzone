+#ifndef CHROME_BROWSER_SLAYZONE_SLAYZONE_AUTOMATIONS_HOST_H_
+#define CHROME_BROWSER_SLAYZONE_SLAYZONE_AUTOMATIONS_HOST_H_
+
+#include <string>
+
+#include "chrome/browser/slayzone/mojom/automations.mojom.h"
+#include "mojo/public/cpp/bindings/pending_receiver.h"
+#include "mojo/public/cpp/bindings/receiver_set.h"
+
+namespace slayzone {
+
+// Phase 8.1 — browser-side implementation of
+// `slayzone::automations::mojom::AutomationsHost`. One instance per
+// `SlayzoneBrowserView`. Forwards to the process-wide `SidecarClient` via
+// JSON-RPC methods `automations:get-snapshot` and `automations:toggle`.
+// The sidecar keeps the authoritative list + enabled flags in-process;
+// real domain wire-up (packages/domains/automations) lands in a later
+// phase — surface stays stable.
+class SlayzoneAutomationsHost
+    : public slayzone::automations::mojom::AutomationsHost {
+ public:
+  SlayzoneAutomationsHost();
+  SlayzoneAutomationsHost(const SlayzoneAutomationsHost&) = delete;
+  SlayzoneAutomationsHost& operator=(const SlayzoneAutomationsHost&) = delete;
+  ~SlayzoneAutomationsHost() override;
+
+  void Bind(
+      mojo::PendingReceiver<slayzone::automations::mojom::AutomationsHost>
+          receiver);
+
+  // slayzone::automations::mojom::AutomationsHost:
+  void GetSnapshot(GetSnapshotCallback callback) override;
+  void ToggleAutomation(const std::string& id,
+                        bool enabled,
+                        ToggleAutomationCallback callback) override;
+
+ private:
+  mojo::ReceiverSet<slayzone::automations::mojom::AutomationsHost> receivers_;
+};
+
+}  // namespace slayzone
+
+#endif  // CHROME_BROWSER_SLAYZONE_SLAYZONE_AUTOMATIONS_HOST_H_
