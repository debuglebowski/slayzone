diff --git a/chrome/browser/slayzone/mojom/automations.mojom b/chrome/browser/slayzone/mojom/automations.mojom
new file mode 100644
index 0000000000000..861a36fe83995
--- /dev/null
+++ b/chrome/browser/slayzone/mojom/automations.mojom
@@ -0,0 +1,24 @@
+// Phase 8.1 automations region data contract (in-tree mirror).
+// Source of truth: packages/shared/mojo-bindings/mojom/automations.mojom.
+// Keep diff-identical below the module line.
+
+module slayzone.automations.mojom;
+
+struct Automation {
+  string id;
+  string name;
+  string description;
+  bool enabled;
+  string trigger_type;
+  int32 run_count;
+};
+
+struct AutomationsSnapshot {
+  string active_project_id;
+  array<Automation> automations;
+};
+
+interface AutomationsHost {
+  GetSnapshot() => (AutomationsSnapshot snapshot);
+  ToggleAutomation(string id, bool enabled) => (AutomationsSnapshot snapshot);
+};
diff --git a/chrome/browser/slayzone/slayzone_automations_host.cc b/chrome/browser/slayzone/slayzone_automations_host.cc
new file mode 100644
index 0000000000000..6fde5f744dbb1
--- /dev/null
+++ b/chrome/browser/slayzone/slayzone_automations_host.cc
@@ -0,0 +1,105 @@
+// Copyright 2026 The SlayZone Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/slayzone/slayzone_automations_host.h"
+
+#include <string>
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "base/values.h"
+#include "chrome/browser/slayzone/sidecar_client.h"
+
+namespace slayzone {
+
+namespace {
+
+// Translate the sidecar's JSON response into a Mojo snapshot. Missing fields
+// fall back to neutral defaults so the region can still render a frame even
+// when the sidecar is handshaking or mid-reconnect.
+automations::mojom::AutomationsSnapshotPtr FromDict(
+    const base::DictValue& response) {
+  auto snapshot = automations::mojom::AutomationsSnapshot::New();
+  const base::Value* result = response.Find("result");
+  const base::DictValue* dict =
+      (result && result->is_dict()) ? &result->GetDict() : nullptr;
+  if (!dict) {
+    return snapshot;
+  }
+
+  if (const std::string* active = dict->FindString("activeProjectId")) {
+    snapshot->active_project_id = *active;
+  }
+
+  const base::ListValue* list = dict->FindList("automations");
+  if (list) {
+    for (const base::Value& entry : *list) {
+      if (!entry.is_dict()) {
+        continue;
+      }
+      const base::DictValue& e = entry.GetDict();
+      auto automation = automations::mojom::Automation::New();
+      if (const std::string* id = e.FindString("id")) {
+        automation->id = *id;
+      }
+      if (const std::string* name = e.FindString("name")) {
+        automation->name = *name;
+      }
+      if (const std::string* desc = e.FindString("description")) {
+        automation->description = *desc;
+      }
+      automation->enabled = e.FindBool("enabled").value_or(false);
+      if (const std::string* trig = e.FindString("triggerType")) {
+        automation->trigger_type = *trig;
+      }
+      automation->run_count = e.FindInt("runCount").value_or(0);
+      snapshot->automations.push_back(std::move(automation));
+    }
+  }
+
+  return snapshot;
+}
+
+}  // namespace
+
+SlayzoneAutomationsHost::SlayzoneAutomationsHost() = default;
+SlayzoneAutomationsHost::~SlayzoneAutomationsHost() = default;
+
+void SlayzoneAutomationsHost::Bind(
+    mojo::PendingReceiver<automations::mojom::AutomationsHost> receiver) {
+  receivers_.Add(this, std::move(receiver));
+}
+
+void SlayzoneAutomationsHost::GetSnapshot(GetSnapshotCallback callback) {
+  SidecarClient::GetInstance()->Call(
+      "automations:get-snapshot", base::DictValue(),
+      base::BindOnce(
+          [](GetSnapshotCallback cb, base::DictValue response) {
+            std::move(cb).Run(FromDict(response));
+          },
+          std::move(callback)));
+}
+
+void SlayzoneAutomationsHost::ToggleAutomation(
+    const std::string& id,
+    bool enabled,
+    ToggleAutomationCallback callback) {
+  // JSON-RPC positional params: [id, enabled]. base::ListValue per the
+  // Phase 7.x hotfix (patch 0022) — base::Value::List does not exist at
+  // Chromium 148.0.7778.40's dict API surface.
+  base::ListValue params;
+  params.Append(id);
+  params.Append(enabled);
+  base::DictValue request;
+  request.Set("params", std::move(params));
+  SidecarClient::GetInstance()->Call(
+      "automations:toggle", std::move(request),
+      base::BindOnce(
+          [](ToggleAutomationCallback cb, base::DictValue response) {
+            std::move(cb).Run(FromDict(response));
+          },
+          std::move(callback)));
+}
+
+}  // namespace slayzone
