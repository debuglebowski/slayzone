{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/**/*",
    "src/**/*.tsx",
    "../../renderer-app/src/env.d.ts",
    "../../shared/types/src/txn-registry.d.ts",
    "../../shared/mojo-bindings/src/runtime/bindings-shim.ts",
    "../../shared/mojo-bindings/src/ambient.d.ts"
  ],
  "compilerOptions": {
    "composite": false,
    "jsx": "react-jsx",
    "types": ["vite/client", "node"],
    "paths": {
      "@/*": ["../../renderer-app/src/*"],
      "convex/_generated/*": ["../../../convex/_generated/*"],
      "//resources/mojo/mojo/public/js/bindings.js": [
        "../../shared/mojo-bindings/src/runtime/bindings-shim.ts"
      ]
    }
  }
}

