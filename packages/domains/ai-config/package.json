{
  "name": "@slayzone/ai-config",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./shared": "./src/shared/index.ts",
    "./main": "./src/main/index.ts",
    "./client": "./src/client/index.ts"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "test:skill-validation": "node --import tsx src/client/skill-validation.test.ts",
    "test:handlers": "ELECTRON_RUN_AS_NODE=1 npx electron --import tsx/esm --loader ../../shared/test-utils/loader.ts src/main/handlers.context.test.ts",
    "test:frontmatter": "pnpm run test:skill-validation && pnpm run test:handlers"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@slayzone/file-editor": "workspace:*",
    "@slayzone/ui": "workspace:*",
    "@xyflow/react": "^12.10.2",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.562.0",
    "zustand": "^5.0.0"
  },
  "peerDependencies": {
    "electron": "^41.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  }
}
