// Phase 8.3 test region data contract.
//
// Scope note: this .mojom lives in packages/shared/mojo-bindings/ (Phase 4.3
// territory) as a coordinated exception, following the 5.6 / 6.1 / 7.x /
// 8.1 / 8.2 pattern. The in-tree mirror at
// chrome/browser/slayzone/mojom/test.mojom is what Chromium's mojom()
// target compiles to C++; Phase 4.3 regenerates TS bindings from this outer
// file. The two must stay diff-identical below the module line.
//
// The test region is the home-tab panel listing discovered test files with
// their last-run status per category. Scope simplification: labels / notes
// / tree-grouping land in Phase 17 polish; scan RPC + settings dialog are
// Phase 8.5 / Phase 10 respectively. 8.3 renders a flat category + file
// list read-only.

module slayzone.test.mojom;

// One discovered test file. `category` matches a TestCategory.id; `status`
// is a string enum: "passing" | "failing" | "skipped" | "unknown".
struct TestFile {
  string path;
  string category;
  string status;
  int32 duration_ms;  // -1 when never run
};

// A category bucket for the rail header — e.g. "Unit", "E2E", "Smoke".
struct TestCategory {
  string id;
  string label;
  int32 file_count;
};

// Full panel state. `active_project_id` is empty when no project selected.
// `last_scan_at` is empty when the project has never been scanned.
struct TestSnapshot {
  string active_project_id;
  string last_scan_at;
  array<TestCategory> categories;
  array<TestFile> files;
};

// Browser-side test-panel data provider. One remote per region WebUI.
// 8.3 is read-only; rescan / settings / run-single-file wire up in 8.5 /
// Phase 10.
interface TestHost {
  GetSnapshot() => (TestSnapshot snapshot);
};
