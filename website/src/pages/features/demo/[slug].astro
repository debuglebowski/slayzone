---
import { features, findFeatureBySlug } from '../../../data/features.js'
import { loadLegacySegments } from '../../../lib/legacy.js'

export function getStaticPaths() {
  return features.map((feature) => ({
    params: { slug: feature.slug },
  }))
}

const feature = findFeatureBySlug(Astro.params.slug)

if (!feature) {
  throw new Error(`Unknown feature slug: ${Astro.params.slug}`)
}

const { styles, bodyHtml, scripts } = loadLegacySegments('features.html')
const scopedCss = `
  html, body {
    margin: 0 !important;
    padding: 0 !important;
    background: transparent !important;
    overflow: hidden !important;
  }
  .container {
    max-width: none !important;
    min-height: 0 !important;
    padding: 0 !important;
  }
  nav,
  .page-header,
  footer,
  .feature-text {
    display: none !important;
  }
  .features-list {
    margin: 0 !important;
  }
  .feature-section {
    display: none !important;
    opacity: 1 !important;
    transform: none !important;
  }
  #${feature.legacyId} {
    display: grid !important;
    grid-template-columns: 1fr !important;
    gap: 0 !important;
    padding: 0 !important;
    border-top: 0 !important;
  }
  #${feature.legacyId} .feature-visual {
    width: 100% !important;
    border-radius: 0 !important;
    background: transparent !important;
    box-shadow: none !important;
  }
`
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@500&family=JetBrains+Mono:wght@400;700&family=Outfit:wght@300;500;700&display=swap" rel="stylesheet" />
    <style is:global set:html={`${styles}\n${scopedCss}`} />
  </head>
  <body>
    <Fragment set:html={bodyHtml} />
    {scripts.map((code) => <script is:inline set:html={code} />)}
  </body>
</html>
