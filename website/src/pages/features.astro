---
import { features, featurePath } from '../data/features.js'
import { loadLegacySegments } from '../lib/legacy.js'

const { styles, bodyHtml, scripts } = loadLegacySegments('features.html')
const featureLinks = features.map((feature) => ({
  legacyId: feature.legacyId,
  href: featurePath(feature),
  label: `Read more about ${feature.title}`,
}))

const enhancementStyles = `
  .feature-text { display: flex; flex-direction: column; align-items: flex-start; }
  .feature-section {
    position: relative;
    cursor: pointer;
  }
  .feature-section + .feature-section {
    border-top: 0;
  }
  .feature-visual,
  .feature-text {
    position: relative;
    z-index: 2;
  }
  .feature-visual {
    pointer-events: auto;
    z-index: 6;
    transition: transform 0.35s ease, box-shadow 0.35s ease;
    transform-origin: left center;
  }
  .feature-visual:hover {
    z-index: 10;
    transform: scale(1.2);
    box-shadow: 0 18px 48px rgba(17, 20, 40, 0.16);
  }
  .feature-section:nth-child(even) .feature-visual {
    transform-origin: right center;
  }
  .feature-detail-link {
    position: relative;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 16px;
    padding: 0;
    border: 0;
    background: transparent;
    color: #5f6478;
    text-decoration: none;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.02em;
  }
  .feature-detail-link:hover {
    color: var(--accent);
  }
  .feature-detail-link {
    pointer-events: auto;
  }
  .feature-detail-link::after {
    content: '→';
    opacity: 0.82;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .feature-detail-link:hover::after {
    opacity: 1;
    transform: translateX(2px);
  }
  .feature-detail-noscript {
    max-width: 960px;
    margin: 0 auto 72px;
    padding: 0 24px;
  }
  .feature-detail-noscript h2 {
    font-size: 18px;
    margin: 0 0 12px;
    letter-spacing: -0.04em;
  }
  .feature-detail-noscript ul {
    margin: 0;
    padding-left: 18px;
    color: #555;
  }
  .feature-detail-noscript a { color: var(--accent); }
  @media (max-width: 800px) {
    .feature-visual {
      transform: none !important;
    }
    .feature-visual:hover {
      transform: none !important;
      box-shadow: none;
    }
  }
`
