---
import SocialLinks from './SocialLinks.astro'

const { current = '' } = Astro.props
---

<nav class="site-nav">
  <a href="/" class="logo">Slay<span class="slash">/</span>Zone</a>
  <div class="nav-right">
    <ul class="nav-links" aria-label="Primary">
      <li><a href="/faq" aria-current={current === 'faq' ? 'page' : undefined}>FAQ</a></li>
      <li><a href="/docs" aria-current={current === 'docs' ? 'page' : undefined}>Docs</a></li>
    </ul>
    <div class="social-links" aria-label="Social links">
      <SocialLinks />
    </div>
  </div>
</nav>
